---
// Site-wide 3D butterfly that swirls around the viewport as you scroll.
// Fixed full-viewport canvas, pointer-events-none, sits above content but below the nav.
// Hides itself on reduced motion or WebGL failure.
---

<div id="bf-rider" class="pointer-events-none fixed inset-0 z-30" aria-hidden="true">
  <canvas id="bf-canvas" class="absolute inset-0 h-full w-full"></canvas>
</div>

<script>
  async function initButterflyRider() {
    const wrap = document.getElementById('bf-rider');
    const canvas = document.getElementById('bf-canvas') as HTMLCanvasElement | null;
    if (!wrap || !canvas || canvas.dataset.init) return;
    canvas.dataset.init = '1'; // guard BEFORE any await — also called from astro:page-load

    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      wrap.style.display = 'none';
      return;
    }

    let THREE;
    try {
      THREE = await import('three');
    } catch {
      wrap.style.display = 'none';
      return;
    }

    let renderer: any;
    try {
      renderer = new THREE.WebGLRenderer({ canvas, alpha: true, antialias: true });
    } catch {
      wrap.style.display = 'none';
      return;
    }
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));

    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(45, 1, 0.1, 30);
    camera.position.z = 6;

    const VIOLET = new THREE.Color('#8b5cf6');
    const VIOLET_LIGHT = new THREE.Color('#c4b5fd');
    const SPARK_TEAL = new THREE.Color('#2dd4bf');
    const SPARK_BLUE = new THREE.Color('#38bdf8');
    const MAGENTA = new THREE.Color('#ff2d78');

    // ---- Butterfly (tube line-art from branding/kaira-mark.svg) ----
    // Coordinates are the mark's 520-space divided by 5.2 (body center ~50,50).
    const S = 0.0062;
    const P = (x: number, y: number) => new THREE.Vector3((x - 50) * S, (50 - y) * S, 0);

    // Right-side wing loops as cubic segments [x0,y0, c1x,c1y, c2x,c2y, x1,y1];
    // the left side is the mirrored group. Upper = big teardrop out+up,
    // lower = slim teardrop down — the mark's silhouette.
    const upperLoop = [
      [51.2, 46.9, 59.6, 34.2, 75.4, 26.5, 81.5, 32.7],
      [81.5, 32.7, 87.3, 38.5, 77.7, 50.4, 66.2, 51.5],
      [66.2, 51.5, 59.6, 52.1, 53.8, 50.4, 51.2, 46.9],
    ];
    const lowerLoop = [
      [51.5, 54.2, 58.5, 61.5, 65.8, 74.2, 60.8, 79.2],
      [60.8, 79.2, 56.2, 83.8, 48.5, 74.6, 49.6, 63.5],
      [49.6, 63.5, 50.0, 59.6, 50.4, 56.5, 51.5, 54.2],
    ];

    const butterfly = new THREE.Group();
    const bfMats: any[] = []; // every butterfly material — for the behind-the-orb fade

    function tubeMat(color: any, opacity: number) {
      const mat = new THREE.MeshBasicMaterial({ color, transparent: true, opacity, blending: THREE.AdditiveBlending, depthWrite: false });
      mat.userData.baseOpacity = mat.opacity;
      bfMats.push(mat);
      return mat;
    }

    function addLoop(group: any, loop: number[][], color: any) {
      for (const seg of loop) {
        const curve = new THREE.CubicBezierCurve3(
          P(seg[0], seg[1]),
          P(seg[2], seg[3]),
          P(seg[4], seg[5]),
          P(seg[6], seg[7])
        );
        group.add(new THREE.Mesh(new THREE.TubeGeometry(curve, 32, 0.009, 6, false), tubeMat(color, 0.95)));
      }
    }

    // Spectrum wings, matching the mark: teal / blue up top, light-violet /
    // magenta below. Mirroring flips geometry, so colors are set per side.
    function buildWingSide(sign: number, upperColor: any, lowerColor: any) {
      const side = new THREE.Group();
      addLoop(side, upperLoop, upperColor);
      addLoop(side, lowerLoop, lowerColor);
      side.scale.x = sign;
      return side;
    }
    const rightWing = buildWingSide(1, SPARK_BLUE, MAGENTA);
    const leftWing = buildWingSide(-1, SPARK_TEAL, VIOLET_LIGHT);
    butterfly.add(rightWing, leftWing);

    // Body + antennae (violet family, like the mark)
    const bodyMat = tubeMat(VIOLET, 0.9);
    butterfly.add(new THREE.Mesh(new THREE.TubeGeometry(new THREE.LineCurve3(P(50, 41), P(50, 70.4)), 2, 0.011, 6, false), bodyMat));
    const antennaeMat = tubeMat(VIOLET_LIGHT, 0.85);
    for (const sign of [1, -1]) {
      const curve = new THREE.QuadraticBezierCurve3(P(50 + sign * 1.5, 40), P(50 + sign * 4.6, 32), P(50 + sign * 12.3, 28.8));
      butterfly.add(new THREE.Mesh(new THREE.TubeGeometry(curve, 12, 0.006, 5, false), antennaeMat));
    }

    // Soft glow behind it
    const glowCanvas = document.createElement('canvas');
    glowCanvas.width = glowCanvas.height = 128;
    const gctx = glowCanvas.getContext('2d')!;
    const grad = gctx.createRadialGradient(64, 64, 0, 64, 64, 64);
    grad.addColorStop(0, 'rgba(196,181,253,0.75)');
    grad.addColorStop(0.5, 'rgba(139,92,246,0.22)');
    grad.addColorStop(1, 'rgba(139,92,246,0)');
    gctx.fillStyle = grad;
    gctx.fillRect(0, 0, 128, 128);
    const glowTex = new THREE.CanvasTexture(glowCanvas);
    const glowMat = new THREE.SpriteMaterial({ map: glowTex, transparent: true, opacity: 0.45, blending: THREE.AdditiveBlending, depthWrite: false });
    glowMat.userData.baseOpacity = glowMat.opacity;
    bfMats.push(glowMat);
    const glow = new THREE.Sprite(glowMat);
    glow.scale.setScalar(0.85);
    butterfly.add(glow);

    butterfly.rotation.x = -0.45;
    butterfly.scale.setScalar(0.8);
    scene.add(butterfly);

    // ---- Faint glowing trail (ring buffer of fading sprites) ----
    const TRAIL = 24;
    const trailPts: any[] = [];
    const trailSprites: any[] = [];
    for (let i = 0; i < TRAIL; i++) {
      const m = new THREE.SpriteMaterial({ map: glowTex, transparent: true, opacity: 0, blending: THREE.AdditiveBlending, depthWrite: false });
      const s = new THREE.Sprite(m);
      const k = 1 - i / TRAIL;
      s.scale.setScalar(0.05 + k * 0.22);
      scene.add(s);
      trailSprites.push(s);
    }

    // ---- Sizing (viewport-fixed canvas) ----
    let visH = 5.0, visW = 5.0;
    function resize() {
      const w = window.innerWidth;
      const h = window.innerHeight;
      renderer.setSize(w, h, false);
      camera.aspect = w / h;
      camera.updateProjectionMatrix();
      visH = 2 * camera.position.z * Math.tan((camera.fov * Math.PI) / 360);
      visW = visH * camera.aspect;
      butterfly.scale.setScalar(Math.min(1, w / 900) * 0.55 + 0.35);
    }
    resize();
    window.addEventListener('resize', resize);

    // ---- Scroll progress over the whole document, eased per-frame ----
    let targetP = 0;
    function onScroll() {
      const doc = document.documentElement;
      const range = doc.scrollHeight - window.innerHeight;
      targetP = range > 0 ? window.scrollY / range : 0;
    }
    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });

    let sp = targetP;
    let lastT = 0;
    let bank = 0; // smoothed banking angle
    let flapPhase = 0; // accumulated so frequency changes never snap the wings
    const prev = new THREE.Vector3();
    const smooth = (x: number) => {
      const c = Math.min(1, Math.max(0, x));
      return c * c * (3 - 2 * c);
    };

    // The hero orb (homepage only) publishes its screen geometry via window.__kairaOrb.
    function getOrb() {
      const d = (window as any).__kairaOrb;
      if (!d || !d.section || !d.section.isConnected) return null;
      const rect = d.section.getBoundingClientRect();
      if (rect.bottom < -80) return null; // hero fully scrolled away
      return {
        cx: rect.left + rect.width / 2,
        cy: rect.top + d.pxFromTop,
        rPx: d.diameterPx / 2,
        prog: Math.min(1, Math.max(0, -rect.top / (rect.height * 0.75))),
      };
    }

    function tick(t: number) {
      requestAnimationFrame(tick);
      const dt = Math.min((t - lastT) / 1000, 0.05) || 0.016;
      lastT = t;
      const ts = t / 1000;

      // ease scroll progress — this is what makes the swirl feel liquid
      sp += (targetP - sp) * Math.min(1, dt * 5);

      // Swirl path: scroll drives the loop phase, time adds idle wander
      const ang = sp * Math.PI * 5;
      const xN = Math.sin(ang + ts * 0.22) * 0.62 + Math.cos(ts * 0.47) * 0.07;
      const yN = Math.cos(ang * 0.8 + ts * 0.13) * 0.46 + Math.sin(ts * 0.61) * 0.05;
      let px = (xN * visW) / 2 * 0.85;
      let py = (yN * visH) / 2 * 0.8;
      let pz = Math.sin(ang * 0.5 + ts * 0.1) * 1.1;
      let fade = 1;

      // Orbit choreography: circle the hero orb, complete one revolution as the
      // hero scrolls by, then peel off down into the page (blend into the swirl).
      const orb = getOrb();
      if (orb) {
        const wpp = visH / window.innerHeight; // world units per px
        const ocx = (orb.cx / window.innerWidth - 0.5) * visW;
        const ocy = (0.5 - orb.cy / window.innerHeight) * visH;
        const oR = orb.rPx * wpp * 1.5;
        // slow idle circling at rest; scroll drives exactly one extra revolution
        const oa = -Math.PI / 3 + ts * 0.3 + smooth(orb.prog / 0.6) * Math.PI * 2;
        const oz = -Math.sin(oa) * 1.3; // depth: swings in front of and behind the orb
        // pre-compensate perspective so the orbit visually hugs the orb at any depth
        const persp = (camera.position.z - oz) / camera.position.z;
        const ox = (ocx + Math.cos(oa) * oR) * persp;
        const oy = (ocy + Math.sin(oa) * oR * 0.34 + Math.sin(ts * 1.7) * 0.04) * persp;
        // hand-off: orbit owns the first ~60% of the hero scroll, then blends into the swirl
        const blend = smooth((orb.prog - 0.58) / 0.42);
        px = ox + (px - ox) * blend;
        py = oy + (py - oy) * blend;
        pz = oz + (pz - oz) * blend;
        // dim slightly while passing behind the sphere
        fade = 1 - Math.max(0, -oz / 1.3) * 0.55 * (1 - blend);
      }

      prev.copy(butterfly.position);
      butterfly.position.set(px, py, pz);
      for (const m of bfMats) m.opacity = m.userData.baseOpacity * fade;

      // Teleport guard: on scroll jumps / page transitions the path can leap —
      // clear the trail so it doesn't spray dots across the screen.
      const jump = butterfly.position.distanceTo(prev);
      if (jump > 1.2) trailPts.length = 0;

      // bank into turns (smoothed — no snap), flutter gently faster when moving
      const vx = (butterfly.position.x - prev.x) / Math.max(dt, 0.001);
      const speed = Math.min(jump / Math.max(dt, 0.001), 3);
      const bankTarget = Math.max(-0.45, Math.min(0.45, -vx * 0.14)) + Math.sin(ts * 1.1) * 0.05;
      bank += (bankTarget - bank) * Math.min(1, dt * 6);
      butterfly.rotation.z = bank;
      butterfly.rotation.y = -0.3 + Math.sin(ang) * 0.3;

      flapPhase += dt * (5 + speed * 1.6);
      const flap = Math.sin(flapPhase) * 0.55;
      rightWing.rotation.y = flap;
      leftWing.rotation.y = -flap;

      // Trail: record position history, brighter when moving fast
      trailPts.unshift({ x: px, y: py, z: pz });
      if (trailPts.length > TRAIL * 2) trailPts.length = TRAIL * 2;
      const trailGain = Math.min(1, speed * 0.4 + 0.15) * fade;
      for (let i = 0; i < TRAIL; i++) {
        const pt = trailPts[Math.min(i * 2, trailPts.length - 1)];
        const s = trailSprites[i];
        if (!pt) {
          s.material.opacity = 0;
          continue;
        }
        s.position.set(pt.x, pt.y, pt.z);
        s.material.opacity = (1 - i / TRAIL) * 0.2 * trailGain;
      }

      renderer.render(scene, camera);
    }
    requestAnimationFrame(tick);
  }

  initButterflyRider();
  document.addEventListener('astro:page-load', initButterflyRider);
</script>
