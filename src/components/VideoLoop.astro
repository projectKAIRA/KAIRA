---
// Cinematic media slot. If `src` is provided, renders a lazy autoplaying loop
// (muted + playsinline, Apple-style ambient video). Without `src`, shows a
// designed "live render" panel — vivid aurora, faint grid, pulsing KAIRA mark —
// so the slot reads as intentional before footage exists.
import Butterfly from './Butterfly.astro';

interface Props {
  src?: string; // e.g. /media/showcase.mp4 (drop files in public/media/)
  poster?: string;
  label?: string; // small HUD caption over the corner
  class?: string;
  ratio?: string; // css aspect-ratio, default 16/9
}
const { src, poster, label, class: className = '', ratio = '16 / 9' } = Astro.props;
---

<div
  class={`glass relative overflow-hidden rounded-3xl ${className}`}
  style={`aspect-ratio: ${ratio};`}
>
  {
    src ? (
      <video
        class="absolute inset-0 h-full w-full object-cover"
        src={src}
        poster={poster}
        autoplay
        muted
        loop
        playsinline
        preload="none"
      />
    ) : (
      <div aria-hidden="true" class="absolute inset-0">
        <div class="video-fallback absolute inset-0"></div>
        <div class="video-grid absolute inset-0"></div>
        <div class="absolute inset-0 grid place-items-center">
          <Butterfly class="mark-pulse h-16 w-16 sm:h-20 sm:w-20" />
        </div>
        <span class="hud-label absolute bottom-4 right-4 text-white/40">RENDER.LOOP <span class="text-white/20">//</span> STANDBY</span>
      </div>
    )
  }
  {label && (
    <span class="hud-label absolute left-4 top-4 z-[1] rounded-full border border-white/10 bg-black/40 px-3 py-1 backdrop-blur">
      {label}
    </span>
  )}
</div>

<style>
  /* Animated spectrum aurora — GPU-cheap, background-position only */
  .video-fallback {
    background:
      radial-gradient(60% 80% at 20% 80%, rgba(45, 212, 191, 0.42) 0%, transparent 62%),
      radial-gradient(55% 70% at 80% 20%, rgba(139, 92, 246, 0.50) 0%, transparent 62%),
      radial-gradient(50% 60% at 70% 90%, rgba(255, 45, 120, 0.30) 0%, transparent 58%),
      radial-gradient(45% 65% at 30% 15%, rgba(56, 189, 248, 0.38) 0%, transparent 62%),
      #0a0a0e;
    background-size: 180% 180%;
    animation: aurora 16s ease-in-out infinite alternate;
  }
  @keyframes aurora {
    0% { background-position: 0% 0%, 100% 100%, 50% 0%, 0% 100%, 0 0; }
    100% { background-position: 100% 100%, 0% 0%, 20% 100%, 100% 0%, 0 0; }
  }

  /* Faint blueprint grid + vignette so the panel reads as a "render viewport" */
  .video-grid {
    background:
      linear-gradient(rgba(255, 255, 255, 0.045) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.045) 1px, transparent 1px);
    background-size: 44px 44px;
    mask-image: radial-gradient(ellipse 90% 85% at 50% 50%, black 30%, transparent 85%);
    -webkit-mask-image: radial-gradient(ellipse 90% 85% at 50% 50%, black 30%, transparent 85%);
  }

  .mark-pulse {
    opacity: 0.85;
    filter: drop-shadow(0 0 22px rgba(167, 139, 250, 0.55));
    animation: mark-breathe 4.5s ease-in-out infinite;
  }
  @keyframes mark-breathe {
    0%, 100% { transform: scale(1); opacity: 0.85; }
    50% { transform: scale(1.07); opacity: 1; }
  }

  @media (prefers-reduced-motion: reduce) {
    .video-fallback, .mark-pulse { animation: none; }
  }
</style>
