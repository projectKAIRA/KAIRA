---
const links = [
  { href: '/services', label: 'Services' },
  { href: '/portfolio', label: 'Work' },
  { href: '/pricing', label: 'Pricing' },
  { href: '/about', label: 'About' },
];
const current = Astro.url.pathname;
---

<header
  class="sticky top-0 z-40 border-b border-purple/10 bg-white/70 backdrop-blur-xl backdrop-saturate-150"
>
  <nav aria-label="Main" class="mx-auto flex max-w-6xl items-center justify-between px-5 py-4">
    <a href="/" class="text-xl font-bold tracking-tight text-ink">
      KAIRA<span class="text-purple">.</span>
    </a>

    <ul class="hidden items-center gap-8 md:flex">
      {
        links.map((l) => (
          <li>
            <a
              href={l.href}
              aria-current={current === l.href || current === l.href + '/' ? 'page' : undefined}
              class:list={[
                'text-sm font-medium transition-colors duration-150',
                current.startsWith(l.href) ? 'text-purple' : 'text-ink-soft hover:text-purple',
              ]}
            >
              {l.label}
            </a>
          </li>
        ))
      }
    </ul>

    <div class="flex items-center gap-3">
      <a
        href="/contact"
        class="hidden rounded-full bg-purple px-5 py-2 text-sm font-semibold text-white shadow-(--shadow-cta) transition-transform duration-150 ease-(--ease-press) hover:scale-[1.03] active:scale-[0.98] md:inline-block"
      >
        Get a Quote
      </a>

      <button
        id="nav-toggle"
        type="button"
        class="flex h-10 w-10 items-center justify-center rounded-lg text-ink md:hidden"
        aria-expanded="false"
        aria-controls="mobile-menu"
        aria-label="Open menu"
      >
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <path class="menu-open" d="M4 7h16M4 12h16M4 17h16" />
          <path class="menu-close hidden" d="M6 6l12 12M18 6L6 18" />
        </svg>
      </button>
    </div>
  </nav>

  <div id="mobile-menu" class="hidden border-t border-purple/10 bg-white/95 px-5 pb-5 pt-3 md:hidden">
    <ul class="flex flex-col gap-1">
      {
        links.map((l) => (
          <li>
            <a href={l.href} class="block rounded-lg px-3 py-2.5 text-base font-medium text-ink-soft hover:bg-purple-ghost hover:text-purple">
              {l.label}
            </a>
          </li>
        ))
      }
      <li class="mt-2">
        <a href="/contact" class="block rounded-full bg-purple px-5 py-2.5 text-center text-base font-semibold text-white">
          Get a Quote
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  const btn = document.getElementById('nav-toggle');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    const open = menu?.classList.toggle('hidden') === false;
    btn.setAttribute('aria-expanded', String(open));
    btn.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
    btn.querySelector('.menu-open')?.classList.toggle('hidden', open);
    btn.querySelector('.menu-close')?.classList.toggle('hidden', !open);
  });
</script>
