---
// KAIRA "K" monogram — geometric, gradient-filled, drop-in replacement
// for the previous butterfly mark. The file is still named Butterfly.astro
// for import compatibility, but the mark itself is now a modern K.
interface Props {
  class?: string;
  /** If true, wraps the K in a rounded-square badge (Apple app-icon style). */
  badge?: boolean;
}
const { class: className = 'h-9 w-9', badge = false } = Astro.props;

// Unique gradient id per instance so multiple logos on one page keep their fills.
const uid = 'k' + Math.random().toString(36).slice(2, 8);
---

<svg class={className} viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
  <defs>
    <linearGradient id={`${uid}-fill`} x1="0" y1="0" x2="1" y2="1">
      <stop offset="0"   stop-color="#0071e3"/>
      <stop offset="0.5" stop-color="#7c3aed"/>
      <stop offset="1"   stop-color="#ff375f"/>
    </linearGradient>
    <linearGradient id={`${uid}-badge`} x1="0" y1="0" x2="0" y2="1">
      <stop offset="0" stop-color="#ffffff"/>
      <stop offset="1" stop-color="#f5f5f7"/>
    </linearGradient>
  </defs>

  {badge && (
    <rect x="4" y="4" width="92" height="92" rx="22" fill={`url(#${uid}-badge)`} stroke="rgba(0,0,0,0.06)"/>
  )}

  <!-- Geometric K: filled monogram with a gradient inline stroke on the diagonals.
       Two shapes: the vertical bar (rounded rect) and a wedge forming the two arms. -->
  <g>
    <!-- Vertical bar -->
    <rect x="20" y="14" width="15" height="72" rx="3" fill={`url(#${uid}-fill)`}/>

    <!-- Upper arm (from mid-vertical up to top-right) -->
    <path
      d="M 35 46 L 68 14 L 84 14 L 46 50 Z"
      fill={`url(#${uid}-fill)`}
    />
    <!-- Lower arm (from mid-vertical down to bottom-right) -->
    <path
      d="M 35 54 L 46 50 L 84 86 L 68 86 Z"
      fill={`url(#${uid}-fill)`}
    />
  </g>
</svg>
