---
// Full-viewport cinematic type moment ("Fast runs in the family."-style):
// huge word-by-word reveal with a spectrum gradient phrase.
// Pass the plain lead-in via `lead` and the gradient payoff via `punch`.
interface Props {
  lead?: string;
  punch: string;
  sub?: string; // optional smaller line underneath
  class?: string;
}
const { lead = '', punch, sub, class: className = '' } = Astro.props;
---

<section class={`flex min-h-[70vh] items-center justify-center px-5 py-24 md:min-h-[85vh] ${className}`}>
  <div class="mx-auto max-w-4xl text-center">
    <p class="reveal-words text-4xl font-bold leading-[1.08] tracking-tight text-ink sm:text-6xl md:text-7xl">
      {lead && <span>{lead} </span>}
      <span class="grad-text">{punch}</span>
    </p>
    {sub && (
      <p class="scrub scrub-fade mx-auto mt-8 max-w-xl text-lg leading-relaxed text-ink-soft md:text-xl">
        {sub}
      </p>
    )}
  </div>
</section>
