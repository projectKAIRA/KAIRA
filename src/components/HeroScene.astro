---
// Full-bleed three.js hero scene, Monday-style:
// purple fresnel orb + equalizer bars, cyan wireframe shell, orbit rings (one dashed,
// one carrying a magenta node), particle starfield — and the KAIRA butterfly as 3D
// line-art that flies into the orb as you scroll.
// Client-only island; hides itself on reduced motion or WebGL failure.
---

<div id="hero-scene" class="pointer-events-none absolute inset-0" aria-hidden="true">
  <canvas id="hero-canvas" class="absolute inset-0 h-full w-full"></canvas>
</div>

<script>
  async function initHeroScene() {
    const wrap = document.getElementById('hero-scene');
    const canvas = document.getElementById('hero-canvas') as HTMLCanvasElement | null;
    const section = wrap?.closest('section');
    if (!wrap || !canvas || !section || canvas.dataset.init) return;
    canvas.dataset.init = '1'; // guard BEFORE any await — init is also called from astro:page-load

    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      wrap.style.display = 'none';
      return;
    }

    let THREE;
    try {
      THREE = await import('three');
    } catch {
      wrap.style.display = 'none';
      return;
    }

    let renderer: any;
    try {
      renderer = new THREE.WebGLRenderer({ canvas, alpha: true, antialias: true });
    } catch {
      wrap.style.display = 'none';
      return;
    }
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));

    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(45, 1, 0.1, 60);
    camera.position.z = 7;

    const VIOLET = new THREE.Color('#8b5cf6');
    const VIOLET_LIGHT = new THREE.Color('#c4b5fd');
    const CYAN = new THREE.Color('#00e5ff');
    const MAGENTA = new THREE.Color('#ff2d78');

    // ---------- Orb group ----------
    const orb = new THREE.Group();
    scene.add(orb);

    // Fresnel-glow core — purple
    const coreMat = new THREE.ShaderMaterial({
      transparent: true,
      uniforms: { uTime: { value: 0 } },
      vertexShader: `
        uniform float uTime;
        varying vec3 vNormal, vView;
        void main() {
          vec3 p = position + normal * (sin(uTime * 1.4 + position.y * 4.0) * 0.03);
          vec4 mv = modelViewMatrix * vec4(p, 1.0);
          vNormal = normalMatrix * normal;
          vView = -mv.xyz;
          gl_Position = projectionMatrix * mv;
        }`,
      fragmentShader: `
        varying vec3 vNormal, vView;
        void main() {
          float fr = pow(1.0 - abs(dot(normalize(vView), normalize(vNormal))), 2.0);
          vec3 deep = vec3(0.07, 0.04, 0.18);
          vec3 violet = vec3(0.55, 0.36, 0.97);
          gl_FragColor = vec4(mix(deep, violet, fr), 0.60 + fr * 0.40);
        }`,
    });
    const core = new THREE.Mesh(new THREE.SphereGeometry(1.05, 48, 48), coreMat);
    orb.add(core);

    // Inner glow sprite
    const glowCanvas = document.createElement('canvas');
    glowCanvas.width = glowCanvas.height = 128;
    const gctx = glowCanvas.getContext('2d')!;
    const grad = gctx.createRadialGradient(64, 64, 0, 64, 64, 64);
    grad.addColorStop(0, 'rgba(167,139,250,0.9)');
    grad.addColorStop(0.4, 'rgba(139,92,246,0.35)');
    grad.addColorStop(1, 'rgba(139,92,246,0)');
    gctx.fillStyle = grad;
    gctx.fillRect(0, 0, 128, 128);
    const glow = new THREE.Sprite(
      new THREE.SpriteMaterial({ map: new THREE.CanvasTexture(glowCanvas), transparent: true, opacity: 0.85, blending: THREE.AdditiveBlending, depthWrite: false })
    );
    glow.scale.setScalar(2.25);
    orb.add(glow);

    // Equalizer bars inside the core (the Monday signature)
    const bars: any[] = [];
    const barGroup = new THREE.Group();
    for (let i = 0; i < 5; i++) {
      const bar = new THREE.Mesh(
        new THREE.BoxGeometry(0.05, 1, 0.05),
        new THREE.MeshBasicMaterial({ color: VIOLET_LIGHT, transparent: true, opacity: 0.85, blending: THREE.AdditiveBlending, depthWrite: false })
      );
      bar.position.x = (i - 2) * 0.11;
      bars.push(bar);
      barGroup.add(bar);
    }
    barGroup.position.z = 1.12; // just in front of the core surface so depth doesn't occlude
    orb.add(barGroup);

    // Wireframe icosahedron shell — cyan, subtle
    const shell = new THREE.Mesh(
      new THREE.IcosahedronGeometry(1.62, 1),
      new THREE.MeshBasicMaterial({ color: CYAN, wireframe: true, transparent: true, opacity: 0.13, blending: THREE.AdditiveBlending })
    );
    orb.add(shell);

    // Solid orbit rings
    const rings: any[] = [];
    [
      { r: 2.15, tilt: [Math.PI / 2.15, 0.15], color: CYAN, op: 0.35 },
      { r: 2.55, tilt: [Math.PI / 2.6, -0.5], color: CYAN, op: 0.22 },
    ].forEach((cfg) => {
      const ring = new THREE.Mesh(
        new THREE.TorusGeometry(cfg.r, 0.006, 8, 128),
        new THREE.MeshBasicMaterial({ color: cfg.color, transparent: true, opacity: cfg.op, blending: THREE.AdditiveBlending })
      );
      ring.rotation.set(cfg.tilt[0], 0, cfg.tilt[1]);
      rings.push(ring);
      orb.add(ring);
    });

    // Dashed equator ring
    const dashPts = new THREE.EllipseCurve(0, 0, 3.0, 3.0, 0, Math.PI * 2, false, 0).getPoints(160);
    const dashGeo = new THREE.BufferGeometry().setFromPoints(dashPts.map((p: any) => new THREE.Vector3(p.x, p.y, 0)));
    const dashRing = new THREE.Line(
      dashGeo,
    new THREE.LineDashedMaterial({ color: CYAN, dashSize: 0.16, gapSize: 0.12, transparent: true, opacity: 0.4 })
    );
    dashRing.computeLineDistances();
    dashRing.rotation.x = Math.PI / 2.3;
    dashRing.rotation.z = 0.3;
    rings.push(dashRing);
    orb.add(dashRing);

    // Magenta node riding the dashed ring
    const node = new THREE.Mesh(
      new THREE.SphereGeometry(0.045, 12, 12),
      new THREE.MeshBasicMaterial({ color: MAGENTA, transparent: true, opacity: 0.95 })
    );
    dashRing.add(node);

    // ---------- Starfield ----------
    const N = 700;
    const pos = new Float32Array(N * 3);
    for (let i = 0; i < N; i++) {
      // deterministic pseudo-random spread (keeps SSR/replay stable)
      const a = Math.sin(i * 12.9898) * 43758.5453;
      const b = Math.sin(i * 78.233) * 12543.2341;
      const c = Math.sin(i * 39.425) * 26431.5327;
      pos[i * 3] = ((a - Math.floor(a)) - 0.5) * 12;
      pos[i * 3 + 1] = ((b - Math.floor(b)) - 0.5) * 8;
      pos[i * 3 + 2] = ((c - Math.floor(c)) - 0.5) * 4 - 1;
    }
    const starGeo = new THREE.BufferGeometry();
    starGeo.setAttribute('position', new THREE.BufferAttribute(pos, 3));
    const stars = new THREE.Points(
      starGeo,
      new THREE.PointsMaterial({ color: 0x9bb8c8, size: 0.015, transparent: true, opacity: 0.55, blending: THREE.AdditiveBlending, depthWrite: false })
    );
    scene.add(stars);


    // ---------- Layout: keep the orb centered in the visual "orb zone" ----------
    let visH = 5.8, visW = 5.8;
    const ORB_PX_FROM_TOP = 250; // px — matches the hero's pt spacing
    function resize() {
      const w = section!.clientWidth;
      const h = section!.clientHeight;
      renderer.setSize(w, h, false);
      camera.aspect = w / h;
      camera.updateProjectionMatrix();
      visH = 2 * camera.position.z * Math.tan((camera.fov * Math.PI) / 360);
      visW = visH * camera.aspect;
      orb.position.y = (0.5 - ORB_PX_FROM_TOP / h) * visH;
      // size the orb to a target pixel diameter so it never swallows the viewport
      const unitPx = h / visH; // px per world unit at z=0
      const targetPx = Math.min(w * 0.48, 340);
      orb.scale.setScalar(targetPx / (2.1 * unitPx));
      // Publish orb screen geometry so the site-wide ButterflyRider can orbit it.
      (window as any).__kairaOrb = { section, pxFromTop: ORB_PX_FROM_TOP, diameterPx: targetPx };
    }
    resize();
    // ResizeObserver, not window.resize — the section grows after fonts/content load
    new ResizeObserver(resize).observe(section);

    // ---------- Scroll + pointer state ----------
    let scrollP = 0;
    function onScroll() {
      const range = section!.offsetHeight * 0.7;
      scrollP = Math.min(1, Math.max(0, window.scrollY / range));
    }
    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });

    let mx = 0, my = 0, cmx = 0, cmy = 0;
    window.addEventListener('pointermove', (e) => {
      mx = (e.clientX / window.innerWidth - 0.5) * 2;
      my = (e.clientY / window.innerHeight - 0.5) * 2;
    }, { passive: true });

    let visible = true;
    new IntersectionObserver(([e]) => { visible = e.isIntersecting; }, { threshold: 0 }).observe(section);

    // ---------- Render loop ----------
    let lastT = 0;

    function tick(t: number) {
      requestAnimationFrame(tick);
      if (!visible) return;
      const dt = Math.min((t - lastT) / 1000, 0.05) || 0.016;
      lastT = t;
      const ts = t / 1000;

      // eased scroll progress
      const p = scrollP * scrollP * (3 - 2 * scrollP);

      // Orb life
      coreMat.uniforms.uTime.value = ts;
      const boost = 1 + p * 1.6;
      core.rotation.y += dt * 0.1;
      shell.rotation.y += dt * 0.12 * boost;
      shell.rotation.x += dt * 0.04;
      rings[0].rotation.y += dt * 0.4 * boost;
      rings[1].rotation.y -= dt * 0.28 * boost;
      rings[2].rotation.z += dt * 0.18 * boost;
      const pulse = 1 + Math.sin(ts * 2.2) * 0.015 + p * 0.05;
      core.scale.setScalar(pulse);
      glow.material.opacity = 0.7 + Math.sin(ts * 2.2) * 0.12 + p * 0.15;

      // Equalizer bars
      bars.forEach((bar, i) => {
        const h = 0.14 + Math.abs(Math.sin(ts * (2.1 + i * 0.37) + i * 1.7)) * (0.34 + p * 0.2);
        bar.scale.y = h;
      });

      // Magenta node rides the dashed ring
      const na = ts * 0.5;
      node.position.set(Math.cos(na) * 3.0, Math.sin(na) * 3.0, 0);

      // Starfield drift + camera parallax
      stars.rotation.y += dt * 0.008;
      cmx += (mx - cmx) * 0.04;
      cmy += (my - cmy) * 0.04;
      camera.position.x = cmx * 0.5 + Math.sin(ts * 0.12) * 0.12;
      camera.position.y = -cmy * 0.25;
      camera.lookAt(0, 0, 0);

      renderer.render(scene, camera);
    }
    requestAnimationFrame(tick);
  }

  initHeroScene();
  document.addEventListener('astro:page-load', initHeroScene);
</script>
