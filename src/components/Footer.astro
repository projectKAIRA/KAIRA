---
import Butterfly from './Butterfly.astro';
const year = new Date().getFullYear();
---

<footer class="relative z-[2] border-t border-black/[0.06] bg-[#f5f5f7]">
  <!-- spectrum hairline -->
  <div
    aria-hidden="true"
    class="h-px w-full opacity-60"
    style="background: linear-gradient(90deg, transparent, #0071e3 20%, #7c3aed 50%, #ff375f 80%, transparent);"
  >
  </div>
  <div class="mx-auto max-w-6xl px-5 py-12">
    <div class="flex flex-col gap-10 md:flex-row md:justify-between">
      <div class="max-w-sm">
        <p class="flex items-center gap-2 text-lg font-bold tracking-[0.15em] text-ink uppercase">
          <Butterfly class="h-7 w-7" /> Kaira
        </p>
        <p class="mt-3 text-sm leading-relaxed text-ink-muted">
          Modern websites, SEO fundamentals, and ongoing maintenance for local businesses ready to
          stand out online.
        </p>
      </div>

      <nav aria-label="Footer" class="grid grid-cols-2 gap-8 text-sm sm:grid-cols-3">
        <div>
          <p class="font-semibold text-ink">Company</p>
          <ul class="mt-3 space-y-2">
            <li><a href="/about" class="text-ink-muted transition-colors hover:text-ink">About</a></li>
            <li><a href="/portfolio" class="text-ink-muted transition-colors hover:text-ink">Work</a></li>
            <li><a href="/contact" class="text-ink-muted transition-colors hover:text-ink">Contact</a></li>
          </ul>
        </div>
        <div>
          <p class="font-semibold text-ink">Services</p>
          <ul class="mt-3 space-y-2">
            <li><a href="/services" class="text-ink-muted transition-colors hover:text-ink">Web Design</a></li>
            <li><a href="/services" class="text-ink-muted transition-colors hover:text-ink">SEO</a></li>
            <li><a href="/services" class="text-ink-muted transition-colors hover:text-ink">Maintenance</a></li>
          </ul>
        </div>
        <div>
          <p class="font-semibold text-ink">Legal</p>
          <ul class="mt-3 space-y-2">
            <li><a href="/privacy" class="text-ink-muted transition-colors hover:text-ink">Privacy</a></li>
            <li><a href="/terms" class="text-ink-muted transition-colors hover:text-ink">Terms</a></li>
          </ul>
        </div>
      </nav>
    </div>

    <div class="mt-10 flex flex-col gap-4 border-t border-black/[0.06] pt-6 sm:flex-row sm:items-center sm:justify-between">
      <div class="flex flex-wrap items-center gap-x-5 gap-y-2" aria-hidden="true">
        <span class="hud-label flex items-center gap-2"><span class="status-dot"></span> Design ready</span>
        <span class="hud-label flex items-center gap-2"><span class="status-dot"></span> SEO ready</span>
        <span class="hud-label flex items-center gap-2"><span class="status-dot status-dot--violet"></span> Maintenance ready</span>
      </div>
      <p class="text-xs text-ink-muted">&copy; {year} KAIRA. All rights reserved.</p>
    </div>
  </div>
</footer>
