---
import Butterfly from './Butterfly.astro';
const year = new Date().getFullYear();
---

<footer class="relative z-[2] border-t border-white/[0.07] bg-[#0a0a0c]/55 backdrop-blur-lg">
  <div class="mx-auto max-w-6xl px-5 py-12">
    <div class="flex flex-col gap-10 md:flex-row md:justify-between">
      <div class="max-w-sm">
        <p class="flex items-center gap-2 text-lg font-bold tracking-[0.15em] text-ink uppercase">
          <Butterfly class="h-7 w-7" /> Kaira
        </p>
        <p class="mt-2 text-sm leading-relaxed text-ink-muted">
          Modern websites, SEO fundamentals, and ongoing maintenance for local businesses ready to
          stand out online.
        </p>
      </div>

      <nav aria-label="Footer" class="grid grid-cols-2 gap-8 text-sm sm:grid-cols-3">
        <div>
          <p class="font-semibold text-ink">Company</p>
          <ul class="mt-3 space-y-2">
            <li><a href="/about" class="text-ink-muted hover:text-purple">About</a></li>
            <li><a href="/portfolio" class="text-ink-muted hover:text-purple">Work</a></li>
            <li><a href="/contact" class="text-ink-muted hover:text-purple">Contact</a></li>
          </ul>
        </div>
        <div>
          <p class="font-semibold text-ink">Services</p>
          <ul class="mt-3 space-y-2">
            <li><a href="/services" class="text-ink-muted hover:text-purple">Web Design</a></li>
            <li><a href="/services" class="text-ink-muted hover:text-purple">SEO</a></li>
            <li><a href="/services" class="text-ink-muted hover:text-purple">Maintenance</a></li>
          </ul>
        </div>
        <div>
          <p class="font-semibold text-ink">Legal</p>
          <ul class="mt-3 space-y-2">
            <li><a href="/privacy" class="text-ink-muted hover:text-purple">Privacy</a></li>
            <li><a href="/terms" class="text-ink-muted hover:text-purple">Terms</a></li>
          </ul>
        </div>
      </nav>
    </div>

    <p class="mt-10 border-t border-white/[0.07] pt-6 text-xs text-ink-muted">
      &copy; {year} KAIRA. All rights reserved.
    </p>
  </div>
</footer>
