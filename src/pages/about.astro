---
import Base from '../layouts/Base.astro';

const values = [
  {
    title: 'Local-first',
    body: 'We build for local businesses — the shops, services, and professionals that keep communities running.',
  },
  {
    title: 'No jargon',
    body: 'You shouldn’t need a translator to work with a web agency. We explain everything in plain language.',
  },
  {
    title: 'Speed matters',
    body: 'Fast sites rank better and convert better. Every site we ship is built for performance from the start.',
  },
  {
    title: 'Long-term partners',
    body: 'A website isn’t a one-time purchase. We stick around to keep it secure, current, and improving.',
  },
];
---

<Base
  title="About — KAIRA"
  description="KAIRA is a web design and digital presence agency helping local businesses look professional online and get found by nearby customers."
>
  <section class="mesh-bg">
    <div class="mx-auto max-w-3xl px-5 pb-16 pt-16 text-center md:pt-24">
      <p class="reveal hud-label mb-4">ABOUT · THE STUDIO</p>
      <h1 class="reveal-words text-4xl font-bold tracking-tight text-ink md:text-6xl">
        Big-league websites, <span class="grad-text">main-street prices.</span>
      </h1>
      <p class="reveal reveal-delay-1 mt-6 text-lg leading-relaxed text-ink-soft">
        Most local businesses know they need a better website — but agencies feel expensive,
        confusing, and slow. KAIRA exists to fix that.
      </p>
    </div>
  </section>

  <section class="mx-auto max-w-3xl px-5 py-8 md:py-12">
    <div class="reveal glass rounded-2xl p-8 md:p-10">
      <h2 class="text-2xl font-bold text-ink">Why we started</h2>
      <div class="mt-4 space-y-4 text-ink-soft leading-relaxed">
        <p>
          Great local businesses lose customers every day to competitors with better websites — not
          better products, not better service. Just a better first impression online.
        </p>
        <p>
          KAIRA was founded to level that playing field: modern, professional websites with real SEO
          fundamentals, at a price a local business can actually justify — starting at $1,000, with
          honest quotes and no lock-in.
        </p>
        <p>
          And because a website is never “done,” we offer ongoing maintenance and SEO so your online
          presence keeps working long after launch day.
        </p>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-5 py-12 md:py-16" aria-labelledby="values-heading">
    <h2 id="values-heading" class="reveal-words text-center text-3xl font-bold tracking-tight text-ink md:text-4xl">
      What <span class="grad-text">we believe</span>
    </h2>
    <div class="mt-10 grid gap-6 sm:grid-cols-2">
      {
        values.map((v, i) => {
          const accents = [
            ['#0071e3', '#5ac8fa'],
            ['#7c3aed', '#a78bfa'],
            ['#ff375f', '#ff9500'],
            ['#34c759', '#5ac8fa'],
          ][i % 4];
          return (
            <div
              class={`grad-border reveal reveal-delay-${i % 2} rounded-2xl p-7`}
              style={`--tile-a: ${accents[0]}; --tile-b: ${accents[1]};`}
            >
              <h3
                class="text-lg font-semibold"
                style={`background: linear-gradient(115deg, ${accents[0]}, ${accents[1]}); -webkit-background-clip: text; background-clip: text; color: transparent;`}
              >
                {v.title}
              </h3>
              <p class="mt-2 text-sm leading-relaxed text-ink-muted">{v.body}</p>
            </div>
          );
        })
      }
    </div>

    <div class="reveal mt-16 text-center">
      <a
        href="/contact"
        class="inline-block rounded-full bg-violet px-8 py-3.5 text-base font-semibold text-white shadow-(--shadow-cta) transition-transform duration-150 ease-(--ease-press) hover:scale-[1.03] active:scale-[0.98]"
      >
        Work With Us
      </a>
    </div>
  </section>
</Base>
