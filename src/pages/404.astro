---
import Base from '../layouts/Base.astro';
---

<Base
  title="Page Not Found — KAIRA"
  description="The page you requested could not be found."
>
  <section class="mesh-bg flex min-h-[70vh] items-center">
    <div class="mx-auto max-w-3xl px-5 py-24 text-center">
      <p class="hud-label">ERROR // 404</p>
      <h1 class="mt-5 text-5xl font-bold tracking-tight text-ink md:text-7xl">
        This page drifted <span class="grad-text">off course.</span>
      </h1>
      <p class="mx-auto mt-6 max-w-xl text-lg leading-relaxed text-ink-soft">
        The address may have changed, or the page may no longer exist. Let’s get you back to
        solid ground.
      </p>
      <a
        href="/"
        class="mt-8 inline-block rounded-full bg-violet px-8 py-3.5 text-base font-semibold text-white shadow-(--shadow-cta) transition-transform duration-150 ease-(--ease-press) hover:scale-[1.03] active:scale-[0.98]"
      >
        Return Home
      </a>
    </div>
  </section>
</Base>
