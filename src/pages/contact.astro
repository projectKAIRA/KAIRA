---
import Base from '../layouts/Base.astro';

const TURNSTILE_SITE_KEY = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY ?? '1x00000000000000000000AA'; // Cloudflare test key (always passes)

const serviceOptions = ['New Website', 'Website Redesign', 'SEO', 'Ongoing Maintenance', 'Not Sure Yet'];
const budgetOptions = ['$1,000 – $2,500', '$2,500 – $5,000', '$5,000+', 'Not sure yet'];
---

<Base
  title="Get a Free Quote — KAIRA"
  description="Tell us about your business and get a free website quote within one business day. Websites starting at $1,000."
>
  <section class="mesh-bg">
    <div class="mx-auto max-w-2xl px-5 pb-12 pt-16 text-center md:pt-24">
      <h1 class="reveal text-4xl font-bold tracking-tight text-ink md:text-5xl">
        Get your free quote
      </h1>
      <p class="reveal reveal-delay-1 mt-4 text-lg text-ink-soft">
        Tell us a bit about your business. We’ll reply within one business day — no pressure, no
        obligation.
      </p>
    </div>
  </section>

  <section class="mx-auto max-w-2xl px-5 pb-20 md:pb-28">
    <form id="quote-form" class="reveal glass rounded-2xl p-7 md:p-10" novalidate>
      <div class="grid gap-6 sm:grid-cols-2">
        <div>
          <label for="name" class="block text-sm font-semibold text-ink">Your name <span aria-hidden="true" class="text-purple">*</span></label>
          <input type="text" id="name" name="name" required autocomplete="name"
            class="mt-2 w-full rounded-xl border border-purple/20 bg-white/80 px-4 py-3 text-sm text-ink placeholder:text-ink-muted/60 focus:border-purple" placeholder="Jane Smith" />
        </div>
        <div>
          <label for="business" class="block text-sm font-semibold text-ink">Business name <span aria-hidden="true" class="text-purple">*</span></label>
          <input type="text" id="business" name="business" required autocomplete="organization"
            class="mt-2 w-full rounded-xl border border-purple/20 bg-white/80 px-4 py-3 text-sm text-ink placeholder:text-ink-muted/60 focus:border-purple" placeholder="Smith's Bakery" />
        </div>
        <div>
          <label for="email" class="block text-sm font-semibold text-ink">Email <span aria-hidden="true" class="text-purple">*</span></label>
          <input type="email" id="email" name="email" required autocomplete="email"
            class="mt-2 w-full rounded-xl border border-purple/20 bg-white/80 px-4 py-3 text-sm text-ink placeholder:text-ink-muted/60 focus:border-purple" placeholder="jane@smithsbakery.com" />
        </div>
        <div>
          <label for="phone" class="block text-sm font-semibold text-ink">Phone</label>
          <input type="tel" id="phone" name="phone" autocomplete="tel"
            class="mt-2 w-full rounded-xl border border-purple/20 bg-white/80 px-4 py-3 text-sm text-ink placeholder:text-ink-muted/60 focus:border-purple" placeholder="(555) 123-4567" />
        </div>
        <div class="sm:col-span-2">
          <label for="website" class="block text-sm font-semibold text-ink">Current website <span class="font-normal text-ink-muted">(if you have one)</span></label>
          <input type="url" id="website" name="website" autocomplete="url" inputmode="url"
            class="mt-2 w-full rounded-xl border border-purple/20 bg-white/80 px-4 py-3 text-sm text-ink placeholder:text-ink-muted/60 focus:border-purple" placeholder="https://www.example.com" />
        </div>

        <fieldset class="sm:col-span-2">
          <legend class="text-sm font-semibold text-ink">What do you need? <span aria-hidden="true" class="text-purple">*</span></legend>
          <div class="mt-3 flex flex-wrap gap-2.5">
            {
              serviceOptions.map((s) => (
                <label class="cursor-pointer">
                  <input type="checkbox" name="services" value={s} class="peer sr-only" />
                  <span class="inline-block rounded-full border border-purple/25 bg-white/70 px-4 py-2 text-sm font-medium text-ink-soft transition-colors duration-150 peer-checked:border-purple peer-checked:bg-purple peer-checked:text-white peer-focus-visible:outline-2 peer-focus-visible:outline-purple">
                    {s}
                  </span>
                </label>
              ))
            }
          </div>
        </fieldset>

        <div class="sm:col-span-2">
          <label for="budget" class="block text-sm font-semibold text-ink">Estimated budget</label>
          <select id="budget" name="budget"
            class="mt-2 w-full rounded-xl border border-purple/20 bg-white/80 px-4 py-3 text-sm text-ink focus:border-purple">
            <option value="">Select a range…</option>
            {budgetOptions.map((b) => <option value={b}>{b}</option>)}
          </select>
        </div>

        <div class="sm:col-span-2">
          <label for="details" class="block text-sm font-semibold text-ink">Tell us about your project <span aria-hidden="true" class="text-purple">*</span></label>
          <textarea id="details" name="details" required rows="5"
            class="mt-2 w-full rounded-xl border border-purple/20 bg-white/80 px-4 py-3 text-sm text-ink placeholder:text-ink-muted/60 focus:border-purple"
            placeholder="What does your business do? What are you hoping a new website will accomplish?"></textarea>
        </div>
      </div>

      <div class="mt-6">
        <div class="cf-turnstile" data-sitekey={TURNSTILE_SITE_KEY} data-theme="light"></div>
      </div>

      <button
        type="submit"
        id="submit-btn"
        class="mt-6 w-full rounded-full bg-purple px-8 py-3.5 text-base font-semibold text-white shadow-(--shadow-cta) transition-transform duration-150 ease-(--ease-press) hover:scale-[1.02] active:scale-[0.98] disabled:cursor-not-allowed disabled:opacity-60"
      >
        Send My Quote Request
      </button>

      <p id="form-status" role="status" aria-live="polite" class="mt-4 hidden text-center text-sm font-medium"></p>
    </form>
  </section>

  <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer is:inline></script>

  <script>
    const form = document.getElementById('quote-form') as HTMLFormElement;
    const btn = document.getElementById('submit-btn') as HTMLButtonElement;
    const status = document.getElementById('form-status') as HTMLParagraphElement;

    function showStatus(msg: string, ok: boolean) {
      status.textContent = msg;
      status.classList.remove('hidden', 'text-red-600', 'text-purple');
      status.classList.add(ok ? 'text-purple' : 'text-red-600');
    }

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();

      if (!form.reportValidity()) return;

      const services = [...form.querySelectorAll<HTMLInputElement>('input[name="services"]:checked')].map((c) => c.value);
      if (services.length === 0) {
        showStatus('Please select at least one service.', false);
        return;
      }

      const data = new FormData(form);
      const token = data.get('cf-turnstile-response');
      if (!token) {
        showStatus('Please complete the verification above.', false);
        return;
      }

      btn.disabled = true;
      btn.textContent = 'Sending…';

      try {
        const res = await fetch('/api/quote', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            name: data.get('name'),
            business: data.get('business'),
            email: data.get('email'),
            phone: data.get('phone'),
            website: data.get('website'),
            services,
            budget: data.get('budget'),
            details: data.get('details'),
            turnstileToken: token,
          }),
        });

        if (res.ok) {
          form.reset();
          // @ts-expect-error Turnstile global from Cloudflare script
          window.turnstile?.reset();
          showStatus('Thanks! Your request is in — we’ll reply within one business day.', true);
          btn.textContent = 'Sent ✓';
        } else {
          const body = await res.json().catch(() => ({}));
          showStatus(body.error ?? 'Something went wrong. Please try again or email us directly.', false);
          btn.disabled = false;
          btn.textContent = 'Send My Quote Request';
        }
      } catch {
        showStatus('Network error — please check your connection and try again.', false);
        btn.disabled = false;
        btn.textContent = 'Send My Quote Request';
      }
    });
  </script>
</Base>
