<!-- ============================================================
     3D + interaction scripts (Three.js orb + tilt)
============================================================ -->
<script>
  // --- Tilt-on-mousemove (for the browser mock and product tiles) ---
  function initTilt() {
    const tiltEls = document.querySelectorAll<HTMLElement>('[data-tilt]:not([data-tilt-init])');
    tiltEls.forEach((el) => {
      el.setAttribute('data-tilt-init', '1');
      let baseRX = 0, baseRY = 0;
      // Preserve the .k-window initial pose
      if (el.classList.contains('k-window')) { baseRX = 6; baseRY = -4; }
      const enter = () => el.style.willChange = 'transform';
      const leave = () => {
        el.style.transform = el.classList.contains('k-window')
          ? `rotateX(${baseRX}deg) rotateY(${baseRY}deg)`
          : '';
        el.style.willChange = 'auto';
      };
      const move = (e: MouseEvent) => {
        const r = el.getBoundingClientRect();
        const x = ((e.clientX - r.left) / r.width - 0.5);
        const y = ((e.clientY - r.top) / r.height - 0.5);
        const strength = el.classList.contains('k-window') ? 10 : 6;
        el.style.transform = `perspective(1200px) rotateX(${baseRX + (-y * strength).toFixed(2)}deg) rotateY(${baseRY + (x * strength).toFixed(2)}deg) translateZ(0)`;
      };
      el.addEventListener('mouseenter', enter);
      el.addEventListener('mousemove', move);
      el.addEventListener('mouseleave', leave);
    });
  }

  // --- Three.js: floating iridescent gem behind the hero window ---
  async function initHeroGem() {
    const canvas = document.getElementById('k-hero-canvas') as HTMLCanvasElement | null;
    if (!canvas || canvas.dataset.init) return;
    canvas.dataset.init = '1';

    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    let THREE: any;
    try { THREE = await import('three'); } catch { return; }

    let renderer: any;
    try {
      renderer = new THREE.WebGLRenderer({ canvas, alpha: true, antialias: true });
    } catch { return; }
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    renderer.setClearColor(0x000000, 0);

    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(38, 1, 0.1, 60);
    camera.position.z = 8;

    // Ambient soft light
    scene.add(new THREE.AmbientLight(0xffffff, 0.55));
    const key = new THREE.DirectionalLight(0xffffff, 0.9); key.position.set(3, 4, 5); scene.add(key);
    const rim = new THREE.DirectionalLight(0x8ab8ff, 0.6); rim.position.set(-4, -2, 3); scene.add(rim);

    // Iridescent gem
    const geo = new THREE.IcosahedronGeometry(1.55, 0);
    const gemMat = new THREE.ShaderMaterial({
      uniforms: { uTime: { value: 0 } },
      vertexShader: `
        varying vec3 vN; varying vec3 vP;
        void main() {
          vN = normalize(normalMatrix * normal);
          vec4 mv = modelViewMatrix * vec4(position, 1.0);
          vP = mv.xyz;
          gl_Position = projectionMatrix * mv;
        }`,
      fragmentShader: `
        varying vec3 vN; varying vec3 vP;
        uniform float uTime;
        void main() {
          vec3 v = normalize(-vP);
          float fr = pow(1.0 - abs(dot(v, vN)), 2.4);
          float hueSeed = dot(vN, vec3(0.7, 0.3, 0.2)) + uTime * 0.15;
          vec3 c1 = vec3(0.0, 0.44, 0.89);   // blue
          vec3 c2 = vec3(0.49, 0.23, 0.93);  // violet
          vec3 c3 = vec3(1.0, 0.22, 0.37);   // red
          float t = 0.5 + 0.5 * sin(hueSeed * 3.14159);
          vec3 base = mix(c1, c2, t);
          base = mix(base, c3, 0.5 + 0.5 * sin(hueSeed * 2.0 + 1.2));
          vec3 col = mix(vec3(0.95, 0.97, 1.0), base, 0.55) + fr * 0.85;
          gl_FragColor = vec4(col, 0.55 + fr * 0.4);
        }`,
      transparent: true,
    });
    const gem = new THREE.Mesh(geo, gemMat);
    scene.add(gem);

    // Wire shell over the gem
    const wire = new THREE.Mesh(
      new THREE.IcosahedronGeometry(1.62, 1),
      new THREE.MeshBasicMaterial({ color: 0x0071e3, wireframe: true, transparent: true, opacity: 0.14 })
    );
    scene.add(wire);

    // Orbit rings
    const rings: any[] = [];
    [
      { r: 2.6, tilt: [Math.PI / 2.2, 0.35], color: 0x0071e3, op: 0.35 },
      { r: 3.1, tilt: [Math.PI / 2.6, -0.5], color: 0x7c3aed, op: 0.25 },
    ].forEach((cfg) => {
      const ring = new THREE.Mesh(
        new THREE.TorusGeometry(cfg.r, 0.008, 8, 128),
        new THREE.MeshBasicMaterial({ color: cfg.color, transparent: true, opacity: cfg.op })
      );
      ring.rotation.set(cfg.tilt[0], 0, cfg.tilt[1]);
      rings.push(ring); scene.add(ring);
    });

    // Small orbiting spheres
    const spheres: any[] = [];
    [
      { r: 2.6, s: 0.09, color: 0x0071e3, speed: 0.55, phase: 0 },
      { r: 3.1, s: 0.07, color: 0xff375f, speed: -0.4, phase: 1.8 },
      { r: 2.2, s: 0.06, color: 0x34c759, speed: 0.7, phase: 3.2 },
    ].forEach((cfg) => {
      const s = new THREE.Mesh(
        new THREE.SphereGeometry(cfg.s, 16, 16),
        new THREE.MeshBasicMaterial({ color: cfg.color })
      );
      (s as any).userData = cfg;
      spheres.push(s); scene.add(s);
    });

    // Sparse particles
    const N = 220;
    const pos = new Float32Array(N * 3);
    for (let i = 0; i < N; i++) {
      const a = Math.sin(i * 12.9898) * 43758.5453;
      const b = Math.sin(i * 78.233) * 12543.2341;
      const c = Math.sin(i * 39.425) * 26431.5327;
      pos[i*3]   = ((a - Math.floor(a)) - 0.5) * 12;
      pos[i*3+1] = ((b - Math.floor(b)) - 0.5) * 7;
      pos[i*3+2] = ((c - Math.floor(c)) - 0.5) * 3;
    }
    const pg = new THREE.BufferGeometry();
    pg.setAttribute('position', new THREE.BufferAttribute(pos, 3));
    const particles = new THREE.Points(pg, new THREE.PointsMaterial({ color: 0x9bb8ff, size: 0.02, transparent: true, opacity: 0.75 }));
    scene.add(particles);

    // Resize
    function resize() {
      const w = canvas.clientWidth;
      const h = canvas.clientHeight;
      if (w === 0 || h === 0) return;
      renderer.setSize(w, h, false);
      camera.aspect = w / h;
      camera.updateProjectionMatrix();
    }
    const ro = new ResizeObserver(resize); ro.observe(canvas);
    resize();

    // Pointer parallax
    let mx = 0, my = 0, cmx = 0, cmy = 0;
    window.addEventListener('pointermove', (e) => {
      mx = (e.clientX / window.innerWidth - 0.5) * 2;
      my = (e.clientY / window.innerHeight - 0.5) * 2;
    }, { passive: true });

    // Visibility
    let visible = true;
    new IntersectionObserver(([e]) => { visible = e.isIntersecting; }, { threshold: 0 })
      .observe(canvas);

    let lastT = 0;
    function tick(t: number) {
      requestAnimationFrame(tick);
      if (!visible) return;
      const dt = Math.min((t - lastT) / 1000, 0.05) || 0.016;
      lastT = t;
      const ts = t / 1000;

      gemMat.uniforms.uTime.value = ts;
      gem.rotation.y += dt * 0.35;
      gem.rotation.x = Math.sin(ts * 0.6) * 0.15;
      wire.rotation.y -= dt * 0.2;
      wire.rotation.x += dt * 0.05;

      rings[0].rotation.z += dt * 0.15;
      rings[1].rotation.z -= dt * 0.1;

      spheres.forEach((s) => {
        const d = s.userData;
        const a = ts * d.speed + d.phase;
        s.position.set(Math.cos(a) * d.r, Math.sin(a * 0.7) * 0.6, Math.sin(a) * d.r);
      });

      particles.rotation.y += dt * 0.02;

      cmx += (mx - cmx) * 0.05;
      cmy += (my - cmy) * 0.05;
      camera.position.x = cmx * 0.5;
      camera.position.y = -cmy * 0.35;
      camera.lookAt(0, 0, 0);

      renderer.render(scene, camera);
    }
    requestAnimationFrame(tick);
  }

  function bootLanding() {
    if (!document.querySelector('.kaira-landing')) return;
    initTilt();
    initHeroGem();
  }
  bootLanding();
  document.addEventListener('astro:page-load', bootLanding);
</script>
