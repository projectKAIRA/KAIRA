---
import Base from '../layouts/Base.astro';
import Butterfly from '../components/Butterfly.astro';
import HeroScene from '../components/HeroScene.astro';

const pillars = [
  {
    title: 'Professional Websites',
    body: 'Custom-designed, mobile-first websites built to load fast, look sharp, and turn visitors into customers.',
    icon: 'M4 5h16a1 1 0 011 1v12a1 1 0 01-1 1H4a1 1 0 01-1-1V6a1 1 0 011-1zm0 4h17M7 7h.01',
    tag: 'DESIGN.CORE',
  },
  {
    title: 'SEO Fundamentals',
    body: 'Clean structure, local search optimization, and the technical groundwork Google rewards — built in from day one.',
    icon: 'M21 21l-4.35-4.35M17 10.5a6.5 6.5 0 11-13 0 6.5 6.5 0 0113 0z',
    tag: 'SEARCH.SYS',
  },
  {
    title: 'Ongoing Maintenance',
    body: 'Updates, security, backups, and small changes handled for you — so your site stays fresh without lifting a finger.',
    icon: 'M12 6v6l4 2m6-2a10 10 0 11-20 0 10 10 0 0120 0z',
    tag: 'CARE.LOOP',
  },
];

const steps = [
  { n: '01', title: 'Discovery', body: 'A short call to understand your business, customers, and goals.' },
  { n: '02', title: 'Design & Build', body: 'We design and build your site, sharing progress along the way.' },
  { n: '03', title: 'Launch', body: 'Your site goes live — fast, polished, and ready to be found.' },
  { n: '04', title: 'Grow', body: 'Optional maintenance and SEO keep it improving month after month.' },
];

const telemetry = [
  { label: 'SEO.SCORE', value: '98/100', pos: 'left-[8%] top-[120px]' },
  { label: 'LOAD.TIME', value: '0.4s', pos: 'right-[9%] top-[150px]' },
  { label: 'UPTIME', value: '99.9%', pos: 'left-[12%] top-[360px]' },
  { label: 'SIGNAL', value: 'STRONG', pos: 'right-[13%] top-[340px]' },
];
---

<Base
  title="KAIRA — Modern Websites for Local Businesses"
  description="KAIRA builds professional websites with SEO fundamentals and ongoing maintenance for local businesses. Websites starting at $1,000."
>
  <!-- ============ HERO ============ -->
  <section class="mesh-bg relative overflow-hidden">
    <HeroScene />

    <!-- HUD telemetry around the orb (decorative) -->
    <div aria-hidden="true" class="pointer-events-none absolute inset-x-0 top-0 hidden lg:block">
      {
        telemetry.map((t) => (
          <div class={`absolute ${t.pos} flex items-center gap-3`}>
            <span class="h-px w-6 bg-white/15" />
            <span class="hud-label">{t.label} <span class="text-purple">{t.value}</span></span>
          </div>
        ))
      }
    </div>

    <div class="relative z-[1] mx-auto max-w-6xl px-5 pb-24 pt-[430px] text-center sm:pt-[460px] md:pb-28">
      <p class="reveal hud-label mb-5 !text-ink-muted">
        KAIRA <span class="text-white/25">//</span> WEB DESIGN STUDIO <span class="text-white/25">//</span> EST. 2026
      </p>

      <p class="reveal mx-auto inline-flex items-center gap-2 rounded-full border border-purple/25 bg-white/[0.04] px-4 py-1.5 text-xs font-semibold tracking-widest text-purple backdrop-blur">
        <span class="status-dot"></span> WEBSITES STARTING AT $1,000
      </p>

      <h1 class="reveal reveal-delay-1 mx-auto mt-6 max-w-3xl text-4xl font-bold leading-tight tracking-tight text-ink sm:text-5xl md:text-6xl">
        The web presence your business
        <span class="bg-gradient-to-r from-violet-mid via-purple-bright to-magenta bg-clip-text text-transparent">was meant to have.</span>
      </h1>

      <p class="reveal reveal-delay-2 mx-auto mt-6 max-w-xl text-lg leading-relaxed text-ink-soft">
        Designed to impress. Engineered to be found. Maintained so it stays that way.
      </p>

      <div class="reveal reveal-delay-3 mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a
          href="/contact"
          class="w-full rounded-full bg-violet px-8 py-3.5 text-base font-semibold text-white shadow-(--shadow-cta) transition-transform duration-150 ease-(--ease-press) hover:scale-[1.03] active:scale-[0.98] sm:w-auto"
        >
          Get a Free Quote
        </a>
        <a
          href="/portfolio"
          class="glass w-full rounded-full px-8 py-3.5 text-base font-semibold text-ink transition-transform duration-150 ease-(--ease-press) hover:scale-[1.03] active:scale-[0.98] sm:w-auto"
        >
          See Our Work
        </a>
      </div>

      <!-- Stat counters, Monday-style -->
      <div class="reveal reveal-delay-3 glass mx-auto mt-16 grid max-w-2xl grid-cols-3 divide-x divide-white/[0.07] rounded-2xl">
        {
          [
            { n: '<1s', l: 'LOAD TIMES' },
            { n: '95+', l: 'LIGHTHOUSE SCORES' },
            { n: '24/7', l: 'SITE MONITORING' },
          ].map((s) => (
            <div class="px-2 py-6 sm:py-7">
              <p class="stat-num text-2xl font-bold text-ink sm:text-3xl">{s.n}</p>
              <p class="hud-label mt-2">{s.l}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ============ PILLARS ============ -->
  <section class="relative mx-auto max-w-6xl px-5 py-20 md:py-28" aria-labelledby="pillars-heading">
    <div class="reveal flex items-center justify-between border-b border-white/[0.07] pb-4">
      <p class="hud-label">SERVICES <span class="text-white/25">//</span> 3 MODULES</p>
      <p class="pill"><span class="status-dot"></span> ALL SYSTEMS ACTIVE</p>
    </div>

    <h2 id="pillars-heading" class="reveal mt-10 text-center text-3xl font-bold tracking-tight text-ink md:text-4xl">
      Everything your online presence needs
    </h2>
    <p class="reveal mx-auto mt-4 max-w-lg text-center text-ink-muted">
      Three services, one goal — making sure customers find you and choose you.
    </p>

    <div class="mt-14 grid gap-6 md:grid-cols-3">
      {
        pillars.map((p, i) => (
          <article class={`reveal reveal-delay-${i + 1} glass rounded-2xl p-8 transition-transform duration-300 ease-(--ease-enter) hover:-translate-y-1.5`}>
            <div class="flex items-center justify-between">
              <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-purple-pale text-purple">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d={p.icon} />
                </svg>
              </div>
              <span class="hud-label">{p.tag}</span>
            </div>
            <h3 class="mt-5 text-lg font-semibold text-ink">{p.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-ink-muted">{p.body}</p>
          </article>
        ))
      }
    </div>

    <p class="reveal mt-10 text-center">
      <a href="/services" class="font-semibold text-purple hover:underline">Explore all services →</a>
    </p>
  </section>

  <!-- ============ HOW IT WORKS ============ -->
  <section class="relative overflow-hidden border-y border-white/[0.06] bg-[#060607] py-20 md:py-28" aria-labelledby="process-heading">
    <div aria-hidden="true" class="pointer-events-none absolute inset-0">
      <div class="absolute -top-32 left-1/4 h-96 w-96 rounded-full bg-violet/[0.08] blur-3xl"></div>
      <div class="absolute bottom-0 right-[10%] h-72 w-72 rounded-full bg-magenta/[0.06] blur-3xl"></div>
    </div>

    <div class="relative mx-auto max-w-6xl px-5">
      <div class="reveal flex items-center justify-between border-b border-white/[0.07] pb-4">
        <p class="hud-label">PROCESS <span class="text-white/25">//</span> 4 STEPS</p>
        <p class="hud-label">AVG. TIMELINE <span class="text-purple">2–4 WEEKS</span></p>
      </div>

      <h2 id="process-heading" class="reveal mt-10 text-center text-3xl font-bold tracking-tight text-white md:text-4xl">
        From first call to launch — <span class="text-purple">in weeks, not months</span>
      </h2>

      <ol class="mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {
          steps.map((s, i) => (
            <li class={`reveal reveal-delay-${Math.min(i, 3)} rounded-2xl border border-white/10 bg-white/[0.04] p-7 backdrop-blur`}>
              <span class="hud-label !text-purple">STEP {s.n}</span>
              <h3 class="mt-3 text-lg font-semibold text-white">{s.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-white/55">{s.body}</p>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <!-- ============ CTA ============ -->
  <section class="mesh-bg" aria-labelledby="cta-heading">
    <div class="mx-auto max-w-3xl px-5 py-20 text-center md:py-28">
      <Butterfly class="reveal animate-float mx-auto mb-8 h-14 w-14 opacity-70" />
      <h2 id="cta-heading" class="reveal text-3xl font-bold tracking-tight text-ink md:text-4xl">
        Ready to look as good online as you are in person?
      </h2>
      <p class="reveal reveal-delay-1 mt-4 text-lg text-ink-soft">
        Tell us about your business and get a free, no-pressure quote within one business day.
      </p>
      <a
        href="/contact"
        class="reveal reveal-delay-2 mt-8 inline-block rounded-full bg-violet px-8 py-3.5 text-base font-semibold text-white shadow-(--shadow-cta) transition-transform duration-150 ease-(--ease-press) hover:scale-[1.03] active:scale-[0.98]"
      >
        Get Your Free Quote
      </a>
      <p class="reveal reveal-delay-3 hud-label mt-8">NO PRESSURE <span class="text-white/25">//</span> NO OBLIGATION <span class="text-white/25">//</span> REPLY IN 1 BUSINESS DAY</p>
    </div>
  </section>
</Base>
