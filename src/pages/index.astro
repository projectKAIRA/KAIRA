    background: linear-gradient(90deg, #0071e3, #7c3aed); }
  .k-mock-links { display: flex; gap: 14px; }
  .k-mock-links i { width: 34px; height: 6px; border-radius: 999px; background: #e5e5ea; display:block; }
  .k-mock-cta { width: 74px; height: 22px; border-radius: 999px; background: #1d1d1f; }

  .k-mock-hero { padding: 8px 0 18px; }
  .k-mock-title { width: 70%; height: 22px; border-radius: 8px; background: #1d1d1f; margin-bottom: 10px; }
  .k-mock-title.short { width: 45%; background: linear-gradient(90deg, #0071e3, #7c3aed, #ff375f); }
  .k-mock-para  { width: 90%; height: 8px; border-radius: 4px; background: #e5e5ea; margin-top: 14px; }
  .k-mock-para.w80 { width: 68%; margin-top: 8px; }
  .k-mock-btn   { width: 120px; height: 30px; border-radius: 999px; background: #1d1d1f; margin-top: 16px; }

  .k-mock-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
    margin-top: 6px;
  }
  .k-mock-card {
    aspect-ratio: 1.4 / 1;
    border-radius: 12px;
    background: #f5f5f7;
    padding: 12px;
    display: flex;
    align-items: flex-end;
  }
  .chip { width: 30px; height: 30px; border-radius: 10px; }
  .chip-a { background: linear-gradient(135deg, #0071e3, #5ac8fa); }
  .chip-b { background: linear-gradient(135deg, #34c759, #a7f3d0); }
  .chip-c { background: linear-gradient(135deg, #ff375f, #ffb37a); }

  /* Floating badges */
  .k-float {
    position: absolute;
    z-index: 3;
    background: rgba(255,255,255,0.9);
    -webkit-backdrop-filter: blur(20px) saturate(180%);
    backdrop-filter: blur(20px) saturate(180%);
    border: 1px solid rgba(0,0,0,0.06);
    border-radius: 18px;
    padding: 12px 14px;
    box-shadow: 0 20px 40px -20px rgba(15,23,42,0.25), 0 4px 12px -4px rgba(15,23,42,0.1);
    display: flex; align-items: center; gap: 10px;
    text-align: left;
    animation: floaty 6s ease-in-out infinite;
  }
  .k-float b { display: block; font-size: 18px; font-weight: 700; color: #1d1d1f; letter-spacing: -0.02em; }
  .k-float span { display: block; font-size: 11px; color: #6e6e73; margin-top: 2px; }
  .k-float-a { top: 8%; left: -2%; animation-delay: -1s; }
  .k-float-a .score {
    width: 46px; height: 46px; border-radius: 14px;
    display: grid; place-items: center;
    background: linear-gradient(135deg, #34c759, #a7f3d0);
    color: #fff; font-weight: 700; font-size: 18px;
    box-shadow: 0 8px 18px -6px rgba(52,199,89,0.55);
  }
  .k-float-a .score-label { font-size: 11px; line-height: 1.25; color: #1d1d1f; font-weight: 600; }
  .k-float-b { top: 30%; right: -3%; animation-delay: -2.5s; color: #ff9500; }
  .k-float-b b, .k-float-b span { color: initial; }
  .k-float-b b { color: #1d1d1f; }
  .k-float-c { bottom: 8%; left: 6%; animation-delay: -4s; }
  .pill-tag {
    background: linear-gradient(135deg, #0071e3, #7c3aed);
    color: #fff; font-size: 10px; letter-spacing: 0.1em; font-weight: 700;
    padding: 4px 8px; border-radius: 6px;
  }
  @keyframes floaty {
    0%, 100% { transform: translateY(0) rotate(-0.4deg); }
    50%       { transform: translateY(-10px) rotate(0.4deg); }
  }

  /* -------------------- Floating phone (device stack partner) -------------------- */
  .k-phone {
    position: absolute;
    z-index: 3;
    right: 3%;
    bottom: -6%;
    width: 22%;
    max-width: 190px;
    aspect-ratio: 9 / 19;
    background: #1d1d1f;
    border-radius: 26px;
    padding: 6px;
    box-shadow:
      0 30px 60px -20px rgba(15, 23, 42, 0.35),
      0 12px 24px -12px rgba(15, 23, 42, 0.25),
      inset 0 0 0 1px rgba(255, 255, 255, 0.08);
    transform: rotate(4deg) translateZ(0);
    animation: phone-float 6s ease-in-out infinite;
  }
  @keyframes phone-float {
    0%, 100% { transform: rotate(4deg) translateY(0); }
    50%       { transform: rotate(3deg) translateY(-10px); }
  }
  .k-phone-notch {
    position: absolute;
    top: 10px; left: 50%; transform: translateX(-50%);
    width: 34%; height: 14px;
    background: #1d1d1f;
    border-radius: 0 0 10px 10px;
    z-index: 2;
  }
  .k-phone-body {
    background: #ffffff;
    border-radius: 20px;
    height: 100%;
    padding: 22px 10px 10px;
    display: flex; flex-direction: column; gap: 6px;
    overflow: hidden;
  }
  .k-phone-hero {
    height: 42%;
    background: linear-gradient(135deg, #0071e3, #7c3aed, #ff375f);
    border-radius: 12px;
  }
  .k-phone-title { height: 8px; width: 80%; background: #1d1d1f; border-radius: 3px; margin-top: 4px; }
  .k-phone-line  { height: 4px; width: 90%; background: #e5e5ea; border-radius: 2px; }
  .k-phone-line.short { width: 60%; }
  .k-phone-btn   { height: 18px; width: 60%; background: #1d1d1f; border-radius: 999px; margin-top: 2px; }
  .k-phone-card  {
    height: 60px; background: #f5f5f7; border-radius: 8px;
    padding: 8px; display: flex; align-items: flex-end; margin-top: auto;
  }
  .k-phone-card .chip { width: 22px; height: 22px; border-radius: 6px; }

  @media (max-width: 720px) {
    .k-phone { right: 2%; bottom: -10%; width: 28%; }
  }

  /* -------------------- BENTO GRID -------------------- */
  .k-bento { padding: 40px 0 100px; text-align: center; }
  .k-bento-grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 16px;
    margin-top: 48px;
    text-align: left;
  }
  .bt {
    position: relative;
    background: #fff;
    border: 1px solid rgba(0, 0, 0, 0.05);
    border-radius: 24px;
    padding: 26px;
    box-shadow: 0 20px 40px -20px rgba(15, 23, 42, 0.10);
    overflow: hidden;
    transition: transform 260ms cubic-bezier(0.16,1,0.3,1), box-shadow 260ms ease;
    min-height: 260px;
    display: flex;
    flex-direction: column;
  }
  .bt:hover {
    transform: translateY(-4px);
    box-shadow: 0 30px 50px -20px rgba(15, 23, 42, 0.14);
  }
  .bt-eyebrow {
    display: inline-block;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.04em;
    color: #0071e3;
    margin-bottom: 6px;
  }
  .bt h3 {
    font-size: clamp(20px, 2vw, 26px);
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.15;
    color: #1d1d1f;
    text-wrap: balance;
  }
  .bt p {
    color: #6e6e73;
    font-size: 14px;
    line-height: 1.5;
    margin-top: 8px;
  }
  .bt-foot { margin-top: auto; font-size: 12px !important; color: #86868b !important; letter-spacing: 0.02em; }

  /* Layout: 6-col grid; tiles occupy varied spans */
  .bt-speed    { grid-column: span 4; }
  .bt-map      { grid-column: span 2; }
  .bt-care     { grid-column: span 2; }
  .bt-devices  { grid-column: span 2; }
  .bt-palette  { grid-column: span 2; }
  .bt-turn     { grid-column: span 6; text-align: center; align-items: center; }
  .bt-turn h3  { font-size: clamp(44px, 5vw, 68px); font-weight: 700; }
  .bt-turn p   { max-width: 400px; }

  @media (max-width: 900px) {
    .k-bento-grid { grid-template-columns: repeat(2, 1fr); }
    .bt-speed, .bt-map, .bt-care, .bt-devices, .bt-palette, .bt-turn { grid-column: span 2; }
  }

  /* -- Speed gauge -- */
  .bt-speed { background: linear-gradient(160deg, #fff 0%, #f5f9ff 100%); }
  .bt-head { max-width: 320px; }
  .bt-gauge {
    margin-top: auto;
    position: relative;
    padding-top: 16px;
  }
  .bt-gauge svg { width: 100%; max-width: 340px; display: block; }
  .gauge-fill { transition: stroke-dashoffset 1400ms cubic-bezier(0.32,0.72,0,1); }
  .bt.is-active .gauge-fill { stroke-dashoffset: 12; }
  .gauge-value { display: flex; flex-direction: column; margin-top: 6px; }
  .gauge-value b { font-size: 28px; font-weight: 700; letter-spacing: -0.02em; color: #34c759; }
  .gauge-value span { font-size: 12px; color: #6e6e73; }

  /* -- Map tile -- */
  .bt-map { background: linear-gradient(160deg, #f0f9f4 0%, #fff 100%); }
  .bt-map-art {
    position: relative;
    margin-top: auto;
    aspect-ratio: 1;
    border-radius: 16px;
    overflow: hidden;
    background: linear-gradient(160deg, #d1fadf, #f0f9f4);
  }
  .map-grid {
    position: absolute; inset: 0;
    background-image:
      linear-gradient(rgba(52, 199, 89, 0.14) 1px, transparent 1px),
      linear-gradient(90deg, rgba(52, 199, 89, 0.14) 1px, transparent 1px);
    background-size: 24px 24px;
  }
  .map-pin {
    position: absolute; left: 50%; top: 45%;
    transform: translate(-50%, -100%);
    width: 34px; height: 44px;
  }
  .map-pin::before {
    content: "";
    position: absolute; inset: 0;
    background: linear-gradient(180deg, #34c759, #16a34a);
    border-radius: 50% 50% 50% 0;
    transform: rotate(-45deg);
    box-shadow: 0 8px 18px -4px rgba(22, 163, 74, 0.5);
  }
  .map-pin span {
    position: absolute; left: 50%; top: 40%;
    transform: translate(-50%, -50%);
    width: 12px; height: 12px; border-radius: 50%;
    background: #fff;
    z-index: 1;
  }
  .map-pulse {
    position: absolute; left: 50%; top: 45%;
    width: 30px; height: 30px; border-radius: 50%;
    background: rgba(52, 199, 89, 0.3);
    transform: translate(-50%, -50%);
    animation: mp 2.4s ease-out infinite;
  }
  @keyframes mp {
    0%   { transform: translate(-50%, -50%) scale(0.6); opacity: 0.6; }
    100% { transform: translate(-50%, -50%) scale(3);  opacity: 0; }
  }

  /* -- Care shield -- */
  .bt-care { background: linear-gradient(160deg, #f5f0ff 0%, #fff 100%); align-items: center; }
  .bt-care h3 { text-align: center; }
  .bt-shield {
    margin: 6px 0 10px;
    width: 92px;
  }
  .bt-shield svg { width: 100%; }
  .bt-shield .check { transition: stroke-dashoffset 900ms cubic-bezier(0.32,0.72,0,1) 300ms; }
  .bt.is-active .check { stroke-dashoffset: 0; }

  /* -- Devices -- */
  .bt-devices { background: linear-gradient(160deg, #fff 0%, #f5f5f7 100%); align-items: center; text-align: center; }
  .bt-devices h3 { text-align: center; }
  .bt-devices-art {
    position: relative;
    width: 100%;
    height: 130px;
    margin-bottom: 12px;
  }
  .dev-laptop {
    position: absolute; left: 50%; top: 20%;
    transform: translateX(-50%);
    width: 160px;
  }
  .dev-laptop .dev-screen {
    height: 90px; border-radius: 8px 8px 2px 2px;
    background: linear-gradient(135deg, #0071e3, #7c3aed);
    border: 4px solid #1d1d1f;
    box-shadow: inset 0 0 0 1px rgba(255,255,255,0.15);
  }
  .dev-laptop .dev-hinge {
    height: 6px;
    background: #1d1d1f;
    border-radius: 0 0 6px 6px;
    margin: 0 -14px;
  }
  .dev-phone {
    position: absolute; right: 12%; bottom: -6px;
    width: 44px; height: 82px;
    background: #1d1d1f;
    border-radius: 10px;
    padding: 4px;
    box-shadow: 0 8px 20px -6px rgba(15,23,42,0.35);
  }
  .dev-phone::before {
    content: "";
    display: block;
    width: 100%; height: 100%;
    border-radius: 6px;
    background: linear-gradient(160deg, #ff375f, #7c3aed);
  }

  /* -- Palette swatches -- */
  .bt-palette { background: linear-gradient(160deg, #fff 0%, #fff5f8 100%); }
  .bt-swatches {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 6px;
    margin-top: auto;
  }
  .sw {
    aspect-ratio: 1;
    border-radius: 10px;
    box-shadow: 0 4px 12px -4px rgba(15, 23, 42, 0.2);
    animation: sw-pop 800ms cubic-bezier(0.16,1,0.3,1) both;
  }
  .sw:nth-child(1) { animation-delay: 0.05s; }
  .sw:nth-child(2) { animation-delay: 0.10s; }
  .sw:nth-child(3) { animation-delay: 0.15s; }
  .sw:nth-child(4) { animation-delay: 0.20s; }
  .sw:nth-child(5) { animation-delay: 0.25s; }
  .sw:nth-child(6) { animation-delay: 0.30s; }
  @keyframes sw-pop { from { transform: scale(0.6); opacity: 0; } to { transform: scale(1); opacity: 1; } }

  /* -- Turnaround -- */
  .bt-turn { background: linear-gradient(120deg, #eff5ff 0%, #f5eeff 50%, #ffeef2 100%); }
  .bt-timeline {
    display: flex; gap: 10px; margin-top: 20px;
    justify-content: center; width: 100%;
  }
  .bt-timeline span {
    height: 6px;
    flex: 1; max-width: 90px;
    background: linear-gradient(90deg, #0071e3, #7c3aed, #ff375f);
    border-radius: 3px;
    opacity: 0.2;
    animation: tl-fill 1600ms ease-out both;
  }
  .bt-timeline span:nth-child(1) { animation-delay: 0.05s; }
  .bt-timeline span:nth-child(2) { animation-delay: 0.25s; }
  .bt-timeline span:nth-child(3) { animation-delay: 0.45s; }
  .bt-timeline span:nth-child(4) { animation-delay: 0.65s; }
  @keyframes tl-fill { from { opacity: 0.2; } to { opacity: 1; } }

  .k-stat .pfx { font-size: 0.55em; color: inherit; margin-right: 2px; opacity: 0.9; }

  /* -------------------- BENTO GRID end -------------------- */
  .k-marquee {
    padding: 50px 0 30px;
    text-align: center;
    overflow: hidden;
  }
  .k-marquee .k-tiny { margin-bottom: 22px; }
  .k-marquee-track {
    display: flex;
    gap: 8px;
    white-space: nowrap;
    animation: scroll 40s linear infinite;
    font-size: clamp(20px, 3vw, 34px);
    font-weight: 600;
    letter-spacing: -0.02em;
    color: #1d1d1f;
    opacity: 0.85;
    width: max-content;
  }
  .k-marquee-item { display: inline-flex; align-items: center; gap: 20px; padding: 0 8px; }
  .k-marquee-item .dotSep { color: #d2d2d7; font-weight: 400; }
  @keyframes scroll {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  /* -------------------- Big statement -------------------- */
  .k-statement { padding: 100px 0 40px; text-align: center; }

  /* -------------------- Stats -------------------- */
  .k-stats { padding: 40px 0 90px; }
  .k-stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 4px;
    background: #fff;
    border: 1px solid rgba(0,0,0,0.06);
    border-radius: 24px;
    padding: 8px;
    box-shadow: 0 20px 50px -30px rgba(15,23,42,0.15);
  }
  .k-stat {
    padding: 26px 18px;
    text-align: center;
    border-radius: 16px;
    transition: background 200ms;
  }
  .k-stat:hover { background: #f5f5f7; }
  .k-stat .n {
    font-size: clamp(28px, 3.6vw, 46px);
    font-weight: 700;
    letter-spacing: -0.03em;
    background: linear-gradient(120deg, #0071e3, #7c3aed);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .k-stat .l { margin-top: 6px; font-size: 13px; color: #6e6e73; font-weight: 500; }
  @media (max-width: 720px) {
    .k-stats-grid { grid-template-columns: repeat(2, 1fr); }
  }

  /* -------------------- Family tiles -------------------- */
  .k-family { padding: 40px 0 100px; text-align: center; }
  .k-family-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-top: 48px;
  }
  @media (max-width: 900px) {
    .k-family-grid { grid-template-columns: 1fr; }
  }
  .k-tile {
    position: relative;
    display: flex;
    flex-direction: column;
    text-align: left;
    padding: 26px 26px 22px;
    background: #fff;
    border: 1px solid rgba(0,0,0,0.06);
    border-radius: 24px;
    box-shadow: 0 20px 40px -20px rgba(15,23,42,0.10);
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: transform 260ms cubic-bezier(0.16,1,0.3,1), box-shadow 260ms ease;
    transform-style: preserve-3d;
  }
  .k-tile::after {
    content: "";
    position: absolute; inset: 0;
    background:
      radial-gradient(120% 90% at 50% 110%,
        color-mix(in srgb, var(--a) 22%, transparent) 0%,
        color-mix(in srgb, var(--b) 8%, transparent) 45%,
        transparent 75%);
    z-index: 0; pointer-events: none;
    transition: opacity 300ms ease;
    opacity: 0.85;
  }
  .k-tile > * { position: relative; z-index: 1; }
  .k-tile:hover {
    transform: translateY(-6px);
    box-shadow: 0 40px 60px -20px rgba(15,23,42,0.18);
  }
  .k-tile-art {
    width: 100%;
    aspect-ratio: 200 / 140;
    background: linear-gradient(160deg, color-mix(in srgb, var(--a) 10%, #fff) 0%, #fff 80%);
    border-radius: 16px;
    padding: 12px;
    margin-bottom: 22px;
    display: grid; place-items: center;
    border: 1px solid rgba(0,0,0,0.04);
  }
  .k-tile-art svg { width: 100%; height: 100%; }
  .k-tile-tag { font-size: 13px; font-weight: 600; letter-spacing: 0.02em; color: var(--a); text-transform: none; }
  .k-tile-name { font-size: clamp(28px, 3vw, 36px); font-weight: 700; letter-spacing: -0.02em; margin-top: 4px; }
  .k-tile-body { color: #494950; font-size: 15px; line-height: 1.55; margin-top: 12px; flex: 1; }
  .k-tile-more {
    display: inline-flex; align-items: center; gap: 6px;
    margin-top: 20px;
    font-size: 14px; font-weight: 600; color: #1d1d1f;
  }
  .k-tile-more svg { transition: transform 200ms; }
  .k-tile:hover .k-tile-more svg { transform: translateX(4px); }

  /* -------------------- Process -------------------- */
  .k-process {
    padding: 80px 0;
    text-align: center;
    background: linear-gradient(180deg, #fbfbfd 0%, #f5f5f7 100%);
    border-top: 1px solid rgba(0,0,0,0.05);
    border-bottom: 1px solid rgba(0,0,0,0.05);
  }
  .k-steps {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    margin-top: 48px;
    padding: 0;
    list-style: none;
  }
  @media (max-width: 900px) {
    .k-steps { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 520px) {
    .k-steps { grid-template-columns: 1fr; }
  }
  .k-step {
    text-align: left;
    background: #fff;
    border-radius: 20px;
    padding: 24px;
    border: 1px solid rgba(0,0,0,0.05);
    box-shadow: 0 6px 20px -12px rgba(15,23,42,0.12);
    transition: transform 220ms cubic-bezier(0.16,1,0.3,1);
  }
  .k-step:hover { transform: translateY(-4px); }
  .k-step-num {
    font-size: 42px;
    font-weight: 700;
    letter-spacing: -0.03em;
    background: linear-gradient(120deg, #0071e3, #7c3aed, #ff375f);
    -webkit-background-clip: text; background-clip: text; color: transparent;
    line-height: 1;
  }
  .k-step h3 { font-size: 20px; font-weight: 600; margin-top: 14px; color: #1d1d1f; letter-spacing: -0.01em; }
  .k-step p { color: #6e6e73; font-size: 15px; line-height: 1.55; margin-top: 8px; }
  .k-timeline {
    margin-top: 40px;
    font-size: 14px;
    color: #6e6e73;
  }
  .k-timeline b { color: #1d1d1f; font-weight: 600; }

  /* -------------------- Pricing teaser -------------------- */
  .k-price { padding: 80px 0; }
  .k-price-card {
    display: flex; align-items: center; justify-content: space-between;
    gap: 20px; flex-wrap: wrap;
    padding: 40px 44px;
    border-radius: 28px;
    background: linear-gradient(135deg, #eff5ff 0%, #f5eeff 60%, #ffeef2 100%);
    border: 1px solid rgba(0,0,0,0.05);
    box-shadow: 0 30px 60px -30px rgba(15,23,42,0.15);
  }
  .k-price-big {
    font-size: clamp(44px, 5.5vw, 68px);
    font-weight: 700;
    letter-spacing: -0.03em;
    color: #1d1d1f;
    margin-top: 4px;
  }
  .k-price-big span {
    font-size: 0.4em; color: #6e6e73; font-weight: 500; margin-left: 6px;
  }
  .k-price-sub { color: #494950; font-size: 15px; margin-top: 6px; }

  /* -------------------- Final CTA -------------------- */
  .k-final {
    position: relative;
    padding: 120px 0 130px;
    text-align: center;
    overflow: hidden;
  }
  .k-final-bg { position: absolute; inset: 0; z-index: 0; pointer-events: none; }
  .k-final > .k-container { position: relative; z-index: 1; }
  .k-final .k-btn { margin-top: 34px; }
  .k-final .k-tiny { margin-top: 18px; }

  /* -------------------- Utility: reveal (matches Base.astro observer) -------------------- */
  .kaira-landing .reveal {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.7s cubic-bezier(0.16,1,0.3,1), transform 0.7s cubic-bezier(0.16,1,0.3,1);
  }
  .kaira-landing .reveal.is-visible {
    opacity: 1;
    transform: translateY(0);
  }
  .kaira-landing .reveal-delay-1 { transition-delay: 0.08s; }
  .kaira-landing .reveal-delay-2 { transition-delay: 0.16s; }
  .kaira-landing .reveal-delay-3 { transition-delay: 0.24s; }

  @media (prefers-reduced-motion: reduce) {
    .kaira-landing .reveal { opacity: 1; transform: none; transition: none; }
    .blob, .k-marquee-track, .k-float, .k-eyebrow .k-dot { animation: none !important; }
  }
</style>

<!-- ============================================================
     3D + interaction scripts (Three.js orb + tilt)
============================================================ -->
<script>
  // --- Tilt-on-mousemove (for the browser mock and product tiles) ---
  function initTilt() {
    const tiltEls = document.querySelectorAll<HTMLElement>('[data-tilt]:not([data-tilt-init])');
    tiltEls.forEach((el) => {
      el.setAttribute('data-tilt-init', '1');
      let baseRX = 0, baseRY = 0;
      if (el.classList.contains('k-frame')) { baseRX = 4; baseRY = -6; }
      const enter = () => el.style.willChange = 'transform';
      const leave = () => {
        el.style.transform = el.classList.contains('k-frame')
          ? `rotateX(${baseRX}deg) rotateY(${baseRY}deg)`
          : '';
        el.style.willChange = 'auto';
      };
      const move = (e: MouseEvent) => {
        const r = el.getBoundingClientRect();
        const x = ((e.clientX - r.left) / r.width - 0.5);
        const y = ((e.clientY - r.top) / r.height - 0.5);
        const strength = el.classList.contains('k-frame') ? 8 : 6;
        el.style.transform = `perspective(1200px) rotateX(${baseRX + (-y * strength).toFixed(2)}deg) rotateY(${baseRY + (x * strength).toFixed(2)}deg) translateZ(0)`;
      };
      el.addEventListener('mouseenter', enter);
      el.addEventListener('mousemove', move);
      el.addEventListener('mouseleave', leave);
    });
  }

  // --- Hero showcase rotator (auto-cycle slides + URL + accent) ---
  function initShowcase() {
    const frame = document.querySelector<HTMLElement>('.k-frame');
    if (!frame || frame.dataset.rotInit) return;
    frame.dataset.rotInit = '1';
    const slides = Array.from(frame.querySelectorAll<HTMLElement>('.k-slide'));
    const dots   = Array.from(frame.querySelectorAll<HTMLElement>('.k-frame-dots .d'));
    const urlEl  = document.getElementById('k-frame-url');
    if (slides.length < 2) return;

    let i = 0;
    const advance = () => {
      slides[i].classList.remove('is-active');
      dots[i]?.classList.remove('is-active');
      i = (i + 1) % slides.length;
      slides[i].classList.add('is-active');
      dots[i]?.classList.add('is-active');
      if (urlEl) urlEl.textContent = slides[i].dataset.slideUrl || urlEl.textContent;
    };
    setInterval(advance, 3800);
  }

  // --- Cursor spotlight in the hero backdrop ---
  function initSpotlight() {
    const hero = document.querySelector<HTMLElement>('.k-hero');
    const spot = document.getElementById('k-spotlight');
    if (!hero || !spot || hero.dataset.spInit) return;
    hero.dataset.spInit = '1';
    hero.addEventListener('pointermove', (e) => {
      const r = hero.getBoundingClientRect();
      const mx = ((e.clientX - r.left) / r.width) * 100;
      const my = ((e.clientY - r.top) / r.height) * 100;
      spot.style.setProperty('--mx', mx + '%');
      spot.style.setProperty('--my', my + '%');
    }, { passive: true });
  }

  // --- Magnetic CTA (button leans toward cursor when near) ---
  function initMagnetic() {
    const els = document.querySelectorAll<HTMLElement>('.k-magnetic:not([data-mag-init])');
    els.forEach((el) => {
      el.setAttribute('data-mag-init', '1');
      const inner = el.querySelector<HTMLElement>('.k-mag-inner') || el;
      const RANGE = 90; // px around the button that "pulls" it
      const STRENGTH = 0.35;
      const onMove = (e: PointerEvent) => {
        const r = el.getBoundingClientRect();
        const cx = r.left + r.width / 2;
        const cy = r.top  + r.height / 2;
        const dx = e.clientX - cx;
        const dy = e.clientY - cy;
        const dist = Math.hypot(dx, dy);
        if (dist > RANGE) {
          inner.style.setProperty('--mx', '0px');
          inner.style.setProperty('--my', '0px');
          return;
        }
        inner.style.setProperty('--mx', (dx * STRENGTH).toFixed(2) + 'px');
        inner.style.setProperty('--my', (dy * STRENGTH).toFixed(2) + 'px');
      };
      const reset = () => {
        inner.style.setProperty('--mx', '0px');
        inner.style.setProperty('--my', '0px');
      };
      window.addEventListener('pointermove', onMove, { passive: true });
      el.addEventListener('pointerleave', reset);
    });
  }

  // --- Count-up on scroll into view ---
  function initCountUp() {
    const els = document.querySelectorAll<HTMLElement>('.count:not([data-cu-init])');
    if (!els.length) return;
    els.forEach((el) => {
      el.setAttribute('data-cu-init', '1');
      const target = parseFloat(el.dataset.target || '0');
      const decimals = parseInt(el.dataset.decimals || '0', 10);
      const suffix = el.dataset.suffix || '';
      const formatNum = (v: number) => {
        const fixed = v.toFixed(decimals);
        // Add thousands separators for whole-number stats like 1,000
        return decimals === 0 && target >= 1000
          ? Math.round(v).toLocaleString('en-US')
          : fixed;
      };
      // Start hidden as 0 with same suffix so layout doesn't jump
      el.textContent = formatNum(0) + suffix;
      const io = new IntersectionObserver(
        (entries, obs) => {
          for (const e of entries) {
            if (!e.isIntersecting) continue;
            obs.disconnect();
            const start = performance.now();
            const dur = 1400;
            const ease = (t: number) => 1 - Math.pow(1 - t, 3);
            const step = (now: number) => {
              const t = Math.min(1, (now - start) / dur);
              const v = target * ease(t);
              el.textContent = formatNum(v) + suffix;
              if (t < 1) requestAnimationFrame(step);
            };
            requestAnimationFrame(step);
          }
        },
        { threshold: 0.35 }
      );
      io.observe(el);
    });
  }

  // --- Bento tile "is-active" state to trigger gauge fill + shield check ---
  function initBentoActive() {
    const tiles = document.querySelectorAll<HTMLElement>('.bt:not([data-bt-init])');
    tiles.forEach((el) => {
      el.setAttribute('data-bt-init', '1');
      new IntersectionObserver(
        (entries, obs) => {
          for (const e of entries) {
            if (e.isIntersecting) {
              el.classList.add('is-active');
              // Speed gauge: animate stroke-dashoffset from 12 → all the way filled to ~92
              const gauge = el.querySelector<SVGPathElement>('.gauge-fill');
              if (gauge) {
                // 100 - 8 = 92 filled (leaves a small tip)
                gauge.style.strokeDashoffset = '8';
              }
              obs.unobserve(el);
            }
          }
        },
        { threshold: 0.3 }
      ).observe(el);
    });
  }


  async function initHeroGem() {
    const canvas = document.getElementById('k-hero-canvas') as HTMLCanvasElement | null;
    if (!canvas || canvas.dataset.init) return;
    canvas.dataset.init = '1';

    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    let THREE: any;
    try { THREE = await import('three'); } catch { return; }

    let renderer: any;
    try {
      renderer = new THREE.WebGLRenderer({ canvas, alpha: true, antialias: true });
    } catch { return; }
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    renderer.setClearColor(0x000000, 0);

    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(38, 1, 0.1, 60);
    camera.position.z = 8;

    // Ambient soft light
    scene.add(new THREE.AmbientLight(0xffffff, 0.55));
    const key = new THREE.DirectionalLight(0xffffff, 0.9); key.position.set(3, 4, 5); scene.add(key);
    const rim = new THREE.DirectionalLight(0x8ab8ff, 0.6); rim.position.set(-4, -2, 3); scene.add(rim);

    // Iridescent gem
    const geo = new THREE.IcosahedronGeometry(1.55, 0);
    const gemMat = new THREE.ShaderMaterial({
      uniforms: { uTime: { value: 0 } },
      vertexShader: `
        varying vec3 vN; varying vec3 vP;
        void main() {
          vN = normalize(normalMatrix * normal);
          vec4 mv = modelViewMatrix * vec4(position, 1.0);
          vP = mv.xyz;
          gl_Position = projectionMatrix * mv;
        }`,
      fragmentShader: `
        varying vec3 vN; varying vec3 vP;
        uniform float uTime;
        void main() {
          vec3 v = normalize(-vP);
          float fr = pow(1.0 - abs(dot(v, vN)), 2.4);
          float hueSeed = dot(vN, vec3(0.7, 0.3, 0.2)) + uTime * 0.15;
          vec3 c1 = vec3(0.0, 0.44, 0.89);   // blue
          vec3 c2 = vec3(0.49, 0.23, 0.93);  // violet
          vec3 c3 = vec3(1.0, 0.22, 0.37);   // red
          float t = 0.5 + 0.5 * sin(hueSeed * 3.14159);
          vec3 base = mix(c1, c2, t);
          base = mix(base, c3, 0.5 + 0.5 * sin(hueSeed * 2.0 + 1.2));
          vec3 col = mix(vec3(0.95, 0.97, 1.0), base, 0.55) + fr * 0.85;
          gl_FragColor = vec4(col, 0.55 + fr * 0.4);
        }`,
      transparent: true,
    });
    const gem = new THREE.Mesh(geo, gemMat);
    scene.add(gem);

    // Wire shell over the gem
    const wire = new THREE.Mesh(
      new THREE.IcosahedronGeometry(1.62, 1),
      new THREE.MeshBasicMaterial({ color: 0x0071e3, wireframe: true, transparent: true, opacity: 0.14 })
    );
    scene.add(wire);

    // Orbit rings
    const rings: any[] = [];
    [
      { r: 2.6, tilt: [Math.PI / 2.2, 0.35], color: 0x0071e3, op: 0.35 },
      { r: 3.1, tilt: [Math.PI / 2.6, -0.5], color: 0x7c3aed, op: 0.25 },
    ].forEach((cfg) => {
      const ring = new THREE.Mesh(
        new THREE.TorusGeometry(cfg.r, 0.008, 8, 128),
        new THREE.MeshBasicMaterial({ color: cfg.color, transparent: true, opacity: cfg.op })
      );
      ring.rotation.set(cfg.tilt[0], 0, cfg.tilt[1]);
      rings.push(ring); scene.add(ring);
    });

    // Small orbiting spheres
    const spheres: any[] = [];
    [
      { r: 2.6, s: 0.09, color: 0x0071e3, speed: 0.55, phase: 0 },
      { r: 3.1, s: 0.07, color: 0xff375f, speed: -0.4, phase: 1.8 },
      { r: 2.2, s: 0.06, color: 0x34c759, speed: 0.7, phase: 3.2 },
    ].forEach((cfg) => {
      const s = new THREE.Mesh(
        new THREE.SphereGeometry(cfg.s, 16, 16),
        new THREE.MeshBasicMaterial({ color: cfg.color })
      );
      (s as any).userData = cfg;
      spheres.push(s); scene.add(s);
    });

    // Sparse particles
    const N = 220;
    const pos = new Float32Array(N * 3);
    for (let i = 0; i < N; i++) {
      const a = Math.sin(i * 12.9898) * 43758.5453;
      const b = Math.sin(i * 78.233) * 12543.2341;
      const c = Math.sin(i * 39.425) * 26431.5327;
      pos[i*3]   = ((a - Math.floor(a)) - 0.5) * 12;
      pos[i*3+1] = ((b - Math.floor(b)) - 0.5) * 7;
      pos[i*3+2] = ((c - Math.floor(c)) - 0.5) * 3;
    }
    const pg = new THREE.BufferGeometry();
    pg.setAttribute('position', new THREE.BufferAttribute(pos, 3));
    const particles = new THREE.Points(pg, new THREE.PointsMaterial({ color: 0x9bb8ff, size: 0.02, transparent: true, opacity: 0.75 }));
    scene.add(particles);

    // Resize
    function resize() {
      const w = canvas.clientWidth;
      const h = canvas.clientHeight;
      if (w === 0 || h === 0) return;
      renderer.setSize(w, h, false);
      camera.aspect = w / h;
      camera.updateProjectionMatrix();
    }
    const ro = new ResizeObserver(resize); ro.observe(canvas);
    resize();

    // Pointer parallax
    let mx = 0, my = 0, cmx = 0, cmy = 0;
    window.addEventListener('pointermove', (e) => {
      mx = (e.clientX / window.innerWidth - 0.5) * 2;
      my = (e.clientY / window.innerHeight - 0.5) * 2;
    }, { passive: true });

    // Visibility
    let visible = true;
    new IntersectionObserver(([e]) => { visible = e.isIntersecting; }, { threshold: 0 })
      .observe(canvas);

    let lastT = 0;
    function tick(t: number) {
      requestAnimationFrame(tick);
      if (!visible) return;
      const dt = Math.min((t - lastT) / 1000, 0.05) || 0.016;
      lastT = t;
      const ts = t / 1000;

      gemMat.uniforms.uTime.value = ts;
      gem.rotation.y += dt * 0.35;
      gem.rotation.x = Math.sin(ts * 0.6) * 0.15;
      wire.rotation.y -= dt * 0.2;
      wire.rotation.x += dt * 0.05;

      rings[0].rotation.z += dt * 0.15;
      rings[1].rotation.z -= dt * 0.1;

      spheres.forEach((s) => {
        const d = s.userData;
        const a = ts * d.speed + d.phase;
        s.position.set(Math.cos(a) * d.r, Math.sin(a * 0.7) * 0.6, Math.sin(a) * d.r);
      });

      particles.rotation.y += dt * 0.02;

      cmx += (mx - cmx) * 0.05;
      cmy += (my - cmy) * 0.05;
      camera.position.x = cmx * 0.5;
      camera.position.y = -cmy * 0.35;
      camera.lookAt(0, 0, 0);

      renderer.render(scene, camera);
    }
    requestAnimationFrame(tick);
  }

  function bootLanding() {
    if (!document.querySelector('.kaira-landing')) return;
    initTilt();
    initCountUp();
    initBentoActive();
    initShowcase();
    initSpotlight();
    initMagnetic();
  }
  bootLanding();
  document.addEventListener('astro:page-load', bootLanding);
</script>
