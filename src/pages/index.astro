---
import Base from '../layouts/Base.astro';

// Business types shown as a horizontal marquee — grounds the brand in real "local" work.
const marquee = [
  'Cafés', 'Barbershops', 'Dentists', 'Plumbers', 'Bakeries',
  'Realtors', 'Studios', 'Salons', 'Roofers', 'Boutiques',
  'Law Firms', 'Gyms', 'Contractors', 'Clinics', 'Florists',
];

const stats = [
  { n: '1000', prefix: '$', l: 'Websites from' },
  { n: '0.4',  suffix: 's',  decimals: 1, l: 'Median load time' },
  { n: '95',   suffix: '+',  l: 'Lighthouse scores' },
  { n: '24',   suffix: '/7', l: 'Care & monitoring' },
];

// Product-style service tiles (Apple.com family lineup)
const tiles = [
  {
    name: 'Websites',
    tag: 'Custom. Considered. Quick.',
    body: 'Mobile-first sites built like products — sharp typography, buttery motion, and copy that turns visitors into customers.',
    accent: '#0071e3', // Apple blue
    accent2: '#5ac8fa',
    href: '/services',
  },
  {
    name: 'Local SEO',
    tag: 'Findable, from day one.',
    body: 'Technical foundations, clean structure, and local search signals so the right customers land on the right page.',
    accent: '#34c759',
    accent2: '#a7f3d0',
    href: '/services',
  },
  {
    name: 'Care Plans',
    tag: 'Set it and forget it.',
    body: 'Updates, security, backups, monitoring, and content tweaks handled monthly — from $75.',
    accent: '#ff375f',
    accent2: '#ffb37a',
    href: '/services',
  },
];

// 4-step process
const steps = [
  { n: '01', title: 'Discovery',     body: 'A friendly call to understand your business, customers, and what a win looks like.' },
  { n: '02', title: 'Design & Build', body: 'We design, build, and share progress along the way. No surprises, no jargon.' },
  { n: '03', title: 'Launch',        body: 'Your site goes live — fast, polished, and ready to be found on Google.' },
  { n: '04', title: 'Grow',          body: 'Optional SEO and care plans keep improving your site month after month.' },
];
---

<Base
  title="KAIRA — Beautifully simple websites for local businesses"
  description="KAIRA designs, builds, and cares for websites that make local businesses look inevitable. Custom sites from $1,000 with SEO and care plans built in."
>
  <div class="kaira-landing" data-testid="landing-root">

    <!-- =====================================================
         HERO
    ===================================================== -->
    <section class="k-hero" data-testid="hero-section">
      <!-- soft airy backdrop with a cursor-following spotlight -->
      <div class="k-hero-bg" aria-hidden="true">
        <div class="blob blob-a"></div>
        <div class="blob blob-b"></div>
        <div class="blob blob-c"></div>
        <div class="grid-mask"></div>
        <div class="k-spotlight" id="k-spotlight"></div>
      </div>

      <div class="k-container k-hero-grid">
        <!-- LEFT: copy -->
        <div class="k-hero-copy">
          <p class="k-eyebrow reveal" data-testid="hero-eyebrow">
            <span class="k-dot"></span> Now booking Spring '26 projects
          </p>

          <h1 class="k-h1 reveal-words" data-testid="hero-title">
            Websites that make your business look
            <span class="grad-text">inevitable.</span>
          </h1>

          <p class="k-lead reveal reveal-delay-2" data-testid="hero-lead">
            Beautifully simple, ridiculously fast websites for local businesses —
            designed, built, and cared for by people who obsess over the details.
          </p>

          <div class="k-cta reveal reveal-delay-3">
            <a href="/contact" class="k-btn k-btn-primary k-magnetic" data-testid="hero-cta-primary">
              <span class="k-mag-inner">
                Get a free quote
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
              </span>
            </a>
            <a href="/portfolio" class="k-btn k-btn-ghost" data-testid="hero-cta-secondary">
              See our work
            </a>
          </div>

          <p class="k-note reveal reveal-delay-3" data-testid="hero-note">
            From $1,000 · Care plans from $75/mo · Reply within 1 business day
          </p>
        </div>

        <!-- RIGHT: rotating device showcase (ALWAYS visible above the fold) -->
        <div class="k-showcase reveal reveal-delay-2" data-testid="hero-showcase">
          <div class="k-showcase-glow" aria-hidden="true"></div>

          <!-- Floating badges (mid-air, glass) -->
          <div class="k-float k-float-a" aria-hidden="true" data-testid="float-lighthouse">
            <div class="score">98</div>
            <div class="score-label">Lighthouse<br/>Performance</div>
          </div>
          <div class="k-float k-float-b" aria-hidden="true" data-testid="float-speed">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
            <div><b>0.4s</b><span>First paint</span></div>
          </div>
          <div class="k-float k-float-c" aria-hidden="true" data-testid="float-seo">
            <div class="pill-tag">SEO</div>
            <div><b>#1</b><span>on Google Maps</span></div>
          </div>

          <!-- Rotating browser frame with 3 detailed mock sites inside -->
          <div class="k-frame" data-tilt data-testid="hero-frame">
            <div class="k-window-bar" aria-hidden="true">
              <span class="dot d-r"></span><span class="dot d-y"></span><span class="dot d-g"></span>
              <div class="k-url" id="k-frame-url">bellascafe.com</div>
            </div>
            <div class="k-frame-body">
              <!-- SLIDE 1: Café -->
              <div class="k-slide is-active" data-slide-url="bellascafe.com" data-slide-accent="#c2410c">
                <div class="cafe">
                  <div class="cafe-nav">
                    <span class="cafe-logo">bella's</span>
                    <span class="cafe-links"><i>Menu</i><i>Story</i><i>Visit</i></span>
                    <span class="cafe-cta">Reserve</span>
                  </div>
                  <div class="cafe-hero">
                    <div class="cafe-hero-img"></div>
                    <div class="cafe-hero-copy">
                      <p class="cafe-eyebrow">Est. 2012 · Portland, OR</p>
                      <h4 class="cafe-title">Slow mornings, <em>strong espresso.</em></h4>
                      <p class="cafe-sub">House-roasted beans, warm sourdough, and a pastry case that never disappoints.</p>
                      <div class="cafe-btns">
                        <span class="cafe-btn primary">Order online</span>
                        <span class="cafe-btn ghost">View menu →</span>
                      </div>
                    </div>
                  </div>
                  <div class="cafe-menu">
                    <div class="cafe-menu-item"><span>Cortado</span><span class="dots"></span><b>$4</b></div>
                    <div class="cafe-menu-item"><span>Almond croissant</span><span class="dots"></span><b>$5</b></div>
                    <div class="cafe-menu-item"><span>Avocado toast</span><span class="dots"></span><b>$12</b></div>
                  </div>
                </div>
              </div>

              <!-- SLIDE 2: Dental -->
              <div class="k-slide" data-slide-url="ridgelinedental.com" data-slide-accent="#0071e3">
                <div class="dental">
                  <div class="dental-nav">
                    <span class="dental-logo"><span class="dl-dot"></span> Ridgeline</span>
                    <span class="dental-links"><i>Services</i><i>Team</i><i>New patients</i></span>
                    <span class="dental-cta">Book visit</span>
                  </div>
                  <div class="dental-hero">
                    <h4 class="dental-title">Modern dentistry, <span>zero anxiety.</span></h4>
                    <p class="dental-sub">Same-day crowns · Emergency care · Weekend hours</p>
                    <div class="dental-card">
                      <div class="dental-card-head">
                        <span class="dc-badge">Next available</span>
                        <span class="dc-time">Tomorrow · 9:40 AM</span>
                      </div>
                      <div class="dental-card-body">
                        <span class="dc-pill">Sat 8:00</span>
                        <span class="dc-pill">Sat 10:30</span>
                        <span class="dc-pill active">Mon 9:40</span>
                        <span class="dc-pill">Mon 2:15</span>
                      </div>
                      <div class="dental-book">Book instantly →</div>
                    </div>
                  </div>
                  <div class="dental-stats">
                    <div><b>4.9★</b><span>642 reviews</span></div>
                    <div><b>12yr</b><span>in the neighborhood</span></div>
                    <div><b>$0</b><span>emergency exams</span></div>
                  </div>
                </div>
              </div>

              <!-- SLIDE 3: Barbershop -->
              <div class="k-slide" data-slide-url="oakandiron.co" data-slide-accent="#ff375f">
                <div class="barber">
                  <div class="barber-nav">
                    <span class="barber-logo">OAK &amp; IRON</span>
                    <span class="barber-links"><i>Menu</i><i>Book</i><i>Shop</i></span>
                    <span class="barber-cta">Book chair</span>
                  </div>
                  <div class="barber-hero">
                    <h4 class="barber-title">Classic cuts. <em>Modern craft.</em></h4>
                    <p class="barber-sub">Six chairs. Twenty-three years. One neighborhood.</p>
                    <div class="barber-services">
                      <div class="barber-item"><span>Skin fade + hot towel</span><b>$38</b></div>
                      <div class="barber-item"><span>Beard sculpt &amp; line-up</span><b>$22</b></div>
                      <div class="barber-item highlight"><span>The full works</span><b>$55</b></div>
                    </div>
                    <div class="barber-cta-big">Reserve a chair →</div>
                  </div>
                </div>
              </div>
            </div>

            <!-- Slide indicator dots -->
            <div class="k-frame-dots" aria-hidden="true">
              <span class="d is-active"></span><span class="d"></span><span class="d"></span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- =====================================================
         MARQUEE — who Kaira builds for
    ===================================================== -->
    <section class="k-marquee" aria-label="Businesses we build for" data-testid="marquee-section">
      <p class="k-tiny">Loved by main street. Built for main street.</p>
      <div class="k-marquee-track" aria-hidden="true">
        {[...marquee, ...marquee].map((m) => (
          <span class="k-marquee-item">{m}<span class="dotSep">·</span></span>
        ))}
      </div>
    </section>

    <!-- =====================================================
         BENTO GRID — Apple-style variety tiles ("hook" visuals)
    ===================================================== -->
    <section class="k-bento" aria-label="What makes a Kaira site" data-testid="bento-section">
      <div class="k-container">
        <p class="k-kicker reveal">Under the hood</p>
        <h2 class="k-h2 reveal-words">
          Every site ships with <span class="grad-text">the whole package.</span>
        </h2>

        <div class="k-bento-grid">
          <!-- Big tile: Speed / gauge -->
          <div class="bt bt-speed reveal" data-testid="bento-speed">
            <div class="bt-head">
              <span class="bt-eyebrow">Speed</span>
              <h3>Sub-second by default.</h3>
              <p>Every page ships with image compression, code-splitting, and edge caching baked in.</p>
            </div>
            <div class="bt-gauge" aria-hidden="true">
              <svg viewBox="0 0 200 120">
                <defs>
                  <linearGradient id="gauge-g" x1="0" y1="0" x2="1" y2="0">
                    <stop offset="0" stop-color="#ff375f"/>
                    <stop offset="0.5" stop-color="#ff9500"/>
                    <stop offset="1" stop-color="#34c759"/>
                  </linearGradient>
                </defs>
                <path d="M 20 100 A 80 80 0 0 1 180 100" stroke="#e5e5ea" stroke-width="14" fill="none" stroke-linecap="round"/>
                <path class="gauge-fill" d="M 20 100 A 80 80 0 0 1 180 100" stroke="url(#gauge-g)" stroke-width="14" fill="none" stroke-linecap="round" pathLength="100" stroke-dasharray="100" stroke-dashoffset="100"/>
                <circle class="gauge-tick" cx="20" cy="100" r="10" fill="#fff" stroke="#ff375f" stroke-width="3"/>
              </svg>
              <div class="gauge-value"><b class="count" data-target="0.4" data-decimals="1" data-suffix="s">0.4s</b><span>First paint</span></div>
            </div>
          </div>

          <!-- Local SEO -->
          <div class="bt bt-map reveal reveal-delay-1" data-testid="bento-seo">
            <span class="bt-eyebrow">Local SEO</span>
            <h3>Show up on the map.</h3>
            <div class="bt-map-art" aria-hidden="true">
              <div class="map-grid"></div>
              <div class="map-pin"><span></span></div>
              <div class="map-pulse"></div>
            </div>
          </div>

          <!-- Care shield -->
          <div class="bt bt-care reveal reveal-delay-2" data-testid="bento-care">
            <span class="bt-eyebrow">Care</span>
            <h3>Sleeps, so you don't have to.</h3>
            <div class="bt-shield" aria-hidden="true">
              <svg viewBox="0 0 120 140" fill="none">
                <defs>
                  <linearGradient id="shield-g" x1="0" y1="0" x2="1" y2="1">
                    <stop offset="0" stop-color="#0071e3"/>
                    <stop offset="1" stop-color="#7c3aed"/>
                  </linearGradient>
                </defs>
                <path d="M60 8 L108 28 V72 C108 100 87 122 60 132 C33 122 12 100 12 72 V28 Z"
                  fill="url(#shield-g)" fill-opacity="0.12" stroke="url(#shield-g)" stroke-width="2"/>
                <path class="check" d="M40 70 L55 85 L82 55" stroke="url(#shield-g)" stroke-width="4.5" stroke-linecap="round" stroke-linejoin="round" fill="none" pathLength="100" stroke-dasharray="100" stroke-dashoffset="100"/>
              </svg>
            </div>
            <p class="bt-foot">Updates · Backups · Monitoring · Support</p>
          </div>

          <!-- Device / responsive -->
          <div class="bt bt-devices reveal" data-testid="bento-devices">
            <div class="bt-devices-art" aria-hidden="true">
              <div class="dev-laptop"><div class="dev-screen"></div><div class="dev-hinge"></div></div>
              <div class="dev-phone"></div>
            </div>
            <span class="bt-eyebrow">Every screen</span>
            <h3>Looks sharp phone to widescreen.</h3>
          </div>

          <!-- Custom design / palette -->
          <div class="bt bt-palette reveal reveal-delay-1" data-testid="bento-design">
            <span class="bt-eyebrow">Custom design</span>
            <h3>No cookie-cutter templates.</h3>
            <div class="bt-swatches" aria-hidden="true">
              <div class="sw" style="background:#0071e3"></div>
              <div class="sw" style="background:#7c3aed"></div>
              <div class="sw" style="background:#ff375f"></div>
              <div class="sw" style="background:#34c759"></div>
              <div class="sw" style="background:#ff9500"></div>
              <div class="sw" style="background:#1d1d1f"></div>
            </div>
          </div>

          <!-- Turnaround -->
          <div class="bt bt-turn reveal reveal-delay-2" data-testid="bento-turnaround">
            <span class="bt-eyebrow">Turnaround</span>
            <h3><span class="count grad-text stat-num" data-target="14" data-suffix=" days">14 days</span></h3>
            <p>Typical time from kickoff to a live, indexable site.</p>
            <div class="bt-timeline" aria-hidden="true">
              <span></span><span></span><span></span><span></span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- =====================================================
         BIG STATEMENT — Apple type moment
    ===================================================== -->
    <section class="k-statement" data-testid="statement-section">
      <div class="k-container narrow">
        <h2 class="k-h2 reveal-words">
          Your storefront never sleeps. <span class="grad-text">Make it worth showing up to.</span>
        </h2>
        <p class="k-sub reveal">
          72% of local customers check your website before they visit. We make sure the first impression
          is the one that closes the deal.
        </p>
      </div>
    </section>

    <!-- =====================================================
         STAT STRIP
    ===================================================== -->
    <section class="k-stats" data-testid="stats-section">
      <div class="k-container">
        <div class="k-stats-grid">
          {stats.map((s, i) => (
            <div class={`k-stat reveal reveal-delay-${Math.min(i, 3)}`} data-testid={`stat-${i}`}>
              <p class="n">
                {s.prefix && <span class="pfx">{s.prefix}</span>}
                <span class="count" data-target={s.n} data-decimals={s.decimals ?? 0} data-suffix={s.suffix ?? ''}>0</span>
              </p>
              <p class="l">{s.l}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- =====================================================
         PRODUCT CARDS — the Kaira family
    ===================================================== -->
    <section class="k-family" aria-labelledby="family-heading" data-testid="family-section">
      <div class="k-container">
        <p class="k-kicker reveal">The Kaira family</p>
        <h2 id="family-heading" class="k-h2 reveal-words">
          Three services. <span class="grad-text">One quiet obsession.</span>
        </h2>
        <p class="k-sub reveal">
          Websites, SEO, and care — designed to work together so your business shows up, stands out, and keeps improving.
        </p>

        <div class="k-family-grid">
          {tiles.map((t, i) => (
            <a href={t.href} class={`k-tile reveal reveal-delay-${Math.min(i, 3)}`} data-tilt style={`--a:${t.accent};--b:${t.accent2}`} data-testid={`tile-${t.name.toLowerCase().replace(' ','-')}`}>
              <div class="k-tile-art" aria-hidden="true">
                {t.name === 'Websites' && (
                  <svg viewBox="0 0 200 140" fill="none">
                    <defs>
                      <linearGradient id="wg1" x1="0" y1="0" x2="1" y2="1">
                        <stop offset="0" stop-color={t.accent}/><stop offset="1" stop-color={t.accent2}/>
                      </linearGradient>
                    </defs>
                    <rect x="20" y="18" width="160" height="104" rx="14" fill="url(#wg1)" fill-opacity="0.15" stroke="url(#wg1)" stroke-width="1.5"/>
                    <rect x="20" y="18" width="160" height="18" rx="14" fill="url(#wg1)" fill-opacity="0.28"/>
                    <circle cx="32" cy="27" r="2.5" fill="#fff"/><circle cx="42" cy="27" r="2.5" fill="#fff"/><circle cx="52" cy="27" r="2.5" fill="#fff"/>
                    <rect x="34" y="50" width="90" height="8" rx="4" fill="url(#wg1)"/>
                    <rect x="34" y="66" width="130" height="4" rx="2" fill="url(#wg1)" fill-opacity="0.6"/>
                    <rect x="34" y="76" width="110" height="4" rx="2" fill="url(#wg1)" fill-opacity="0.4"/>
                    <rect x="34" y="92" width="40" height="14" rx="7" fill="url(#wg1)"/>
                    <rect x="130" y="88" width="34" height="24" rx="6" fill="url(#wg1)" fill-opacity="0.35"/>
                  </svg>
                )}
                {t.name === 'Local SEO' && (
                  <svg viewBox="0 0 200 140" fill="none">
                    <defs>
                      <linearGradient id="wg2" x1="0" y1="0" x2="1" y2="1">
                        <stop offset="0" stop-color={t.accent}/><stop offset="1" stop-color={t.accent2}/>
                      </linearGradient>
                    </defs>
                    <circle cx="100" cy="70" r="46" stroke="url(#wg2)" stroke-width="1.5" fill="url(#wg2)" fill-opacity="0.08"/>
                    <ellipse cx="100" cy="70" rx="46" ry="20" stroke="url(#wg2)" stroke-width="1.5" fill="none"/>
                    <ellipse cx="100" cy="70" rx="20" ry="46" stroke="url(#wg2)" stroke-width="1.5" fill="none"/>
                    <path d="M100 24 Q108 40 122 46" stroke="url(#wg2)" stroke-width="1.5" fill="none"/>
                    <circle cx="100" cy="70" r="6" fill="url(#wg2)"/>
                    <g transform="translate(138,32)">
                      <path d="M0 14 C0 6, 6 0, 14 0 C22 0, 28 6, 28 14 C28 24, 14 34, 14 34 S0 24, 0 14 Z" fill="url(#wg2)"/>
                      <circle cx="14" cy="14" r="5" fill="#fff"/>
                    </g>
                  </svg>
                )}
                {t.name === 'Care Plans' && (
                  <svg viewBox="0 0 200 140" fill="none">
                    <defs>
                      <linearGradient id="wg3" x1="0" y1="0" x2="1" y2="1">
                        <stop offset="0" stop-color={t.accent}/><stop offset="1" stop-color={t.accent2}/>
                      </linearGradient>
                    </defs>
                    <path d="M100 25 L140 45 V80 C140 100 122 115 100 120 C78 115 60 100 60 80 V45 Z"
                      fill="url(#wg3)" fill-opacity="0.14" stroke="url(#wg3)" stroke-width="1.5"/>
                    <path d="M82 78 L95 91 L120 66" stroke="url(#wg3)" stroke-width="3" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                    <circle cx="42" cy="42" r="6" fill="url(#wg3)" fill-opacity="0.6"/>
                    <circle cx="160" cy="106" r="4" fill="url(#wg3)" fill-opacity="0.8"/>
                    <circle cx="170" cy="40" r="3" fill="url(#wg3)" fill-opacity="0.5"/>
                  </svg>
                )}
              </div>
              <p class="k-tile-tag">{t.tag}</p>
              <h3 class="k-tile-name" style={`background: linear-gradient(120deg, ${t.accent}, ${t.accent2}); -webkit-background-clip:text; background-clip:text; color:transparent;`}>
                {t.name}
              </h3>
              <p class="k-tile-body">{t.body}</p>
              <span class="k-tile-more">
                Learn more
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
              </span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- =====================================================
         PROCESS
    ===================================================== -->
    <section class="k-process" data-testid="process-section">
      <div class="k-container">
        <p class="k-kicker reveal">How it works</p>
        <h2 class="k-h2 reveal-words">
          Four steps. <span class="grad-text">Zero surprises.</span>
        </h2>

        <ol class="k-steps">
          {steps.map((s, i) => (
            <li class={`k-step reveal reveal-delay-${Math.min(i, 3)}`} data-testid={`step-${s.n}`}>
              <div class="k-step-num">{s.n}</div>
              <h3>{s.title}</h3>
              <p>{s.body}</p>
            </li>
          ))}
        </ol>

        <p class="k-timeline reveal">Typical timeline · <b>2–4 weeks from kickoff to launch</b></p>
      </div>
    </section>

    <!-- =====================================================
         PRICING TEASER
    ===================================================== -->
    <section class="k-price" data-testid="price-section">
      <div class="k-container narrow">
        <div class="k-price-card reveal">
          <div>
            <p class="k-tiny">Starting from</p>
            <p class="k-price-big">$1,000<span>/site</span></p>
            <p class="k-price-sub">Plus care from $75/mo. Custom pricing for SEO.</p>
          </div>
          <a href="/pricing" class="k-btn k-btn-primary" data-testid="price-cta">
            See pricing
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </a>
        </div>
      </div>
    </section>

    <!-- =====================================================
         FINAL CTA
    ===================================================== -->
    <section class="k-final" data-testid="final-cta">
      <div class="k-final-bg" aria-hidden="true">
        <div class="blob blob-a"></div>
        <div class="blob blob-c"></div>
      </div>
      <div class="k-container">
        <h2 class="k-h2 reveal-words">
          Ready to look like the biggest <span class="grad-text">small business in town?</span>
        </h2>
        <p class="k-sub reveal">
