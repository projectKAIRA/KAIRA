---
import Base from '../layouts/Base.astro';

// Business types shown as a horizontal marquee — grounds the brand in real "local" work.
const marquee = [
  'Cafés', 'Barbershops', 'Dentists', 'Plumbers', 'Bakeries',
  'Realtors', 'Studios', 'Salons', 'Roofers', 'Boutiques',
  'Law Firms', 'Gyms', 'Contractors', 'Clinics', 'Florists',
];

const stats = [
  { n: '$1,000', l: 'Websites from' },
  { n: '<1s',    l: 'Median load time' },
  { n: '95+',    l: 'Lighthouse scores' },
  { n: '24/7',   l: 'Care & monitoring' },
];

// Product-style service tiles (Apple.com family lineup)
const tiles = [
  {
    name: 'Websites',
    tag: 'Custom. Considered. Quick.',
    body: 'Mobile-first sites built like products — sharp typography, buttery motion, and copy that turns visitors into customers.',
    accent: '#0071e3', // Apple blue
    accent2: '#5ac8fa',
    href: '/services',
  },
  {
    name: 'Local SEO',
    tag: 'Findable, from day one.',
    body: 'Technical foundations, clean structure, and local search signals so the right customers land on the right page.',
    accent: '#34c759',
    accent2: '#a7f3d0',
    href: '/services',
  },
  {
    name: 'Care Plans',
    tag: 'Set it and forget it.',
    body: 'Updates, security, backups, monitoring, and content tweaks handled monthly — from $75.',
    accent: '#ff375f',
    accent2: '#ffb37a',
    href: '/services',
  },
];

// 4-step process
const steps = [
  { n: '01', title: 'Discovery',     body: 'A friendly call to understand your business, customers, and what a win looks like.' },
  { n: '02', title: 'Design & Build', body: 'We design, build, and share progress along the way. No surprises, no jargon.' },
  { n: '03', title: 'Launch',        body: 'Your site goes live — fast, polished, and ready to be found on Google.' },
  { n: '04', title: 'Grow',          body: 'Optional SEO and care plans keep improving your site month after month.' },
];
---

<Base
  title="KAIRA — Beautifully simple websites for local businesses"
  description="KAIRA designs, builds, and cares for websites that make local businesses look inevitable. Custom sites from $1,000 with SEO and care plans built in."
>
  <div class="kaira-landing" data-testid="landing-root">

    <!-- =====================================================
         HERO
    ===================================================== -->
    <section class="k-hero" data-testid="hero-section">
      <!-- soft airy backdrop -->
      <div class="k-hero-bg" aria-hidden="true">
        <div class="blob blob-a"></div>
        <div class="blob blob-b"></div>
        <div class="blob blob-c"></div>
        <div class="grid-mask"></div>
      </div>

      <div class="k-container">
        <p class="k-eyebrow reveal" data-testid="hero-eyebrow">
          <span class="k-dot"></span> Now booking Spring '26 projects
        </p>

        <h1 class="k-h1 reveal-words" data-testid="hero-title">
          Websites that make your business look
          <span class="k-grad">inevitable.</span>
        </h1>

        <p class="k-lead reveal reveal-delay-2" data-testid="hero-lead">
          Beautifully simple, ridiculously fast websites for local businesses.
          Designed to impress. Engineered to be found. Cared for so it stays that way.
        </p>

        <div class="k-cta reveal reveal-delay-3">
          <a href="/contact" class="k-btn k-btn-primary" data-testid="hero-cta-primary">
            Get a free quote
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </a>
          <a href="/portfolio" class="k-btn k-btn-ghost" data-testid="hero-cta-secondary">
            See our work
          </a>
        </div>

        <p class="k-note reveal reveal-delay-3" data-testid="hero-note">
          From $1,000 · Care plans from $75/mo · Reply within 1 business day
        </p>

        <!-- 3D hero stage: floating gradient orb + parallax browser card -->
        <div class="k-stage reveal reveal-delay-3" data-testid="hero-stage">
          <canvas id="k-hero-canvas" aria-hidden="true"></canvas>

          <div class="k-window" data-tilt data-testid="hero-window">
            <div class="k-window-bar" aria-hidden="true">
              <span class="dot d-r"></span><span class="dot d-y"></span><span class="dot d-g"></span>
              <div class="k-url">trykaira.ai</div>
            </div>
            <div class="k-window-body">
              <div class="k-mock-nav">
                <span class="k-mock-logo"></span>
                <span class="k-mock-links"><i></i><i></i><i></i></span>
                <span class="k-mock-cta"></span>
              </div>
              <div class="k-mock-hero">
                <div class="k-mock-title"></div>
                <div class="k-mock-title short"></div>
                <div class="k-mock-para"></div>
                <div class="k-mock-para w80"></div>
                <div class="k-mock-btn"></div>
              </div>
              <div class="k-mock-grid">
                <div class="k-mock-card"><div class="chip chip-a"></div></div>
                <div class="k-mock-card"><div class="chip chip-b"></div></div>
                <div class="k-mock-card"><div class="chip chip-c"></div></div>
              </div>
            </div>
          </div>

          <!-- floating badges around the window -->
          <div class="k-float k-float-a" aria-hidden="true" data-testid="float-lighthouse">
            <div class="score">98</div>
            <div class="score-label">Lighthouse<br/>Performance</div>
          </div>
          <div class="k-float k-float-b" aria-hidden="true" data-testid="float-speed">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
            <div><b>0.4s</b><span>First paint</span></div>
          </div>
          <div class="k-float k-float-c" aria-hidden="true" data-testid="float-seo">
            <div class="pill-tag">SEO</div>
            <div><b>#1</b><span>on Google Maps</span></div>
          </div>
        </div>
      </div>
    </section>

    <!-- =====================================================
         MARQUEE — who Kaira builds for
    ===================================================== -->
    <section class="k-marquee" aria-label="Businesses we build for" data-testid="marquee-section">
      <p class="k-tiny">Loved by main street. Built for main street.</p>
      <div class="k-marquee-track" aria-hidden="true">
        {[...marquee, ...marquee].map((m) => (
          <span class="k-marquee-item">{m}<span class="dotSep">·</span></span>
        ))}
      </div>
    </section>

    <!-- =====================================================
         BIG STATEMENT — Apple type moment
    ===================================================== -->
    <section class="k-statement" data-testid="statement-section">
      <div class="k-container narrow">
        <h2 class="k-h2 reveal-words">
          Your storefront never sleeps. <span class="k-grad">Make it worth showing up to.</span>
        </h2>
        <p class="k-sub reveal">
          72% of local customers check your website before they visit. We make sure the first impression
          is the one that closes the deal.
        </p>
      </div>
    </section>

    <!-- =====================================================
         STAT STRIP
    ===================================================== -->
    <section class="k-stats" data-testid="stats-section">
      <div class="k-container">
        <div class="k-stats-grid">
          {stats.map((s, i) => (
            <div class={`k-stat reveal reveal-delay-${Math.min(i, 3)}`} data-testid={`stat-${i}`}>
              <p class="n">{s.n}</p>
              <p class="l">{s.l}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- =====================================================
         PRODUCT CARDS — the Kaira family
    ===================================================== -->
    <section class="k-family" aria-labelledby="family-heading" data-testid="family-section">
      <div class="k-container">
        <p class="k-kicker reveal">The Kaira family</p>
        <h2 id="family-heading" class="k-h2 reveal-words">
          Three services. <span class="k-grad">One quiet obsession.</span>
        </h2>
        <p class="k-sub reveal">
          Websites, SEO, and care — designed to work together so your business shows up, stands out, and keeps improving.
        </p>

        <div class="k-family-grid">
          {tiles.map((t, i) => (
            <a href={t.href} class={`k-tile reveal reveal-delay-${Math.min(i, 3)}`} data-tilt style={`--a:${t.accent};--b:${t.accent2}`} data-testid={`tile-${t.name.toLowerCase().replace(' ','-')}`}>
              <div class="k-tile-art" aria-hidden="true">
                {t.name === 'Websites' && (
                  <svg viewBox="0 0 200 140" fill="none">
                    <defs>
                      <linearGradient id="wg1" x1="0" y1="0" x2="1" y2="1">
                        <stop offset="0" stop-color={t.accent}/><stop offset="1" stop-color={t.accent2}/>
                      </linearGradient>
                    </defs>
                    <rect x="20" y="18" width="160" height="104" rx="14" fill="url(#wg1)" fill-opacity="0.15" stroke="url(#wg1)" stroke-width="1.5"/>
                    <rect x="20" y="18" width="160" height="18" rx="14" fill="url(#wg1)" fill-opacity="0.28"/>
                    <circle cx="32" cy="27" r="2.5" fill="#fff"/><circle cx="42" cy="27" r="2.5" fill="#fff"/><circle cx="52" cy="27" r="2.5" fill="#fff"/>
                    <rect x="34" y="50" width="90" height="8" rx="4" fill="url(#wg1)"/>
                    <rect x="34" y="66" width="130" height="4" rx="2" fill="url(#wg1)" fill-opacity="0.6"/>
                    <rect x="34" y="76" width="110" height="4" rx="2" fill="url(#wg1)" fill-opacity="0.4"/>
                    <rect x="34" y="92" width="40" height="14" rx="7" fill="url(#wg1)"/>
                    <rect x="130" y="88" width="34" height="24" rx="6" fill="url(#wg1)" fill-opacity="0.35"/>
                  </svg>
                )}
                {t.name === 'Local SEO' && (
                  <svg viewBox="0 0 200 140" fill="none">
                    <defs>
                      <linearGradient id="wg2" x1="0" y1="0" x2="1" y2="1">
                        <stop offset="0" stop-color={t.accent}/><stop offset="1" stop-color={t.accent2}/>
                      </linearGradient>
                    </defs>
                    <circle cx="100" cy="70" r="46" stroke="url(#wg2)" stroke-width="1.5" fill="url(#wg2)" fill-opacity="0.08"/>
                    <ellipse cx="100" cy="70" rx="46" ry="20" stroke="url(#wg2)" stroke-width="1.5" fill="none"/>
                    <ellipse cx="100" cy="70" rx="20" ry="46" stroke="url(#wg2)" stroke-width="1.5" fill="none"/>
                    <path d="M100 24 Q108 40 122 46" stroke="url(#wg2)" stroke-width="1.5" fill="none"/>
                    <circle cx="100" cy="70" r="6" fill="url(#wg2)"/>
                    <g transform="translate(138,32)">
                      <path d="M0 14 C0 6, 6 0, 14 0 C22 0, 28 6, 28 14 C28 24, 14 34, 14 34 S0 24, 0 14 Z" fill="url(#wg2)"/>
                      <circle cx="14" cy="14" r="5" fill="#fff"/>
                    </g>
                  </svg>
                )}
                {t.name === 'Care Plans' && (
                  <svg viewBox="0 0 200 140" fill="none">
                    <defs>
                      <linearGradient id="wg3" x1="0" y1="0" x2="1" y2="1">
                        <stop offset="0" stop-color={t.accent}/><stop offset="1" stop-color={t.accent2}/>
                      </linearGradient>
                    </defs>
                    <path d="M100 25 L140 45 V80 C140 100 122 115 100 120 C78 115 60 100 60 80 V45 Z"
                      fill="url(#wg3)" fill-opacity="0.14" stroke="url(#wg3)" stroke-width="1.5"/>
                    <path d="M82 78 L95 91 L120 66" stroke="url(#wg3)" stroke-width="3" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                    <circle cx="42" cy="42" r="6" fill="url(#wg3)" fill-opacity="0.6"/>
                    <circle cx="160" cy="106" r="4" fill="url(#wg3)" fill-opacity="0.8"/>
                    <circle cx="170" cy="40" r="3" fill="url(#wg3)" fill-opacity="0.5"/>
                  </svg>
                )}
              </div>
              <p class="k-tile-tag">{t.tag}</p>
              <h3 class="k-tile-name" style={`background: linear-gradient(120deg, ${t.accent}, ${t.accent2}); -webkit-background-clip:text; background-clip:text; color:transparent;`}>
                {t.name}
              </h3>
              <p class="k-tile-body">{t.body}</p>
              <span class="k-tile-more">
                Learn more
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
              </span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- =====================================================
         PROCESS
    ===================================================== -->
    <section class="k-process" data-testid="process-section">
      <div class="k-container">
        <p class="k-kicker reveal">How it works</p>
        <h2 class="k-h2 reveal-words">
          Four steps. <span class="k-grad">Zero surprises.</span>
        </h2>

        <ol class="k-steps">
          {steps.map((s, i) => (
            <li class={`k-step reveal reveal-delay-${Math.min(i, 3)}`} data-testid={`step-${s.n}`}>
              <div class="k-step-num">{s.n}</div>
              <h3>{s.title}</h3>
              <p>{s.body}</p>
            </li>
          ))}
        </ol>

        <p class="k-timeline reveal">Typical timeline · <b>2–4 weeks from kickoff to launch</b></p>
      </div>
    </section>

    <!-- =====================================================
         PRICING TEASER
    ===================================================== -->
    <section class="k-price" data-testid="price-section">
      <div class="k-container narrow">
        <div class="k-price-card reveal">
          <div>
            <p class="k-tiny">Starting from</p>
            <p class="k-price-big">$1,000<span>/site</span></p>
            <p class="k-price-sub">Plus care from $75/mo. Custom pricing for SEO.</p>
          </div>
          <a href="/pricing" class="k-btn k-btn-primary" data-testid="price-cta">
            See pricing
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </a>
        </div>
      </div>
    </section>

    <!-- =====================================================
         FINAL CTA
    ===================================================== -->
    <section class="k-final" data-testid="final-cta">
      <div class="k-final-bg" aria-hidden="true">
        <div class="blob blob-a"></div>
        <div class="blob blob-c"></div>
      </div>
      <div class="k-container">
        <h2 class="k-h2 reveal-words">
          Ready to look like the biggest <span class="k-grad">small business in town?</span>
        </h2>
        <p class="k-sub reveal">
          Tell us about your business. We'll come back with a free, no-pressure quote within one business day.
        </p>
        <a href="/contact" class="k-btn k-btn-primary large reveal reveal-delay-2" data-testid="final-cta-btn">
          Start your quote
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
        </a>
        <p class="k-tiny reveal reveal-delay-3">No pressure · No obligation · Reply in 1 business day</p>
      </div>
    </section>
  </div>
</Base>

<!-- ============================================================
     STYLES — scoped to landing only via :has(.kaira-landing)
============================================================ -->
<style is:global>
  /* ---------- Reset the site-wide dark theme for this page only ---------- */
  html:has(.kaira-landing),
  body:has(.kaira-landing) {
    background: #fbfbfd !important;
    color: #1d1d1f !important;
    color-scheme: light !important;
  }
  body:has(.kaira-landing)::before,
  body:has(.kaira-landing)::after { display: none !important; }

  /* Recolor the sticky Nav on the landing page */
  body:has(.kaira-landing) header {
    background: rgba(251, 251, 253, 0.72) !important;
    border-color: rgba(0, 0, 0, 0.08) !important;
    -webkit-backdrop-filter: saturate(180%) blur(20px);
    backdrop-filter: saturate(180%) blur(20px);
  }
  body:has(.kaira-landing) header .text-ink,
  body:has(.kaira-landing) header span.uppercase {
    color: #1d1d1f !important;
  }
  body:has(.kaira-landing) header .nav-link { color: #1d1d1f !important; opacity: 0.85; }
  body:has(.kaira-landing) header .nav-link:hover { opacity: 1; }
  body:has(.kaira-landing) header .pill {
    color: #1d1d1f !important;
    background: rgba(0, 0, 0, 0.04) !important;
    border-color: rgba(0, 0, 0, 0.08) !important;
  }
  body:has(.kaira-landing) header a[href="/contact"] {
    background: #1d1d1f !important;
    box-shadow: 0 6px 20px -8px rgba(0, 0, 0, 0.45) !important;
  }

  /* Footer light adaptation on landing */
  body:has(.kaira-landing) footer {
    background: #f5f5f7 !important;
    color: #1d1d1f !important;
  }
  body:has(.kaira-landing) footer .text-ink,
  body:has(.kaira-landing) footer p.font-semibold { color: #1d1d1f !important; }
  body:has(.kaira-landing) footer a,
  body:has(.kaira-landing) footer .text-ink-muted { color: #6e6e73 !important; }
  body:has(.kaira-landing) footer a:hover { color: #0071e3 !important; }
  body:has(.kaira-landing) footer .hud-label { color: #6e6e73 !important; }
  body:has(.kaira-landing) footer .border-t { border-color: rgba(0,0,0,0.08) !important; }

  /* Butterfly rider decorative element — hide entirely on landing (Apple-clean) */
  body:has(.kaira-landing) #bf-rider,
  body:has(.kaira-landing) .butterfly-rider,
  body:has(.kaira-landing) [class*="butterfly-rider"] { display: none !important; }
</style>

<style>
  /* -------------------- Type system (SF Pro) -------------------- */
  .kaira-landing {
    font-family: "SF Pro Display", -apple-system, BlinkMacSystemFont, "Helvetica Neue", "Segoe UI", Arial, sans-serif;
    color: #1d1d1f;
    -webkit-font-smoothing: antialiased;
    letter-spacing: -0.01em;
  }
  .k-container {
    width: 100%;
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 22px;
  }
  .k-container.narrow { max-width: 860px; }

  .k-h1 {
    font-size: clamp(44px, 7vw, 92px);
    line-height: 1.02;
    font-weight: 700;
    letter-spacing: -0.03em;
    margin: 22px auto 0;
    max-width: 14ch;
    text-wrap: balance;
  }
  .k-h2 {
    font-size: clamp(34px, 5vw, 64px);
    line-height: 1.05;
    font-weight: 700;
    letter-spacing: -0.025em;
    margin: 14px auto 0;
    max-width: 18ch;
    text-wrap: balance;
    color: #1d1d1f;
  }
  .k-lead {
    font-size: clamp(17px, 1.6vw, 22px);
    line-height: 1.45;
    color: #494950;
    margin: 22px auto 0;
    max-width: 640px;
    font-weight: 400;
  }
  .k-sub {
    font-size: clamp(15px, 1.3vw, 19px);
    line-height: 1.55;
    color: #6e6e73;
    margin: 14px auto 0;
    max-width: 620px;
    text-wrap: balance;
  }
  .k-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.02em;
    color: #1d1d1f;
    background: #fff;
    border: 1px solid rgba(0,0,0,0.08);
    padding: 7px 14px;
    border-radius: 999px;
    box-shadow: 0 4px 12px -4px rgba(0,0,0,0.06);
  }
  .k-eyebrow .k-dot {
    width: 7px; height: 7px; border-radius: 99px;
    background: #34c759;
    box-shadow: 0 0 0 3px rgba(52,199,89,0.18);
    animation: pulse 2.4s ease-in-out infinite;
  }
  @keyframes pulse { 0%,100% { opacity: 1; } 50% { opacity: 0.5; } }

  .k-kicker {
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #0071e3;
    margin-bottom: 6px;
  }
  .k-tiny {
    font-size: 12px;
    letter-spacing: 0.04em;
    color: #86868b;
    text-transform: uppercase;
    font-weight: 500;
  }
  .k-note {
    font-size: 14px;
    color: #86868b;
    margin: 18px auto 0;
    max-width: 560px;
    text-wrap: balance;
  }

  /* Apple-style spectrum gradient — juicy but restrained */
  .k-grad {
    background: linear-gradient(100deg, #0071e3 0%, #7c3aed 45%, #ff375f 85%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    display: inline-block;
  }

  /* -------------------- Buttons -------------------- */
  .k-cta {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    justify-content: center;
    margin-top: 32px;
  }
  .k-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 15px;
    font-weight: 600;
    padding: 13px 22px;
    border-radius: 999px;
    line-height: 1;
    transition: transform 180ms cubic-bezier(0.32,0.72,0,1), box-shadow 220ms ease, background 180ms ease;
    text-decoration: none;
    will-change: transform;
  }
  .k-btn.large { font-size: 17px; padding: 16px 28px; }
  .k-btn-primary {
    background: #1d1d1f;
    color: #fff;
    box-shadow: 0 8px 24px -8px rgba(0,0,0,0.35), 0 2px 6px -2px rgba(0,0,0,0.25);
  }
  .k-btn-primary:hover { transform: translateY(-1px) scale(1.02); box-shadow: 0 14px 30px -8px rgba(0,0,0,0.45); }
  .k-btn-primary:active { transform: scale(0.98); }
  .k-btn-ghost {
    background: rgba(0,0,0,0.05);
    color: #1d1d1f;
    border: 1px solid rgba(0,0,0,0.06);
  }
  .k-btn-ghost:hover { background: rgba(0,0,0,0.08); transform: translateY(-1px); }

  /* -------------------- HERO -------------------- */
  .k-hero {
    position: relative;
    text-align: center;
    padding: 84px 0 60px;
    overflow: hidden;
  }
  .k-hero-bg {
    position: absolute; inset: 0;
    pointer-events: none;
    z-index: 0;
  }
  .k-hero-bg .grid-mask {
    position: absolute; inset: 0;
    background-image:
      linear-gradient(rgba(0,0,0,0.035) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0,0,0,0.035) 1px, transparent 1px);
    background-size: 44px 44px;
    mask-image: radial-gradient(ellipse 90% 60% at 50% 30%, #000 20%, transparent 75%);
    -webkit-mask-image: radial-gradient(ellipse 90% 60% at 50% 30%, #000 20%, transparent 75%);
  }
  .blob {
    position: absolute;
    border-radius: 50%;
