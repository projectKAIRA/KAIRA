---
import Base from '../layouts/Base.astro';

const tiers = [
  {
    name: 'Website Build',
    price: 'From $1,000',
    cadence: 'one-time project',
    blurb: 'A complete, custom professional website. Final pricing depends on scope — pages, features, and content.',
    a: '#2dd4bf',
    b: '#38bdf8',
    features: [
      'Custom mobile-first design',
      'Up to 5 pages (more available)',
      'Contact form & Google Maps',
      'Technical SEO foundations',
      'Fast, secure hosting setup',
      'Launch support & training',
    ],
    cta: 'Get a Quote',
    featured: true,
  },
  {
    name: 'Care Plan',
    price: 'From $75/mo',
    cadence: 'monthly maintenance',
    blurb: 'Keep your site secure, updated, and fresh — we handle the technical side so you never have to.',
    a: '#38bdf8',
    b: '#a78bfa',
    features: [
      'Software updates & security',
      'Daily backups',
      'Uptime monitoring',
      'Monthly content updates',
      'Priority email support',
      'Monthly health report',
    ],
    cta: 'Ask About Care Plans',
    featured: false,
  },
  {
    name: 'SEO Boost',
    price: 'Custom',
    cadence: 'monthly engagement',
    blurb: 'Ongoing local SEO to climb search results and bring in more nearby customers over time.',
    a: '#a78bfa',
    b: '#ff2d78',
    features: [
      'Local keyword strategy',
      'Google Business Profile optimization',
      'On-page improvements',
      'Content recommendations',
      'Monthly ranking & traffic report',
      'Pairs with any Care Plan',
    ],
    cta: 'Discuss SEO Goals',
    featured: false,
  },
];
---

<Base
  title="Pricing — Websites Starting at $1,000 | KAIRA"
  description="Transparent pricing: professional websites starting at $1,000, monthly care plans from $75/mo, and custom local SEO engagements."
>
  <section class="mesh-bg">
    <div class="mx-auto max-w-6xl px-5 pb-16 pt-16 text-center md:pt-24">
      <p class="reveal hud-label mb-4">PRICING <span class="text-white/25">//</span> TRANSPARENT</p>
      <h1 class="reveal-words text-4xl font-bold tracking-tight text-ink md:text-6xl">
        Simple. Honest. <span class="grad-text">Priced for main street.</span>
      </h1>
      <p class="reveal reveal-delay-1 mx-auto mt-5 max-w-xl text-lg text-ink-soft">
        Websites starting at $1,000. Every project is quoted individually based on what your
        business actually needs.
      </p>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-5 py-16 md:py-20">
    <div class="grid gap-6 lg:grid-cols-3">
      {
        tiers.map((t, i) => (
          <article
            class={`grad-border reveal reveal-delay-${i} relative flex flex-col overflow-hidden rounded-3xl p-8 ${
              t.featured ? 'shadow-(--shadow-glass-lg)' : ''
            }`}
            style={`--tile-a: ${t.a}; --tile-b: ${t.b};`}
          >
            <div
              aria-hidden="true"
              class="pointer-events-none absolute inset-0 opacity-40"
              style={`background: radial-gradient(120% 80% at 50% 115%, color-mix(in srgb, ${t.a} 20%, transparent) 0%, color-mix(in srgb, ${t.b} 8%, transparent) 50%, transparent 78%);`}
            />
            {t.featured && (
              <span class="absolute right-4 top-4 rounded-full border border-white/10 bg-black/40 px-3 py-1 text-[10px] font-semibold tracking-[0.16em] text-ink backdrop-blur">
                MOST POPULAR
              </span>
            )}
            <h2
              class="relative text-2xl font-bold tracking-tight"
              style={`background: linear-gradient(115deg, ${t.a}, ${t.b}); -webkit-background-clip: text; background-clip: text; color: transparent;`}
            >
              {t.name}
            </h2>
            <p class="stat-num relative mt-3 text-3xl font-bold text-ink">{t.price}</p>
            <p class="hud-label relative mt-1">{t.cadence}</p>
            <p class="relative mt-4 text-sm leading-relaxed text-ink-soft">{t.blurb}</p>
            <ul class="relative mt-6 flex-1 space-y-2.5">
              {t.features.map((f) => (
                <li class="flex items-start gap-2.5 text-sm text-ink-soft">
                  <svg class="mt-0.5 shrink-0" style={`color: ${t.a};`} width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M20 6L9 17l-5-5" />
                  </svg>
                  {f}
                </li>
              ))}
            </ul>
            <a
              href="/contact"
              class={`relative mt-8 rounded-full px-6 py-3 text-center text-sm font-semibold transition-transform duration-150 ease-(--ease-press) hover:scale-[1.02] active:scale-[0.98] ${
                t.featured
                  ? 'bg-violet text-white shadow-(--shadow-cta)'
                  : 'border border-white/15 bg-white/[0.04] text-ink'
              }`}
            >
              {t.cta}
            </a>
          </article>
        ))
      }
    </div>

    <div class="scrub scrub-fade mx-auto mt-14 max-w-2xl rounded-2xl bg-purple-ghost p-7 text-center">
      <h2 class="font-semibold text-ink">How payment works</h2>
      <p class="mt-2 text-sm leading-relaxed text-ink-muted">
        Website projects are quoted up front — typically a deposit to begin and the balance at
        launch, invoiced securely through Stripe. No surprises, no hidden fees.
      </p>
    </div>
  </section>
</Base>
