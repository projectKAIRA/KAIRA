# --- Frontend (build-time, safe to expose) ---
# Turnstile SITE key (public). Default in code is Cloudflare's always-pass test key.
PUBLIC_TURNSTILE_SITE_KEY=

# --- Cloudflare Pages Function secrets (set in the Cloudflare dashboard, NOT committed) ---
# TURNSTILE_SECRET_KEY=   Turnstile secret key
# RESEND_API_KEY=         Resend API key
# LEAD_TO_EMAIL=          inbox that receives quote requests
# LEAD_FROM_EMAIL=        verified Resend sender, e.g. "KAIRA <quotes@yourdomain.com>"
