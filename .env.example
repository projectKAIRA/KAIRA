# ─── Microsoft Azure App Registration ────────────────────────────────────────
# Create an app in https://portal.azure.com → Entra ID → App Registrations
# Grant it: Mail.Read (Application permission) on Microsoft Graph
# Then grant admin consent.

AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret

# UPN or object-ID of the mailbox to monitor (e.g. orders@yourcompany.com)
GRAPH_MAILBOX_USER_ID=orders@yourcompany.com

# Inbox folder name (default: inbox)
GRAPH_INBOX_FOLDER=inbox

# How often to check for new emails, in seconds (default: 60)
POLL_INTERVAL_SECONDS=60

# ─── Anthropic / Claude ───────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# Model to use (default: claude-opus-4-6)
CLAUDE_MODEL=claude-opus-4-6

# ─── Notification Provider ────────────────────────────────────────────────────
# Set to "slack" or "teams"
NOTIFICATION_PROVIDER=slack

# ─── Slack ───────────────────────────────────────────────────────────────────
# Create an Incoming Webhook at https://api.slack.com/apps → Your App → Incoming Webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../...
SLACK_CHANNEL=#kaira-orders
SLACK_BOT_NAME=KAIRA

# ─── Microsoft Teams (swap in when ready) ────────────────────────────────────
# Create an Incoming Webhook connector in your Teams channel
# NOTIFICATION_PROVIDER=teams
# TEAMS_WEBHOOK_URL=https://outlook.office.com/webhook/...

# ─── App Server ───────────────────────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0
