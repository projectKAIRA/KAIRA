generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum NotificationProvider {
  SLACK
  TEAMS
}

enum OrderStatus {
  UNCLAIMED
  CLAIMED
}

// ─── Models ───────────────────────────────────────────────────────────────────

/// One customer of the KAIRA SaaS platform.
/// Holds all per-tenant credentials and configuration.
model Tenant {
  id        String   @id @default(uuid())
  name      String                         // Human-readable customer name
  isActive  Boolean  @default(true)

  // ── Email provider ─────────────────────────────────────────────────────────
  /// "microsoft" = Microsoft Graph API (Outlook / Exchange / M365)
  /// "imap"      = Generic IMAP (Gmail, Yahoo, any IMAP server)
  providerType      String  @default("microsoft")

  // ── Microsoft Graph (email inbox) ──────────────────────────────────────────
  azureClientId     String  @default("")
  azureClientSecret String  @default("")
  azureTenantId     String  @default("consumers")
  /// "app_only"    — ClientSecretCredential (work/school accounts, production).
  /// "device_code" — DeviceCodeCredential (personal @outlook.com, testing).
  /// "oauth"       — Delegated OAuth 2.0 via self-serve onboarding flow.
  azureAuthMode     String  @default("app_only")
  /// The UPN / email address of the mailbox to monitor.
  /// Used for /users/{userEmail}/ Graph API endpoints (Microsoft provider only).
  userEmail         String  @default("")
  inboxFolder       String  @default("inbox")
  pollIntervalSeconds Int   @default(30)

  // ── OAuth delegated tokens (azureAuthMode = "oauth") ──────────────────────
  azureRefreshToken   String?
  azureAccessToken    String?
  azureTokenExpiresAt DateTime?

  // ── IMAP (Gmail, Yahoo, any IMAP server) ───────────────────────────────────
  imapHost     String?
  imapPort     Int?
  imapUser     String?
  imapPassword String?
  imapSecure   Boolean @default(true)   // true = TLS (port 993), false = STARTTLS

  // ── Notification routing ───────────────────────────────────────────────────
  notificationProvider NotificationProvider @default(SLACK)

  // ── Slack ──────────────────────────────────────────────────────────────────
  slackBotToken         String?
  slackSigningSecret    String?
  slackWebhookRfq       String?
  slackWebhookInquiry   String?
  slackPoChannelId      String?
  /// Channel ID for posting "✅ Claimed" summaries (e.g. #kaira-claimed).
  slackClaimedChannelId String?
  /// Slack workspace / team ID — used to route /orders slash commands to the right tenant.
  slackTeamId           String?
  slackBotName          String  @default("KAIRA")

  // ── Microsoft Teams ────────────────────────────────────────────────────────
  teamsWebhookUrl    String?

  // ── Trial & billing plan ───────────────────────────────────────────────────
  /// "none" = no plan (manually provisioned), "trial" = self-serve trial,
  /// "starter" / "growth" / "enterprise" = paid tiers.
  planTier            String   @default("none")
  isTrialActive       Boolean  @default(false)
  trialStartDate      DateTime?
  trialEndDate        DateTime?
  /// Set to true when the tenant has consumed all their monthly trial documents.
  /// The scheduler skips processing for this tenant until they upgrade.
  trialLimitReached   Boolean  @default(false)
  /// Running count of documents processed in the current billing month.
  monthlyDocCount     Int      @default(0)
  /// The timestamp when monthlyDocCount was last reset to 0 (start of month).
  monthlyDocResetAt   DateTime?

  // ── Contact ────────────────────────────────────────────────────────────────
  /// The customer's own email address (from Stripe checkout / onboarding).
  /// Used for the "find my account" flow so customers can recover their dashboard link.
  contactEmail         String  @default("")

  // ── Stripe billing ────────────────────────────────────────────────────────
  stripeCustomerId     String?
  stripeSubscriptionId String?

  // ── Timestamps ─────────────────────────────────────────────────────────────
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ── Relations ──────────────────────────────────────────────────────────────
  orders     TrackedOrder[]
  deltaLinks DeltaLink[]
}

/// A purchase order detected and tracked by KAIRA.
/// Replaces the in-memory POTracker Map — persisted per tenant.
model TrackedOrder {
  id       String      @id @default(uuid())
  tenantId String

  emailId  String      // Microsoft Graph message ID
  status   OrderStatus @default(UNCLAIMED)

  // Serialised JSON blobs (PurchaseOrderData and EmailMessage types)
  purchaseOrderJson String
  emailJson         String

  // Original PDF
  pdfBase64 String
  pdfName   String

  // Claim metadata
  claimedBy     String?   // Slack user ID
  claimedByName String?
  claimedAt     DateTime?

  // Slack posting coordinates (needed to update the message on claim)
  slackMessageTs  String?
  slackChannelId  String?

  receivedAt String    // ISO timestamp from the email
  createdAt  DateTime  @default(now())

  // ── Relations ──────────────────────────────────────────────────────────────
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, status])
}

/// Blocked signup attempt — logged whenever a duplicate company name or email
/// is detected during onboarding so abuse patterns are visible in the admin panel.
model SignupBlock {
  id              String   @id @default(uuid())
  /// The email address used in the blocked attempt.
  email           String   @default("")
  /// The company name used in the blocked attempt.
  companyName     String
  /// Why the attempt was blocked: "name_match" | "email_match"
  reason          String
  /// ID of the existing tenant that triggered the block (if still present).
  matchedTenantId   String?
  /// Name of the existing tenant that triggered the block.
  matchedTenantName String?
  createdAt       DateTime @default(now())

  @@index([email])
  @@index([companyName])
}

/// Persists the Microsoft Graph API delta query bookmark per tenant.
/// Replaces the in-memory deltaLink cache in GraphService.
model DeltaLink {
  id         String   @id @default(uuid())
  tenantId   String
  folderName String
  deltaLink  String
  updatedAt  DateTime @updatedAt

  // ── Relations ──────────────────────────────────────────────────────────────
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, folderName])
}
