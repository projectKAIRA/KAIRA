---
import Base from '../layouts/Base.astro';

// Fictional concept projects — clearly labeled. None represent real clients.
const projects = [
  {
    name: 'Harbor & Vine',
    type: 'Restaurant',
    body: 'A warm, photo-forward site for a coastal bistro concept — online menu, reservations, and a mobile experience built for hungry customers searching on the go.',
    tags: ['Web Design', 'Local SEO', 'Mobile-First'],
    mock: 'restaurant',
    accent: '#ff9500',
  },
  {
    name: 'Summit Physical Therapy',
    type: 'Health & Wellness',
    body: 'A clean, trustworthy presence for a PT clinic concept — service pages structured for local search, easy appointment requests, and accessible design throughout.',
    tags: ['Web Design', 'SEO Structure', 'Accessibility'],
    mock: 'clinic',
    accent: '#0071e3',
  },
  {
    name: 'Brightside Cleaning Co.',
    type: 'Home Services',
    body: 'A conversion-focused site for a cleaning service concept — instant quote form above the fold, service-area pages, and trust signals that win the booking.',
    tags: ['Web Design', 'Lead Generation', 'Speed'],
    mock: 'cleaning',
    accent: '#34c759',
  },
  {
    name: 'Oak & Iron Barbershop',
    type: 'Personal Care',
    body: 'A bold, modern look for a barbershop concept — online booking integration, service menu, and a gallery layout that shows off the craft.',
    tags: ['Web Design', 'Branding', 'Booking'],
    mock: 'barber',
    accent: '#ff375f',
  },
];
---

<Base
  title="Our Work — Concept Projects | KAIRA"
  description="Explore KAIRA's design work: polished concept projects showing how we approach websites for restaurants, clinics, home services, and more."
>
  <section class="mesh-bg">
    <div class="mx-auto max-w-6xl px-5 pb-16 pt-16 text-center md:pt-24">
      <p class="reveal hud-label mb-4">PORTFOLIO · 4 CONCEPTS</p>
      <h1 class="reveal-words text-4xl font-bold tracking-tight text-ink md:text-6xl">
        Work that <span class="grad-text">works the room.</span>
      </h1>
      <p class="reveal reveal-delay-1 mx-auto mt-4 max-w-xl text-lg text-ink-soft">
        Concept projects that show how we think about design, speed, and getting local businesses
        found.
      </p>
      <p class="reveal reveal-delay-2 mx-auto mt-4 max-w-xl text-sm text-ink-muted">
        The projects below are fictional concept work created to demonstrate our approach — they do
        not represent real client engagements.
      </p>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-5 py-16 md:py-20">
    <div class="grid gap-8 md:grid-cols-2">
      {
        projects.map((p, i) => (
          <article class={`reveal reveal-delay-${i % 2} glass overflow-hidden rounded-2xl transition-transform duration-300 ease-(--ease-enter) hover:-translate-y-1.5`}>
            <!-- Mini site mockup — light panel tinted for each concept -->
            <div class={`pf-panel pf-panel--${p.mock} relative p-6 sm:p-8`} aria-hidden="true">
              <span class="absolute right-4 top-4 z-[1] rounded-full border border-black/10 bg-white/85 px-3 py-1 text-[11px] font-semibold tracking-wide text-ink backdrop-blur">
                CONCEPT PROJECT
              </span>

              <div
                class="animate-float relative mx-auto max-w-sm overflow-hidden rounded-xl border border-black/[0.06] bg-white shadow-[0_18px_36px_-14px_rgba(15,23,42,0.20),0_6px_16px_-8px_rgba(15,23,42,0.14)]"
                style={`animation-delay: ${i * -1.6}s;`}
              >
                <!-- browser chrome -->
                <div class="flex items-center gap-1.5 border-b border-black/[0.05] bg-[#f5f5f7] px-3 py-2">
                  <span class="h-2 w-2 rounded-full bg-[#ff5f57]" />
                  <span class="h-2 w-2 rounded-full bg-[#febc2e]" />
                  <span class="h-2 w-2 rounded-full bg-[#28c840]" />
                  <span class="ml-2 h-3.5 flex-1 rounded-full border border-black/[0.06] bg-white px-2 text-[7px] leading-[14px] text-ink-muted font-mono">
                    {p.name.toLowerCase().replace(/[^a-z]/g, '')}.com
                  </span>
                </div>

                <div class="p-4">
                  {p.mock === 'restaurant' && (
                    <div>
                      <div class="mb-3 h-16 rounded-md" style={`background: linear-gradient(160deg, ${p.accent}, #7c2d12 60%, #451a03); box-shadow: inset 0 0 0 1px rgba(255,255,255,0.06);`}></div>
                      <p class="text-[8px] tracking-[0.2em] uppercase font-bold" style={`color:${p.accent}`}>Waterfront dining</p>
                      <p class="mt-1 text-[13px] font-bold leading-tight text-ink" style="font-family: Georgia, serif;">Coastal plates, <em style={`color:${p.accent}`}>golden-hour</em> views.</p>
                      <div class="mt-3 space-y-1">
                        <div class="flex items-baseline gap-1 text-[8px] text-ink-soft"><span>Seared dayboat scallops</span><span class="flex-1 border-b border-dotted border-black/15"></span><b class="text-ink font-bold">$24</b></div>
                        <div class="flex items-baseline gap-1 text-[8px] text-ink-soft"><span>Charred octopus &amp; tomato</span><span class="flex-1 border-b border-dotted border-black/15"></span><b class="text-ink font-bold">$19</b></div>
                        <div class="flex items-baseline gap-1 text-[8px] text-ink-soft"><span>Harbor burger, smoked aioli</span><span class="flex-1 border-b border-dotted border-black/15"></span><b class="text-ink font-bold">$16</b></div>
                      </div>
                      <div class="mt-3 inline-block rounded-full bg-ink px-3 py-1 text-[8px] font-bold text-white">Reserve a table</div>
                    </div>
                  )}
                  {p.mock === 'clinic' && (
                    <div>
                      <p class="text-[8px] tracking-[0.2em] uppercase font-bold" style={`color:${p.accent}`}>Physical therapy</p>
                      <p class="mt-1 text-[13px] font-bold leading-tight text-ink">Move better. <span style={`color:${p.accent}`}>Live better.</span></p>
                      <div class="mt-3 flex gap-1.5">
                        <span class="rounded-full border border-black/10 bg-white px-2 py-0.5 text-[7px] text-ink-soft">Sports rehab</span>
                        <span class="rounded-full border border-black/10 bg-white px-2 py-0.5 text-[7px] text-ink-soft">Post-op</span>
                        <span class="rounded-full border border-black/10 bg-white px-2 py-0.5 text-[7px] text-ink-soft">Chronic pain</span>
                      </div>
                      <div class="mt-3 rounded-lg border border-black/[0.06] bg-[#eff6ff] p-2">
                        <p class="text-[7px] text-ink-muted font-bold tracking-wider">NEXT AVAILABLE</p>
                        <p class="text-[10px] font-semibold text-ink">Tomorrow, 9:40 AM — Dr. Reyes</p>
                      </div>
                      <div class="mt-2.5 flex gap-1">
                        <span class="rounded px-2 py-0.5 text-[7px] font-semibold border" style={`color:${p.accent}; border-color:${p.accent}30`}>Sat 8:00</span>
                        <span class="rounded px-2 py-0.5 text-[7px] font-semibold text-white" style={`background:${p.accent}`}>Mon 9:40</span>
                        <span class="rounded px-2 py-0.5 text-[7px] font-semibold border" style={`color:${p.accent}; border-color:${p.accent}30`}>Mon 2:15</span>
                      </div>
                    </div>
                  )}
                  {p.mock === 'cleaning' && (
                    <div>
                      <p class="text-[8px] tracking-[0.2em] uppercase font-bold" style={`color:${p.accent}`}>Home cleaning</p>
                      <p class="mt-1 text-[14px] font-bold leading-tight text-ink">A spotless home by <span style={`color:${p.accent}`}>Friday</span>.</p>
                      <div class="mt-3 space-y-1.5">
                        <div class="rounded-md border border-black/[0.08] bg-white px-2 py-1.5 text-[8px] text-ink-muted">Your ZIP code</div>
                        <div class="rounded-md border border-black/[0.08] bg-white px-2 py-1.5 text-[8px] text-ink-muted">Home size — 3 bed / 2 bath</div>
                      </div>
                      <div class="mt-2.5 inline-block rounded-full px-3 py-1 text-[9px] font-bold text-white" style={`background:${p.accent}; box-shadow: 0 6px 14px -4px ${p.accent}55;`}>Get an instant quote</div>
                      <p class="mt-2 text-[7px] text-ink-muted" style={`color:${p.accent}`}>★★★★★ <span class="text-ink-muted">4.9 — 210+ local homes cleaned</span></p>
                    </div>
                  )}
                  {p.mock === 'barber' && (
                    <div>
                      <p class="text-[8px] tracking-[0.2em] uppercase font-bold" style={`color:${p.accent}`}>Est. 2026</p>
                      <p class="mt-1 text-[14px] font-bold leading-tight text-ink" style="font-family: Georgia, serif;">Classic cuts. <em style={`color:${p.accent}`}>Modern craft.</em></p>
                      <div class="mt-3 space-y-1 rounded-md border border-black/[0.06] bg-[#fafafa] p-2">
                        <div class="flex justify-between text-[8px] text-ink-soft"><span>Skin fade + hot towel</span><b class="text-ink font-bold">$38</b></div>
                        <div class="flex justify-between text-[8px] text-ink-soft"><span>Beard sculpt &amp; line-up</span><b class="text-ink font-bold">$22</b></div>
                        <div class="flex justify-between text-[8px] font-bold" style={`color:${p.accent}`}><span>The full works</span><span>$55</span></div>
                      </div>
                      <div class="mt-3 block rounded-md px-3 py-1.5 text-center text-[9px] font-bold text-white" style={`background:${p.accent}; box-shadow: 0 6px 14px -4px ${p.accent}55;`}>Book a chair →</div>
                    </div>
                  )}
                </div>
              </div>
            </div>

            <div class="p-7">
              <p class="text-xs font-semibold tracking-widest text-purple uppercase">{p.type}</p>
              <h2 class="mt-1.5 text-xl font-bold text-ink">{p.name}</h2>
              <p class="mt-3 text-sm leading-relaxed text-ink-muted">{p.body}</p>
              <ul class="mt-5 flex flex-wrap gap-2">
                {p.tags.map((t) => (
                  <li class="rounded-full bg-purple-ghost px-3 py-1 text-xs font-medium text-purple">{t}</li>
                ))}
              </ul>
            </div>
          </article>
        ))
      }
    </div>

    <div class="reveal mt-16 text-center">
      <h2 class="reveal-words text-2xl font-bold text-ink md:text-3xl">
        Want your business to be <span class="grad-text">our next project?</span>
      </h2>
      <a
        href="/contact"
        class="mt-6 inline-block rounded-full bg-violet px-8 py-3 text-base font-semibold text-white shadow-(--shadow-cta) transition-transform duration-150 ease-(--ease-press) hover:scale-[1.03] active:scale-[0.98]"
      >
        Start Your Project
      </a>
    </div>
  </section>
</Base>

<style>
  /* Slow light sweep across each mockup screen — sells "live product" */
  .sheen {
    background: linear-gradient(
      115deg,
      transparent 42%,
      rgba(255, 255, 255, 0.05) 48%,
      rgba(196, 181, 253, 0.09) 51%,
      transparent 58%
    );
    background-size: 260% 260%;
    animation: sheen 8s ease-in-out infinite;
  }
  @keyframes sheen {
    0% { background-position: 130% 0; }
    55%, 100% { background-position: -60% 0; }
  }
  @media (prefers-reduced-motion: reduce) {
    .sheen { animation: none; background: none; }
  }

  /* Per-concept light-panel backgrounds (replace old .dark-panel) */
  .pf-panel {
    border-radius: 24px;
    border: 1px solid rgba(0, 0, 0, 0.05);
    box-shadow:
      0 20px 40px -20px rgba(15, 23, 42, 0.12),
      inset 0 0 0 1px rgba(255, 255, 255, 0.6);
    overflow: hidden;
  }
  .pf-panel--restaurant {
    background:
      radial-gradient(60% 50% at 20% 15%, rgba(255, 149, 0, 0.14), transparent 65%),
      radial-gradient(60% 50% at 90% 90%, rgba(194, 65, 12, 0.10), transparent 65%),
      linear-gradient(160deg, #fff7ed 0%, #fffbf5 100%);
  }
  .pf-panel--clinic {
    background:
      radial-gradient(60% 50% at 20% 15%, rgba(0, 113, 227, 0.14), transparent 65%),
      radial-gradient(60% 50% at 90% 90%, rgba(90, 200, 250, 0.14), transparent 65%),
      linear-gradient(160deg, #eff6ff 0%, #f5faff 100%);
  }
  .pf-panel--cleaning {
    background:
      radial-gradient(60% 50% at 20% 15%, rgba(52, 199, 89, 0.16), transparent 65%),
      radial-gradient(60% 50% at 90% 90%, rgba(90, 200, 250, 0.10), transparent 65%),
      linear-gradient(160deg, #f0fdf4 0%, #f5fdf7 100%);
  }
  .pf-panel--barber {
    background:
      radial-gradient(60% 50% at 20% 15%, rgba(255, 55, 95, 0.14), transparent 65%),
      radial-gradient(60% 50% at 90% 90%, rgba(124, 58, 237, 0.10), transparent 65%),
      linear-gradient(160deg, #fff5f7 0%, #fff9fb 100%);
  }
</style>
