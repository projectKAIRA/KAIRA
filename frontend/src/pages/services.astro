---
import Base from '../layouts/Base.astro';

const services = [
  {
    kicker: 'DESIGN.CORE',
    title: 'Web Design & Development',
    tagline: 'A website you\u2019re proud to send customers to.',
    a: '#0071e3',
    b: '#5ac8fa',
    points: [
      'Custom design tailored to your brand — no cookie-cutter templates',
      'Mobile-first and responsive on every screen size',
      'Fast load times that keep visitors from bouncing',
      'Clear calls-to-action that turn visitors into inquiries',
      'Contact forms, maps, menus, galleries — whatever your business needs',
    ],
    stats: [
      { n: '<1s', l: 'FIRST PAINT' },
      { n: '95+', l: 'LIGHTHOUSE' },
      { n: '100%', l: 'RESPONSIVE' },
    ],
  },
  {
    kicker: 'SEARCH.SYS',
    title: 'SEO Fundamentals',
    tagline: 'Built to be found by the customers searching for you.',
    a: '#7c3aed',
    b: '#a78bfa',
    points: [
      'Technical SEO: clean structure, fast pages, proper metadata',
      'Local search setup so nearby customers find you first',
      'Google Business Profile guidance',
      'Keyword-aware page copy and headings',
      'Analytics set up so you can see what’s working',
    ],
    stats: [
      { n: '98/100', l: 'SEO SCORE' },
      { n: 'LOCAL', l: 'SEARCH FIRST' },
      { n: 'DAY 1', l: 'BUILT IN' },
    ],
  },
  {
    kicker: 'CARE.LOOP',
    title: 'Ongoing Maintenance',
    tagline: 'Your site stays secure, fresh, and up to date \u2014 hands-off.',
    a: '#ff375f',
    b: '#ff9500',
    points: [
      'Software updates, security monitoring, and backups',
      'Content updates — new hours, menus, photos, promotions',
      'Uptime monitoring and fast fixes if anything breaks',
      'Monthly summary of your site’s health and traffic',
      'Priority support when you need a change made',
    ],
    stats: [
      { n: '24/7', l: 'MONITORING' },
      { n: '99.9%', l: 'UPTIME' },
      { n: 'DAILY', l: 'BACKUPS' },
    ],
  },
];
---

<Base
  title="Services — Web Design, SEO & Maintenance | KAIRA"
  description="Professional web design, SEO fundamentals, and ongoing website maintenance for local businesses. Websites starting at $1,000."
>
  <section class="mesh-bg">
    <div class="mx-auto max-w-6xl px-5 pb-16 pt-16 text-center md:pt-24">
      <p class="reveal hud-label mb-4">SERVICES · 3 MODULES</p>
      <h1 class="reveal-words text-4xl font-bold tracking-tight text-ink md:text-6xl">
        Everything you need. <span class="grad-text">Nothing you don’t.</span>
      </h1>
      <p class="reveal reveal-delay-1 mx-auto mt-5 max-w-xl text-lg text-ink-soft">
        Everything a local business needs to look professional online and get found.
      </p>
    </div>
  </section>

  <section class="mx-auto max-w-6xl space-y-24 px-5 py-16 md:space-y-36 md:py-24">
    {
      services.map((s, i) => (
        <article class="scrub grid items-center gap-10 md:grid-cols-2 md:gap-14">
          <div class={`scrub-fade ${i % 2 === 1 ? 'md:order-2' : ''}`}>
            <p class="hud-label">{s.kicker}</p>
            <h2
              class="mt-3 text-3xl font-bold tracking-tight md:text-4xl"
              style={`background: linear-gradient(115deg, ${s.a}, ${s.b}); -webkit-background-clip: text; background-clip: text; color: transparent;`}
            >
              {s.title}
            </h2>
            <p class="mt-2 text-lg font-medium text-ink">{s.tagline}</p>
            <ul class="mt-7 space-y-3.5">
              {s.points.map((p) => (
                <li class="flex items-start gap-3 text-sm leading-relaxed text-ink-soft">
                  <svg class="mt-0.5 shrink-0" style={`color: ${s.a};`} width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M20 6L9 17l-5-5" />
                  </svg>
                  {p}
                </li>
              ))}
            </ul>
          </div>

          <div class={`scrub-fade ${i % 2 === 1 ? 'md:order-1' : ''}`}>
            {i === 0 ? (
              <div class="svc-stack" aria-hidden="true">
                <!-- Back mockup -->
                <div class="svc-mock svc-mock--3">
                  <div class="svc-bar"><span class="d d-r"></span><span class="d d-y"></span><span class="d d-g"></span></div>
                  <div class="svc-body" style="background: linear-gradient(160deg,#fff7ed,#fef3c7);">
                    <div class="svc-block" style="background:#c2410c"></div>
                    <div class="svc-line" style="width:70%"></div>
                    <div class="svc-line" style="width:50%"></div>
                  </div>
                </div>
                <!-- Middle mockup -->
                <div class="svc-mock svc-mock--2">
                  <div class="svc-bar"><span class="d d-r"></span><span class="d d-y"></span><span class="d d-g"></span></div>
                  <div class="svc-body" style="background: linear-gradient(160deg,#f5f3ff,#eff6ff);">
                    <div class="svc-block" style="background: linear-gradient(120deg,#0071e3,#7c3aed);"></div>
                    <div class="svc-line" style="width:80%"></div>
                    <div class="svc-line" style="width:55%"></div>
                    <div class="svc-pill" style="background:#1d1d1f;color:#fff">Book now</div>
                  </div>
                </div>
                <!-- Front mockup (the "hero" one) -->
                <div class="svc-mock svc-mock--1">
                  <div class="svc-bar"><span class="d d-r"></span><span class="d d-y"></span><span class="d d-g"></span><span class="svc-url">yourbusiness.com</span></div>
                  <div class="svc-body" style="background:#ffffff">
                    <div class="svc-nav">
                      <span class="svc-logo"></span>
                      <span class="svc-links"><i></i><i></i><i></i></span>
                    </div>
                    <div class="svc-hero-block"></div>
                    <p class="svc-title">Beautifully simple.</p>
                    <p class="svc-sub">A site your customers will actually enjoy using.</p>
                    <div class="svc-cta-row">
                      <span class="svc-pill" style="background:#1d1d1f;color:#fff">Get in touch</span>
                      <span class="svc-pill" style="border:1px solid rgba(0,0,0,0.1);color:#1d1d1f">Learn more</span>
                    </div>
                    <div class="svc-grid">
                      <div style="background:linear-gradient(135deg,#0071e3,#5ac8fa)"></div>
                      <div style="background:linear-gradient(135deg,#7c3aed,#a78bfa)"></div>
                      <div style="background:linear-gradient(135deg,#ff375f,#ff9500)"></div>
                    </div>
                  </div>
                </div>
                <!-- Floating badges -->
                <div class="svc-badge svc-badge-a">
                  <div class="svc-badge-score">98</div>
                  <div><b>Lighthouse</b><span>Performance</span></div>
                </div>
                <div class="svc-badge svc-badge-b">
                  <b>0.4s</b><span>First paint</span>
                </div>
              </div>
            ) : (
              <div
                class="grad-border relative overflow-hidden rounded-3xl p-10"
                style={`--tile-a: ${s.a}; --tile-b: ${s.b};`}
              >
                <div
                  aria-hidden="true"
                  class="pointer-events-none absolute inset-0 opacity-65"
                  style={`background: radial-gradient(110% 90% at 50% 115%, color-mix(in srgb, ${s.a} 28%, transparent) 0%, color-mix(in srgb, ${s.b} 11%, transparent) 50%, transparent 78%);`}
                />
                <div class="relative grid gap-6">
                  {s.stats.map((st) => (
                    <div class="flex items-baseline justify-between border-b border-black/[0.06] pb-4 last:border-0 last:pb-0">
                      <span
                        class="stat-num text-3xl font-bold md:text-4xl"
                        style={`background: linear-gradient(115deg, ${s.a}, ${s.b}); -webkit-background-clip: text; background-clip: text; color: transparent;`}
                      >
                        {st.n}
                      </span>
                      <span class="hud-label">{st.l}</span>
                    </div>
                  ))}
                </div>
              </div>
            )}
          </div>
        </article>
      ))
    }
  </section>

  <section class="mx-auto max-w-3xl px-5 pb-20 text-center md:pb-28">
    <div class="reveal glass rounded-3xl p-10">
      <h2 class="reveal-words text-2xl font-bold text-ink md:text-3xl">
        Not sure <span class="grad-text">what you need?</span>
      </h2>
      <p class="mt-3 text-ink-muted">
        Tell us about your business and we’ll recommend the right starting point — no jargon, no
        pressure.
      </p>
      <a
        href="/contact"
        class="mt-6 inline-block rounded-full bg-violet px-8 py-3 text-base font-semibold text-white shadow-(--shadow-cta) transition-transform duration-150 ease-(--ease-press) hover:scale-[1.03] active:scale-[0.98]"
      >
        Get a Free Quote
      </a>
    </div>
  </section>
</Base>

<style>
  /* Light, layered browser-mockup stack for the Web Design service section */
  .svc-stack {
    position: relative;
    aspect-ratio: 4 / 3;
    width: 100%;
    perspective: 1400px;
  }
  .svc-mock {
    position: absolute;
    background: #fff;
    border-radius: 14px;
    box-shadow:
      0 30px 60px -30px rgba(15, 23, 42, 0.22),
      0 14px 28px -16px rgba(15, 23, 42, 0.14),
      0 0 0 1px rgba(0, 0, 0, 0.05);
    overflow: hidden;
    transform-origin: center center;
  }
  .svc-bar { display: flex; align-items: center; gap: 5px; padding: 8px 10px; background: #f5f5f7; border-bottom: 1px solid rgba(0,0,0,0.05); }
  .svc-bar .d { width: 7px; height: 7px; border-radius: 50%; }
  .svc-bar .d-r { background: #ff5f57; } .svc-bar .d-y { background: #febc2e; } .svc-bar .d-g { background: #28c840; }
  .svc-url { margin-left: 8px; font-size: 9px; padding: 2px 8px; border-radius: 999px; background: #fff; border: 1px solid rgba(0,0,0,0.06); color: #6e6e73; font-family: "SF Mono", ui-monospace, Menlo, monospace; }
  .svc-body { padding: 12px; height: calc(100% - 26px); }
  .svc-block { width: 100%; height: 40%; border-radius: 8px; }
  .svc-line { height: 6px; background: #e5e5ea; border-radius: 3px; margin-top: 8px; }
  .svc-pill { display: inline-block; padding: 5px 12px; border-radius: 999px; font-size: 10px; font-weight: 600; margin-top: 8px; }

  .svc-mock--1 { inset: 8% 4% 8% 12%; z-index: 3; transform: rotateY(-8deg) rotateX(4deg); }
  .svc-mock--2 { inset: 2% 14% 26% 2%; z-index: 2; transform: rotateY(-14deg) rotateX(6deg) translate(-4%, -6%); opacity: 0.85; }
  .svc-mock--3 { inset: 20% 2% 4% 24%; z-index: 1; transform: rotateY(-4deg) rotateX(2deg) translate(6%, 8%); opacity: 0.75; }

  .svc-mock--1 .svc-body { display: flex; flex-direction: column; gap: 6px; padding: 12px 14px 14px; }
  .svc-nav { display: flex; justify-content: space-between; align-items: center; padding-bottom: 4px; }
  .svc-logo { display: block; width: 42px; height: 8px; border-radius: 999px; background: linear-gradient(90deg, #0071e3, #7c3aed); }
  .svc-links { display: flex; gap: 6px; }
  .svc-links i { display: block; width: 22px; height: 4px; border-radius: 999px; background: #e5e5ea; }
  .svc-hero-block {
    height: 68px; border-radius: 10px;
    background: radial-gradient(60% 55% at 55% 45%, rgba(124, 58, 237, 0.35), transparent 65%),
                linear-gradient(135deg, #0071e3, #7c3aed 55%, #ff375f);
    box-shadow: inset 0 0 0 1px rgba(255,255,255,0.08);
  }
  .svc-title { font-size: 15px; font-weight: 700; letter-spacing: -0.01em; color: #1d1d1f; margin-top: 2px; }
  .svc-sub   { font-size: 10px; color: #6e6e73; margin-top: 2px; line-height: 1.4; }
  .svc-cta-row { display: flex; gap: 6px; }
  .svc-grid  { display: grid; grid-template-columns: repeat(3, 1fr); gap: 6px; margin-top: 6px; }
  .svc-grid div { height: 22px; border-radius: 6px; box-shadow: 0 4px 10px -4px rgba(15,23,42,0.2); }

  .svc-badge {
    position: absolute; z-index: 4;
    background: rgba(255,255,255,0.9);
    -webkit-backdrop-filter: blur(20px) saturate(180%); backdrop-filter: blur(20px) saturate(180%);
    border: 1px solid rgba(0,0,0,0.06);
    border-radius: 14px; padding: 8px 10px;
    display: flex; align-items: center; gap: 8px;
    box-shadow: 0 18px 36px -18px rgba(15,23,42,0.2);
    animation: svc-float 6s ease-in-out infinite;
  }
  .svc-badge b { display: block; font-size: 13px; font-weight: 700; color: #1d1d1f; letter-spacing: -0.02em; }
  .svc-badge span { display: block; font-size: 9px; color: #6e6e73; }
  .svc-badge-a { top: 4%; left: -4%; }
  .svc-badge-a .svc-badge-score {
    width: 32px; height: 32px; border-radius: 10px; display: grid; place-items: center;
    background: linear-gradient(135deg, #34c759, #a7f3d0);
    color: #fff; font-weight: 700; font-size: 13px;
    box-shadow: 0 6px 12px -4px rgba(52,199,89,0.5);
  }
  .svc-badge-b { bottom: 10%; right: -3%; animation-delay: -2.5s; }
  @keyframes svc-float { 0%, 100% { transform: translateY(0) rotate(-0.4deg); } 50% { transform: translateY(-8px) rotate(0.4deg); } }

  @media (max-width: 900px) {
    .svc-mock--1 { inset: 8% 6% 8% 8%; }
    .svc-mock--2, .svc-mock--3 { display: none; }
    .svc-badge-a { left: 0; }
    .svc-badge-b { right: 0; }
  }
</style>

