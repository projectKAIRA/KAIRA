---
import Butterfly from './Butterfly.astro';

const links = [
  { href: '/services', label: 'Services' },
  { href: '/portfolio', label: 'Work' },
  { href: '/pricing', label: 'Pricing' },
  { href: '/about', label: 'About' },
];
const current = Astro.url.pathname;
---

<header
  class="sticky top-0 z-40 border-b border-black/[0.06] bg-white/70 backdrop-blur-xl backdrop-saturate-150"
>
  <nav aria-label="Main" class="mx-auto flex max-w-6xl items-center justify-between px-5 py-3.5">
    <a href="/" class="flex items-center gap-2.5" data-testid="nav-logo">
      <Butterfly class="h-9 w-9" />
      <span class="text-lg font-bold tracking-[0.2em] text-ink uppercase">Kaira</span>
      <span class="pill ml-2 hidden sm:inline-flex"><span class="status-dot"></span> Accepting projects</span>
    </a>

    <ul class="hidden items-center gap-8 md:flex">
      {
        links.map((l) => (
          <li>
            <a
              href={l.href}
              aria-current={current === l.href || current === l.href + '/' ? 'page' : undefined}
              class:list={[
                'nav-link text-sm font-medium transition-colors duration-150',
                current.startsWith(l.href) ? 'text-ink' : 'text-ink-soft hover:text-ink',
              ]}
              data-testid={`nav-link-${l.label.toLowerCase()}`}
            >
              {l.label}
            </a>
          </li>
        ))
      }
    </ul>

    <div class="flex items-center gap-3">
      <a
        href="/contact"
        class="hidden rounded-full bg-ink px-5 py-2 text-sm font-semibold text-white transition-all duration-150 ease-(--ease-press) hover:scale-[1.03] hover:shadow-lg active:scale-[0.98] md:inline-block"
        style="background-color: #1d1d1f;"
        data-testid="nav-cta"
      >
        Get a Quote
      </a>

      <button
        id="nav-toggle"
        type="button"
        class="flex h-10 w-10 items-center justify-center rounded-lg text-ink md:hidden"
        aria-expanded="false"
        aria-controls="mobile-menu"
        aria-label="Open menu"
        data-testid="nav-toggle"
      >
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <path class="menu-open" d="M4 7h16M4 12h16M4 17h16" />
          <path class="menu-close hidden" d="M6 6l12 12M18 6L6 18" />
        </svg>
      </button>
    </div>
  </nav>

  <div id="mobile-menu" class="hidden border-t border-black/[0.06] bg-white/95 px-5 pb-5 pt-3 backdrop-blur-xl md:hidden">
    <ul class="flex flex-col gap-1">
      {
        links.map((l) => (
          <li>
            <a href={l.href} class="block rounded-lg px-3 py-2.5 text-base font-medium text-ink-soft hover:bg-black/[0.04] hover:text-ink">
              {l.label}
            </a>
          </li>
        ))
      }
      <li class="mt-2">
        <a href="/contact" class="block rounded-full px-5 py-2.5 text-center text-base font-semibold text-white" style="background-color: #1d1d1f;">
          Get a Quote
        </a>
      </li>
    </ul>
  </div>
</header>

<style>
  .nav-link {
    position: relative;
  }
  .nav-link::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: -5px;
    height: 1.5px;
    border-radius: 1px;
    background: linear-gradient(90deg, #0071e3, #7c3aed, #ff375f);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.25s var(--ease-enter);
  }
  .nav-link:hover::after,
  .nav-link[aria-current="page"]::after {
    transform: scaleX(1);
  }
  @media (prefers-reduced-motion: reduce) {
    .nav-link::after { transition: none; }
  }
</style>

<script>
  function initNav() {
    const btn = document.getElementById('nav-toggle');
    const menu = document.getElementById('mobile-menu');
    if (!btn || btn.dataset.init) return;
    btn.dataset.init = '1';
    btn.addEventListener('click', () => {
      const open = menu?.classList.toggle('hidden') === false;
      btn.setAttribute('aria-expanded', String(open));
      btn.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
      btn.querySelector('.menu-open')?.classList.toggle('hidden', open);
      btn.querySelector('.menu-close')?.classList.toggle('hidden', !open);
    });
  }
  initNav();
  document.addEventListener('astro:page-load', initNav);
</script>
