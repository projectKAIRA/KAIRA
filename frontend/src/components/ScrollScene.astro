---
// Pinned scroll scene: wrapper is `mult`× viewport tall; the stage sticks for
// the ride while the Base scroll engine drives --p (0→1) on the wrapper.
// Children read var(--p) for scrubbed opacity/transform choreography.
interface Props {
  mult?: number; // wrapper height in viewport multiples
  class?: string;
}
const { mult = 3, class: className = '' } = Astro.props;
---

<div class={`scroll-scene scrub ${className}`} style={`height: ${mult * 100}dvh;`}>
  <div class="scroll-scene__stage">
    <slot />
  </div>
</div>
