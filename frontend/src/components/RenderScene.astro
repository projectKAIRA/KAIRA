---
// Coded 3D "live render": a holographic website floating in space — translucent
// browser panel, spectrum-gradient hero block, glowing UI cards bobbing in front,
// perspective grid floor, starfield. Camera sways slowly and follows the pointer.
// Lazy Three.js init per canvas; pauses offscreen; static frame on reduced motion.
interface Props {
  label?: string;
  class?: string;
  ratio?: string; // css aspect-ratio, default 16/9
}
const { label, class: className = '', ratio = '16 / 9' } = Astro.props;
---

<div
  class={`dark-panel relative overflow-hidden ${className}`}
  style={`aspect-ratio: ${ratio};`}
>
  <canvas data-render-scene class="absolute inset-0 h-full w-full"></canvas>
  {label && (
    <span class="hud-label absolute left-4 top-4 z-[1] rounded-full border border-white/10 bg-black/40 px-3 py-1 backdrop-blur">
      {label}
    </span>
  )}
  <span class="hud-label absolute bottom-4 right-4 z-[1] text-white/35">WEBGL <span class="text-white/15">//</span> REALTIME</span>
</div>

<script>
  async function initRenderScenes() {
    const canvases = document.querySelectorAll<HTMLCanvasElement>('canvas[data-render-scene]:not([data-init])');
    if (!canvases.length) return;
    canvases.forEach((c) => (c.dataset.init = '1'));

    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    let THREE: any;
    try {
      THREE = await import('three');
    } catch {
      return; // glass panel still shows; scene is decorative
    }

    // shared pointer parallax
    let mx = 0, my = 0;
    window.addEventListener('pointermove', (e) => {
      mx = (e.clientX / window.innerWidth - 0.5) * 2;
      my = (e.clientY / window.innerHeight - 0.5) * 2;
    }, { passive: true });

    const TEAL = '#2dd4bf', BLUE = '#38bdf8', VIOLET = '#8b5cf6', VIOLET_LIGHT = '#c4b5fd', MAGENTA = '#ff2d78';

    function spectrumTexture() {
      const cv = document.createElement('canvas');
      cv.width = 256; cv.height = 64;
      const ctx = cv.getContext('2d')!;
      const g = ctx.createLinearGradient(0, 0, 256, 64);
      g.addColorStop(0, TEAL); g.addColorStop(0.35, BLUE); g.addColorStop(0.7, VIOLET); g.addColorStop(1, MAGENTA);
      ctx.fillStyle = g;
      ctx.fillRect(0, 0, 256, 64);
      return new THREE.CanvasTexture(cv);
    }

    canvases.forEach((canvas) => {
      let renderer: any;
      try {
        renderer = new THREE.WebGLRenderer({ canvas, alpha: true, antialias: true });
      } catch {
        return;
      }
      renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));

      const scene = new THREE.Scene();
      const camera = new THREE.PerspectiveCamera(40, 1, 0.1, 50);
      camera.position.set(0, 0.15, 7.5);

      const addMat = (color: string, opacity: number) =>
        new THREE.MeshBasicMaterial({ color: new THREE.Color(color), transparent: true, opacity, blending: THREE.AdditiveBlending, depthWrite: false });

      // ---------- Holographic browser ----------
      const site = new THREE.Group();
      scene.add(site);

      // frame
      const frame = new THREE.Mesh(
        new THREE.PlaneGeometry(4.4, 2.9),
        new THREE.MeshBasicMaterial({ color: 0x0d0d15, transparent: true, opacity: 0.72 })
      );
      site.add(frame);
      const frameEdge = new THREE.LineSegments(
        new THREE.EdgesGeometry(new THREE.PlaneGeometry(4.4, 2.9)),
        new THREE.LineBasicMaterial({ color: new THREE.Color(VIOLET_LIGHT), transparent: true, opacity: 0.6, blending: THREE.AdditiveBlending })
      );
      frameEdge.position.z = 0.001;
      site.add(frameEdge);

      // header bar + traffic dots
      const header = new THREE.Mesh(new THREE.PlaneGeometry(4.4, 0.26), addMat('#ffffff', 0.05));
      header.position.set(0, 1.32, 0.002);
      site.add(header);
      [MAGENTA, BLUE, TEAL].forEach((c, i) => {
        const dot = new THREE.Mesh(new THREE.CircleGeometry(0.035, 16), addMat(c, 0.9));
        dot.position.set(-2.0 + i * 0.13, 1.32, 0.003);
        site.add(dot);
      });

      // spectrum hero block — texture scrolls slowly so the gradient shimmers
      const heroTex = spectrumTexture();
      heroTex.wrapS = THREE.RepeatWrapping;
      const hero = new THREE.Mesh(
        new THREE.PlaneGeometry(3.9, 0.85),
        new THREE.MeshBasicMaterial({ map: heroTex, transparent: true, opacity: 0.9 })
      );
      hero.position.set(0, 0.72, 0.004);
      site.add(hero);

      // text lines — pulse sequentially like content streaming in
      const lines: any[] = [];
      [[2.6, 0.15], [2.0, 0.02], [2.3, -0.11]].forEach(([w, y]) => {
        const line = new THREE.Mesh(new THREE.PlaneGeometry(w, 0.055), addMat('#ffffff', 0.16));
        line.position.set(-(3.9 - w) / 2 + 0.65, y, 0.004);
        lines.push(line);
        site.add(line);
      });

      // CTA pill
      const cta = new THREE.Mesh(new THREE.PlaneGeometry(0.72, 0.17), addMat(VIOLET, 0.85));
      cta.position.set(-1.55, -0.34, 0.005);
      site.add(cta);

      // floating UI cards (in front, each bobs on its own rhythm)
      const cards: any[] = [];
      [TEAL, BLUE, MAGENTA].forEach((c, i) => {
        const card = new THREE.Group();
        const body = new THREE.Mesh(
          new THREE.PlaneGeometry(1.14, 0.74),
          new THREE.MeshBasicMaterial({ color: 0x11111a, transparent: true, opacity: 0.88 })
        );
        const edge = new THREE.LineSegments(
          new THREE.EdgesGeometry(new THREE.PlaneGeometry(1.14, 0.74)),
          new THREE.LineBasicMaterial({ color: new THREE.Color(c), transparent: true, opacity: 0.85, blending: THREE.AdditiveBlending })
        );
        const bar = new THREE.Mesh(new THREE.PlaneGeometry(0.62, 0.05), addMat(c, 0.75));
        bar.position.set(-0.14, 0.18, 0.002);
        const txt = new THREE.Mesh(new THREE.PlaneGeometry(0.82, 0.04), addMat('#ffffff', 0.16));
        txt.position.set(-0.04, 0.02, 0.002);
        // mini stat bars — a tiny equalizer per card so the panels feel live
        const statBars: any[] = [];
        for (let s = 0; s < 4; s++) {
          const stat = new THREE.Mesh(new THREE.PlaneGeometry(0.08, 0.2), addMat(c, 0.55));
          stat.position.set(0.18 + s * 0.13, -0.18, 0.002);
          statBars.push(stat);
          card.add(stat);
        }
        card.userData.statBars = statBars;
        card.add(body, edge, bar, txt);
        card.position.set(-1.35 + i * 1.35, -0.92, 0.3);
        cards.push(card);
        site.add(card);
      });

      // ---------- Floating phone (responsive companion, back-left) ----------
      const phone = new THREE.Group();
      {
        const body = new THREE.Mesh(
          new THREE.PlaneGeometry(0.95, 1.9),
          new THREE.MeshBasicMaterial({ color: 0x0d0d15, transparent: true, opacity: 0.8 })
        );
        const edge = new THREE.LineSegments(
          new THREE.EdgesGeometry(new THREE.PlaneGeometry(0.95, 1.9)),
          new THREE.LineBasicMaterial({ color: new THREE.Color(TEAL), transparent: true, opacity: 0.7, blending: THREE.AdditiveBlending })
        );
        const phoneHero = new THREE.Mesh(
          new THREE.PlaneGeometry(0.79, 0.42),
          new THREE.MeshBasicMaterial({ map: heroTex, transparent: true, opacity: 0.85 })
        );
        phoneHero.position.set(0, 0.55, 0.002);
        phone.add(body, edge, phoneHero);
        [[0.6, 0.18], [0.5, 0.04], [0.55, -0.1], [0.42, -0.24]].forEach(([w, y]) => {
          const line = new THREE.Mesh(new THREE.PlaneGeometry(w, 0.045), addMat('#ffffff', 0.15));
          line.position.set(-(0.79 - w) / 2 + 0.1, y, 0.002);
          phone.add(line);
        });
        const phoneCta = new THREE.Mesh(new THREE.PlaneGeometry(0.4, 0.12), addMat(VIOLET, 0.8));
        phoneCta.position.set(0, -0.55, 0.002);
        phone.add(phoneCta);
        phone.position.set(-3.05, -0.25, -0.35);
        phone.rotation.y = 0.42;
        scene.add(phone);
      }

      // ---------- Agent cursor: a glowing dot "building" the page ----------
      function glowSprite(color: string, opacity: number) {
        const cv = document.createElement('canvas');
        cv.width = cv.height = 64;
        const ctx = cv.getContext('2d')!;
        const g = ctx.createRadialGradient(32, 32, 0, 32, 32, 32);
        g.addColorStop(0, color);
        g.addColorStop(1, 'rgba(0,0,0,0)');
        ctx.fillStyle = g;
        ctx.fillRect(0, 0, 64, 64);
        return new THREE.Sprite(
          new THREE.SpriteMaterial({ map: new THREE.CanvasTexture(cv), transparent: true, opacity, blending: THREE.AdditiveBlending, depthWrite: false })
        );
      }
      const cursor = glowSprite('rgba(196,235,255,0.95)', 0.9);
      cursor.scale.setScalar(0.16);
      site.add(cursor);
      // waypoints in panel-local space: hero → lines → CTA → each card
      const waypoints = [
        [0.9, 0.72, 0.02], [-1.2, 0.55, 0.02], [-0.6, 0.02, 0.02], [-1.55, -0.34, 0.02],
        [-1.35, -0.85, 0.33], [0.0, -0.95, 0.33], [1.35, -0.85, 0.33], [1.6, 0.9, 0.02],
      ];
      let wpIndex = 0, wpFrom = waypoints[0], wpTo = waypoints[1], wpT = 0;
      cursor.position.set(wpFrom[0], wpFrom[1], wpFrom[2]);

      // ---------- Drifting colored light orbs ----------
      const orbs: any[] = [];
      [['rgba(45,212,191,0.9)', -2.6, 1.2, -0.8], ['rgba(139,92,246,0.9)', 2.8, 1.5, -0.5],
       ['rgba(255,45,120,0.85)', 3.0, -1.3, 0.2], ['rgba(56,189,248,0.9)', -3.2, -1.5, 0.4]].forEach(([col, ox, oy, oz], i) => {
        const orb = glowSprite(col as string, 0.4);
        orb.scale.setScalar(0.5 + (i % 2) * 0.25);
        orb.position.set(ox as number, oy as number, oz as number);
        orb.userData.base = [ox, oy, oz];
        orbs.push(orb);
        scene.add(orb);
      });

      // ---------- Light streaks racing along the grid ----------
      const streaks: any[] = [];
      for (let i = 0; i < 3; i++) {
        const streak = new THREE.Mesh(
          new THREE.PlaneGeometry(0.05, 3.2),
          addMat(i === 1 ? VIOLET : '#00e5ff', 0.4)
        );
        streak.rotation.x = -Math.PI / 2;
        streak.position.set(-6 + i * 5.2, -2.08, -6);
        streak.userData.speed = 2.2 + i * 0.9;
        streaks.push(streak);
        scene.add(streak);
      }

      // ---------- Interactivity: hover glow + click payoffs ----------
      // The hologram is a toy: hovering an element makes it swell and glow,
      // clicking bursts particles / spins the phone / sweeps the gradient.
      const raycaster = new THREE.Raycaster();
      const pointerNdc = new THREE.Vector2(-10, -10);
      let hovered: any = null;

      const interactables: any[] = [];
      function tagInteractive(mesh: any, kind: string, payload: any = null) {
        mesh.userData.interactive = { kind, payload };
        interactables.push(mesh);
      }
      tagInteractive(hero, 'hero');
      tagInteractive(cta, 'cta');
      cards.forEach((card: any, i: number) => {
        const body = card.children.find((ch: any) => ch.geometry?.parameters?.width === 1.14 && ch.material?.opacity === 0.88) ?? card.children[0];
        tagInteractive(body, 'card', { card, color: [TEAL, BLUE, MAGENTA][i] });
      });
      tagInteractive(phone.children[0], 'phone');

      // particle pool for bursts
      const PARTICLES = 42;
      const particles: any[] = [];
      const particleTextures: Record<string, any> = {};
      function particleSprite(color: string) {
        if (!particleTextures[color]) {
          const cv = document.createElement('canvas');
          cv.width = cv.height = 32;
          const ctx = cv.getContext('2d')!;
          const g = ctx.createRadialGradient(16, 16, 0, 16, 16, 16);
          g.addColorStop(0, color);
          g.addColorStop(1, 'rgba(0,0,0,0)');
          ctx.fillStyle = g;
          ctx.fillRect(0, 0, 32, 32);
          particleTextures[color] = new THREE.CanvasTexture(cv);
        }
        return new THREE.Sprite(
          new THREE.SpriteMaterial({ map: particleTextures[color], transparent: true, opacity: 0, blending: THREE.AdditiveBlending, depthWrite: false })
        );
      }
      const SPECTRUM = ['rgba(45,212,191,1)', 'rgba(56,189,248,1)', 'rgba(139,92,246,1)', 'rgba(255,45,120,1)'];
      for (let i = 0; i < PARTICLES; i++) {
        const p = particleSprite(SPECTRUM[i % SPECTRUM.length]);
        p.scale.setScalar(0.09);
        p.userData.life = 0;
        p.userData.vel = new THREE.Vector3();
        particles.push(p);
        scene.add(p);
      }
      let nextParticle = 0;
      function burst(worldPos: any, count: number, spread: number) {
        for (let i = 0; i < count; i++) {
          const p = particles[nextParticle];
          nextParticle = (nextParticle + 1) % PARTICLES;
          p.position.copy(worldPos);
          p.userData.vel.set(
            (Math.random() - 0.5) * spread,
            Math.random() * spread * 0.9 + 0.3,
            (Math.random() - 0.5) * spread * 0.6
          );
          p.userData.life = 1;
          p.material.opacity = 0.95;
        }
      }

      let heroSweep = 0; // >0 = gradient fast-sweep timer
      let phoneSpin = 0; // target extra rotations

      function raycastHit() {
        raycaster.setFromCamera(pointerNdc, camera);
        const hits = raycaster.intersectObjects(interactables, false);
        return hits.length ? hits[0] : null;
      }

      canvas.addEventListener('pointermove', (e) => {
        const r = canvas.getBoundingClientRect();
        pointerNdc.set(((e.clientX - r.left) / r.width) * 2 - 1, -((e.clientY - r.top) / r.height) * 2 + 1);
        const hit = raycastHit();
        hovered = hit?.object ?? null;
        canvas.style.cursor = hovered ? 'pointer' : 'default';
      }, { passive: true });
      canvas.addEventListener('pointerleave', () => {
        hovered = null;
        pointerNdc.set(-10, -10);
        canvas.style.cursor = 'default';
      });

      canvas.addEventListener('click', () => {
        const hit = raycastHit();
        if (!hit) return;
        const { kind, payload } = hit.object.userData.interactive;
        if (kind === 'card') {
          payload.card.userData.pop = 1;
          payload.card.userData.frenzy = 1.4; // equalizer goes wild
          burst(hit.point, 14, 2.2);
        } else if (kind === 'cta') {
          burst(hit.point, 26, 3.2);
          heroSweep = 1.2;
        } else if (kind === 'hero') {
          heroSweep = 1.4;
          burst(hit.point, 10, 1.6);
        } else if (kind === 'phone') {
          phoneSpin += Math.PI * 2;
          burst(hit.point, 10, 1.8);
        }
      });

      // ---------- Environment ----------
      const grid = new THREE.GridHelper(26, 30, new THREE.Color('#00e5ff'), new THREE.Color('#00e5ff'));
      (grid.material as any).transparent = true;
      (grid.material as any).opacity = 0.09;
      grid.position.y = -2.1;
      scene.add(grid);

      const N = 260;
      const pos = new Float32Array(N * 3);
      for (let i = 0; i < N; i++) {
        const a = Math.sin(i * 12.9898) * 43758.5453;
        const b = Math.sin(i * 78.233) * 12543.2341;
        const c = Math.sin(i * 39.425) * 26431.5327;
        pos[i * 3] = ((a - Math.floor(a)) - 0.5) * 14;
        pos[i * 3 + 1] = ((b - Math.floor(b)) - 0.5) * 7;
        pos[i * 3 + 2] = ((c - Math.floor(c)) - 0.5) * 5 - 2;
      }
      const starGeo = new THREE.BufferGeometry();
      starGeo.setAttribute('position', new THREE.BufferAttribute(pos, 3));
      const stars = new THREE.Points(
        starGeo,
        new THREE.PointsMaterial({ color: 0x9bb8c8, size: 0.02, transparent: true, opacity: 0.5, blending: THREE.AdditiveBlending, depthWrite: false })
      );
      scene.add(stars);

      // ---------- Sizing ----------
      const wrap = canvas.parentElement!;
      function resize() {
        const w = wrap.clientWidth, h = wrap.clientHeight;
        if (!w || !h) return;
        renderer.setSize(w, h, false);
        camera.aspect = w / h;
        camera.updateProjectionMatrix();
      }
      resize();
      new ResizeObserver(resize).observe(wrap);

      let visible = true;
      new IntersectionObserver(([e]) => { visible = e.isIntersecting; }, { threshold: 0 }).observe(wrap);

      // ---------- Loop ----------
      let cmx = 0, cmy = 0, lastT = 0;
      function tick(t: number) {
        if (!reduceMotion) requestAnimationFrame(tick);
        if (!visible && !reduceMotion) return;
        const dt = Math.min((t - lastT) / 1000, 0.05) || 0.016;
        lastT = t;
        const ts = t / 1000;

        cmx += (mx - cmx) * 0.05;
        cmy += (my - cmy) * 0.05;
        site.rotation.y = Math.sin(ts * 0.28) * 0.16 + cmx * 0.12;
        site.rotation.x = -0.04 + Math.sin(ts * 0.4) * 0.03 - cmy * 0.06;
        site.position.y = Math.sin(ts * 0.7) * 0.06;

        cards.forEach((card, i) => {
          card.position.y = -0.92 + Math.sin(ts * (0.9 + i * 0.27) + i * 2.1) * 0.055;
          card.position.z = 0.3 + Math.sin(ts * 0.6 + i * 1.4) * 0.05;
          // click pop: quick swell that eases back
          card.userData.pop = Math.max(0, (card.userData.pop ?? 0) - dt * 2.5);
          const pop = card.userData.pop;
          // hover swell: is this card's body the hovered mesh?
          const isHovered = hovered && hovered.userData.interactive?.payload?.card === card;
          card.userData.hoverScale = (card.userData.hoverScale ?? 1) +
            (((isHovered ? 1.08 : 1) + Math.sin(pop * Math.PI) * 0.12) - (card.userData.hoverScale ?? 1)) * Math.min(1, dt * 10);
          card.scale.setScalar(card.userData.hoverScale);
          // per-card equalizer (frenzy after a click)
          card.userData.frenzy = Math.max(0, (card.userData.frenzy ?? 0) - dt);
          const frenzy = 1 + card.userData.frenzy * 4;
          card.userData.statBars.forEach((stat: any, s: number) => {
            stat.scale.y = 0.35 + Math.abs(Math.sin(ts * (1.6 + s * 0.42) * frenzy + i * 1.3 + s)) * (0.75 + card.userData.frenzy * 0.4);
          });
        });

        // hover glow on any interactive element
        interactables.forEach((mesh) => {
          if (!mesh.material?.userData) mesh.material.userData = {};
          if (mesh.material.userData.baseOpacity === undefined) mesh.material.userData.baseOpacity = mesh.material.opacity;
          const target = mesh === hovered ? Math.min(1, mesh.material.userData.baseOpacity + 0.25) : mesh.material.userData.baseOpacity;
          mesh.material.opacity += (target - mesh.material.opacity) * Math.min(1, dt * 12);
        });

        // hero gradient shimmer; clicking triggers a fast sweep
        heroSweep = Math.max(0, heroSweep - dt);
        heroTex.offset.x = (heroTex.offset.x + dt * (0.04 + heroSweep * 0.9)) % 1;

        // phone spin (eases toward its accumulated target)
        phone.userData.spinCur = (phone.userData.spinCur ?? 0) + (phoneSpin - (phone.userData.spinCur ?? 0)) * Math.min(1, dt * 4);

        // particle bursts: drift, fall, fade
        particles.forEach((p) => {
          if (p.userData.life <= 0) return;
          p.userData.life -= dt * 1.4;
          p.userData.vel.y -= dt * 2.2; // gravity
          p.userData.vel.multiplyScalar(1 - dt * 1.6); // drag
          p.position.addScaledVector(p.userData.vel, dt);
          p.material.opacity = Math.max(0, p.userData.life) * 0.95;
        });

        // skeleton lines pulse like streaming content
        lines.forEach((line, i) => {
          line.material.opacity = 0.1 + Math.abs(Math.sin(ts * 1.2 - i * 0.9)) * 0.16;
        });

        // phone bobs on its own rhythm (+ any click-spin still easing out)
        phone.position.y = -0.25 + Math.sin(ts * 0.55 + 1.7) * 0.09;
        phone.rotation.y = 0.42 + Math.sin(ts * 0.3) * 0.05 + (phone.userData.spinCur ?? 0);

        // agent cursor works through the page: ease between waypoints, pause,
        // pulse on arrival — like someone is building the site live
        wpT += dt * 0.55;
        if (wpT >= 1.6) { // 1.0 travel + 0.6 dwell
          wpT = 0;
          wpIndex = (wpIndex + 1) % waypoints.length;
          wpFrom = wpTo;
          wpTo = waypoints[(wpIndex + 1) % waypoints.length];
        }
        const travel = Math.min(wpT, 1);
        const eased = travel * travel * (3 - 2 * travel);
        cursor.position.set(
          wpFrom[0] + (wpTo[0] - wpFrom[0]) * eased,
          wpFrom[1] + (wpTo[1] - wpFrom[1]) * eased,
          wpFrom[2] + (wpTo[2] - wpFrom[2]) * eased
        );
        // click pulse just after arrival
        const dwell = Math.max(0, wpT - 1);
        cursor.scale.setScalar(0.16 + (dwell > 0 ? Math.sin(Math.min(dwell / 0.3, 1) * Math.PI) * 0.10 : 0));

        // drifting colored orbs
        orbs.forEach((orb, i) => {
          const [bx, by, bz] = orb.userData.base;
          orb.position.set(
            bx + Math.sin(ts * 0.22 + i * 1.9) * 0.35,
            by + Math.cos(ts * 0.18 + i * 1.1) * 0.28,
            bz + Math.sin(ts * 0.15 + i) * 0.2
          );
          orb.material.opacity = 0.3 + Math.abs(Math.sin(ts * 0.5 + i * 2.2)) * 0.2;
        });

        // light streaks race toward the horizon and loop
        streaks.forEach((streak) => {
          streak.position.z += dt * streak.userData.speed;
          if (streak.position.z > 4) streak.position.z = -9;
        });

        stars.rotation.y += dt * 0.01;
        stars.material.opacity = 0.42 + Math.sin(ts * 1.1) * 0.12; // twinkle
        grid.position.z = (ts * 0.35) % 0.9; // slow crawl toward the camera

        renderer.render(scene, camera);
      }
      requestAnimationFrame(tick);
    });
  }

  initRenderScenes();
  document.addEventListener('astro:page-load', initRenderScenes);
</script>
