---
import { ClientRouter } from 'astro:transitions';
import '@fontsource-variable/inter/opsz.css';
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import ButterflyRider from '../components/ButterflyRider.astro';

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'ProfessionalService',
  name: 'KAIRA',
  description:
    'KAIRA helps local businesses build a modern online presence through professional websites, SEO fundamentals, and ongoing website maintenance.',
  url: Astro.site?.toString(),
  priceRange: 'Websites starting at $1,000',
  areaServed: 'United States',
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <!-- v=2 busts caches from the old butterfly mark -->
    <link rel="icon" href="/favicon.ico" sizes="32x32 48x48" />
    <link rel="icon" href="/favicon.svg?v=2" type="image/svg+xml" />
    <link rel="icon" href="/favicon-192.png?v=2" type="image/png" sizes="192x192" />
    <link rel="apple-touch-icon" href="/favicon-192.png?v=2" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <meta name="theme-color" content="#09090b" />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="KAIRA" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
    <ClientRouter />
  </head>
  <body class="min-h-dvh flex flex-col">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 focus:z-50 focus:rounded-lg focus:bg-violet focus:px-4 focus:py-2 focus:text-white"
    >
      Skip to content
    </a>
    <Nav />
    <main id="main" class="relative z-[2] flex-1">
      <slot />
    </main>
    <Footer />
    <ButterflyRider />

    <script>
      // Scroll-reveal: dependency-free IntersectionObserver.
      // Re-runs on astro:page-load so view transitions keep reveals working.
      function initReveal() {
        const els = document.querySelectorAll('.reveal:not(.is-visible)');
        if (!els.length) return;
        if (!('IntersectionObserver' in window)) {
          els.forEach((el) => el.classList.add('is-visible'));
          return;
        }
        const io = new IntersectionObserver(
          (entries) => {
            for (const e of entries) {
              if (e.isIntersecting) {
                e.target.classList.add('is-visible');
                io.unobserve(e.target);
              }
            }
          },
          { threshold: 0.15, rootMargin: '0px 0px -40px 0px' }
        );
        els.forEach((el) => io.observe(el));
      }
      initReveal();
      document.addEventListener('astro:page-load', initReveal);

      // ---- Apple-style scroll engine ----
      // 1) .reveal-words: wrap each word in a staggered span (preserves nested
      //    markup like gradient <span>s by walking text nodes).
      // 2) .scrub: drive --p (0..1) from scroll position — pinned formula for
      //    .scroll-scene wrappers, travel-through-viewport otherwise.
      const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      function splitWords() {
        if (reduceMotion) return;
        document.querySelectorAll<HTMLElement>('.reveal-words:not([data-split])').forEach((el) => {
          el.dataset.split = '1';
          let wi = 0;
          const walk = (node: Node) => {
            if (node.nodeType === Node.TEXT_NODE) {
              const parts = (node.textContent ?? '').split(/(\s+)/);
              if (parts.length <= 1) return;
              const frag = document.createDocumentFragment();
              for (const part of parts) {
                if (!part) continue;
                if (/^\s+$/.test(part)) {
                  frag.appendChild(document.createTextNode(part));
                } else {
                  const w = document.createElement('span');
                  w.className = 'w';
                  w.style.setProperty('--wi', String(wi++));
                  w.textContent = part;
                  frag.appendChild(w);
                }
              }
              node.parentNode?.replaceChild(frag, node);
            } else if (node.nodeType === Node.ELEMENT_NODE) {
              const elNode = node as HTMLElement;
              // Gradient spans reveal as one unit — splitting words inside
              // background-clip:text breaks the gradient in some browsers.
              if (elNode.classList?.contains('grad-text')) {
                elNode.classList.add('w');
                elNode.style.setProperty('--wi', String(wi++));
                return;
              }
              [...node.childNodes].forEach(walk);
            }
          };
          [...el.childNodes].forEach(walk);
          // reveal via the same IO pattern as .reveal
          new IntersectionObserver(
            (entries, io) => {
              for (const e of entries) {
                if (e.isIntersecting) {
                  e.target.classList.add('is-visible');
                  io.disconnect();
                }
              }
            },
            { threshold: 0.35 }
          ).observe(el);
        });
      }

      let scrubEls: HTMLElement[] = [];
      let scrubQueued = false;
      function measureScrubs() {
        scrubEls = [...document.querySelectorAll<HTMLElement>('.scrub')];
        updateScrubs();
      }
      function updateScrubs() {
        scrubQueued = false;
        if (reduceMotion) return;
        const vh = window.innerHeight;
        for (const el of scrubEls) {
          if (!el.isConnected) continue;
          const r = el.getBoundingClientRect();
          let p;
          if (el.classList.contains('scroll-scene')) {
            // pinned: progress through the extra height while the stage is stuck
            p = -r.top / Math.max(r.height - vh, 1);
          } else {
            // travel: 0 when entering from below, 1 when leaving above
            p = (vh - r.top) / (vh + r.height);
          }
          el.style.setProperty('--p', String(Math.min(1, Math.max(0, p))));
        }
      }
      function onScrubScroll() {
        if (!scrubQueued) {
          scrubQueued = true;
          requestAnimationFrame(updateScrubs);
        }
      }

      function initScrollEngine() {
        splitWords();
        measureScrubs();
      }
      initScrollEngine();
      window.addEventListener('scroll', onScrubScroll, { passive: true });
      window.addEventListener('resize', onScrubScroll);
      document.addEventListener('astro:page-load', initScrollEngine);
    </script>
  </body>
</html>
